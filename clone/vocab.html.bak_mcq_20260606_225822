    function refreshShareTokensList() {
        var listEl = document.getElementById('share-tokens-list');
        if (!listEl) return;
        listEl.innerHTML = '<div style="color:#6b7280">טוען...</div>';
        _activeTokenForDialogCat = null;
        _renderActiveShareLinkBox();
        var token = _vocabAuthToken();
        if (!token) { listEl.innerHTML = '<div style="color:#dc2626">לא מחובר</div>'; return; }
        var dialogCat = (document.getElementById('share-link-cat') || {}).textContent || '';
        // Plonter task #11 (2026-04-29): for built-in categories use the
        // communal endpoint so authorized users (Amitai/Dragon/King) see the
        // whole team's share-links and avoid creating duplicates. Personal
        // categories keep the original list_tokens behavior (caller's only).
        var isBuiltinCat = (typeof BUILTIN_CATEGORIES !== 'undefined') &&
            BUILTIN_CATEGORIES.hasOwnProperty(dialogCat);
        var fetchUrl = '/plonter/api/vocab_share_api.php?action=' +
            (isBuiltinCat ? 'list_tokens_for_category' : 'list_tokens');
        var fetchOpts = {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token }
        };
        if (isBuiltinCat) fetchOpts.body = JSON.stringify({ category: dialogCat });
        fetch(fetchUrl, fetchOpts).then(function(r) { return r.json(); }).then(function(j) {
            if (!j.success) { listEl.innerHTML = '<div style="color:#dc2626">' + (j.error || 'שגיאה') + '</div>'; return; }
            var scope = j.scope || 'mine';
            if (!j.items || !j.items.length) {
                var emptyMsg = (scope === 'all_owners')
                    ? 'אין קישורים לקטגוריה הזאת אצל אף אחד מהצוות'
                    : 'אין קישורים פעילים';
                listEl.innerHTML = '<div style="color:#6b7280;text-align:center;padding:12px">' + emptyMsg + '</div>';
                return;
            }
            // Find the freshest active token for the dialog's category and
            // surface it at the top. In all_owners scope, it might be someone
            // else's — surface it anyway so we don't double up.
            var matches = j.items.filter(function(t) {
                return !t.revoked && !t.expired && String(t.category) === String(dialogCat);
            });
            if (matches.length) {
                matches.sort(function(a, b) { return (b.expires_at || 0) - (a.expires_at || 0); });
                _activeTokenForDialogCat = matches[0];
                _renderActiveShareLinkBox();
            }
            // Plonter task #25 (2026-04-29) — de-duplicate: if a token is
            // surfaced in the top 'קישור מוכן' active box, filter it out of
            // the bottom 'קישורים קיימים' list so users don't see the same
            // link twice.
            var surfacedToken = _activeTokenForDialogCat ? _activeTokenForDialogCat.token : null;
            var filteredItems = surfacedToken
                ? j.items.filter(function(t) { return t.token !== surfacedToken; })
                : j.items;
            var html = '';
            if (scope === 'all_owners') {
                var safeDialogCat = String(dialogCat).replace(/[&<>"]/g, function(c) { return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]; });
                html += '<div style="font-size:0.85em;color:#6366f1;margin-bottom:8px;font-weight:600">הקישורים של כל הצוות לקטגוריה ' + safeDialogCat + ':</div>';
            }
            if (filteredItems.length === 0 && surfacedToken) {
                html += '<div style="font-size:0.85em;color:#9ca3af;text-align:center;padding:8px">אין קישורים נוספים מעבר למוצג למעלה</div>';
                listEl.innerHTML = html;
                return;
            }
            filteredItems.forEach(function(t) {
                var status = t.revoked ? '🚫 בוטל' : (t.expired ? '⏰ פג תוקף' : '✅ פעיל');
