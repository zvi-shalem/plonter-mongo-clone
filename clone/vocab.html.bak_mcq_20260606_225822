                matchClick('right', matchPairs.indexOf(w), el);
            };
            rightCol.appendChild(el);
        });

        // Image-question categories show the flag on the LEFT (Hebrew)
        // column; the RIGHT (Arabic) column stays as the country-name text.
        // Pair index is unchanged so matching logic still works.
        var _matchImageMode = _getCategoryQuestionType(currentCategory) === 'image';
        leftOrder.forEach(function(w, i) {
            var el = document.createElement('div');
            el.className = 'matching-item';
            if (_matchImageMode && w.image) {
