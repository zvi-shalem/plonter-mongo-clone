        try { _wireTriviaGameAreaLongPress(); } catch (_) {}
    }
    // Long-press on the trivia game container itself (sub-feature 2 of TODO
    // #541 PHASE A). Distinct from the trivia tab long-press: uses SESSION
    // buckets keyed off `_triviaSessionState`, not lifetime stats. Idempotent
    // because `_attachLongPress` flags `_lpBound` on the element.
    function _wireTriviaGameAreaLongPress() {
        var area = document.getElementById('trivia-mode');
        if (!area) return;
        _attachLongPress(area, function() {
            var groups = _buildTriviaSessionGroups();
            if (!groups) {
                _showCopyBucketToast('לא נטענה קטגוריה', false);
                return;
            }
            _copyGroupedWords('טריוויה (סשן)', groups, function(gs) {
                var c = function(i) { return (gs[i] && gs[i].words) ? gs[i].words.length : 0; };
                return 'הועתק — ' + c(0) + ' לא ראיתי, ' + c(1) + ' צדקתי, ' +
                    c(2) + ' טעיתי, ' + c(3) + ' לא סגור';
            });
        });
    }

    function _copyBucketWords(words, bucketLabel) {
        if (!words || !words.length) {
            _showCopyBucketToast('המחסן ריק (' + bucketLabel + ')', false);
            return;
        }
        var lines = words.map(function(w) {
            var ar = (w && w.arabic) ? String(w.arabic) : '';
            var he = (w && w.hebrew) ? String(w.hebrew) : '';
            return ar + ' — ' + he;
        });
        var text = lines.join('\n');
        var done = function(ok) {
            _showCopyBucketToast(ok ? '✅ הועתקו ' + words.length + ' מילים מ"' + bucketLabel + '"' : '❌ העתקה נכשלה', ok);
        };
        if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text).then(function() { done(true); }, function() { _legacyCopy(text, done); });
        } else {
            _legacyCopy(text, done);
        }
    }
    function _legacyCopy(text, done) {
        try {
            var ta = document.createElement('textarea');
            ta.value = text;
            ta.style.cssText = 'position:fixed;left:0;top:0;opacity:0';
            document.body.appendChild(ta);
            ta.focus(); ta.select();
            var ok = document.execCommand('copy');
            ta.remove();
            done(!!ok);
        } catch (_) { done(false); }
    }

    // Module-level cache of last-rendered trivia bucket contents so the long-press
    // handler can grab them without re-deriving from stats.
    var _lastTriviaCorrectWords = [];
    var _lastTriviaWrongWords = [];
    var _lastTriviaNotSureWords = [];

    function _wireFlashcardWarehouseLongPress() {
        var fcLabels = { known: 'ידעתי', unknown: 'לא ידעתי', notsure: 'ממש לא ידעתי' };
        var fcGetters = {
            known: function() { return fcKnownWords; },
            unknown: function() { return fcUnknownWords; },
            notsure: function() { return fcNotSureWords; }
        };
        Object.keys(fcLabels).forEach(function(k) {
            var btn = document.getElementById('fc-bf-' + k);
            if (btn) _attachLongPress(btn, function() { _copyBucketWords(fcGetters[k](), fcLabels[k]); });
            var hdr = document.querySelector('.fc-list-header.' + k + '-header');
            if (hdr) _attachLongPress(hdr, function() { _copyBucketWords(fcGetters[k](), fcLabels[k]); });
        });
    }
    function _wireTriviaWarehouseLongPress(rootEl) {
        if (!rootEl) return;
        var trvLabels = { correct: 'צדקתי', wrong: 'טעיתי', notsure: 'עדיין לא סגור' };
        var trvGetters = {
            correct: function() { return _lastTriviaCorrectWords; },
            wrong: function() { return _lastTriviaWrongWords; },
            notsure: function() { return _lastTriviaNotSureWords; }
        };
        rootEl.querySelectorAll('[data-trivia-bucket]').forEach(function(el) {
            var k = el.getAttribute('data-trivia-bucket');
            if (!trvLabels[k]) return;
            _attachLongPress(el, function() { _copyBucketWords(trvGetters[k](), trvLabels[k]); });
        });
    }

    function _ttsSupported() {
        return typeof window !== 'undefined' && typeof window.speechSynthesis !== 'undefined';
    }
    // Prime voices early — some browsers (Chrome Android especially) return
    // [] from getVoices() until onvoiceschanged fires at least once.
    if (_ttsSupported()) {
        try { window.speechSynthesis.getVoices(); } catch(_) {}
        if (typeof window.speechSynthesis.addEventListener === 'function') {
            window.speechSynthesis.addEventListener('voiceschanged', function() {
                try { window.speechSynthesis.getVoices(); } catch(_) {}
            });
        }
