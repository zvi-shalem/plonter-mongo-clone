        // _prepareTrimmedAudio fetches the blob, decodes it, finds the first non-silent
        // sample, and returns a blobUrl + offsetSec. We set audio.src = blobUrl and seek
        // to offsetSec before playing.
        var _autoPlayed = false;
        function _autoPlay() {
            if (_skipAutoplay) return;
            if (_autoPlayed) return;
