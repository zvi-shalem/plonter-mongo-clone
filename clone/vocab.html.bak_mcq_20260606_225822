        var closeBtn = panel.querySelector('[data-play-action="close"]');
        var seekEl = panel.querySelector('[data-play-seek]');
        var timeEl = panel.querySelector('[data-play-time]');
        var durEl = panel.querySelector('[data-play-dur]');

        var seeking = false;

        audio.addEventListener('loadedmetadata', function() {
            var d = audio.duration;
            if (isFinite(d) && d > 0) durEl.textContent = _vocabFmtTime(d * 1000);
        });
