                                        Dictionary.renderMilsonEntries(results, d3.entries, { includePin: false });
                                    } else {
                                        results.innerHTML = '<div style="color:#9ca3af;padding:16px;text-align:center">אין תוצאות עבור "' + clean + '"</div>';
                                    }
                                });
                            return;
                        }
                    }
                    results.innerHTML = '<div style="color:#9ca3af;padding:16px;text-align:center">אין תוצאות עבור "' + clean + '"</div>';
                    return;
                }
                Dictionary.renderMilsonEntries(results, data.entries, { includePin: false });
