                    memoryCurrentPlayer = 1 - memoryCurrentPlayer;
                    updateMemoryStatus();
                }
                setTimeout(function() {
                    c1.el.classList.remove('flipped');
                    c2.el.classList.remove('flipped');
                    memoryFlipped = [];
                    memoryLocked = false;
                }, 1000);
