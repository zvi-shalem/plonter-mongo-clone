        'N مُتَتَالِيَة مُمْتَاز':             'N ברצף, מצוין!',
        'سَبْعَة مُتَتَالِيَة':                 'שבעה ברצף!',
        'N مُتَتَالِيَة يَا بَطَل':             'N ברצף, יא גיבור!',
        // streakBig
        'N مُتَتَالِيَة':                       'N ברצף!',
        'N مُتَتَالِيَة أُسْطُورَة':            'N ברצף — אגדה!'
    };
    function normalizeForSentence(cleaned) {
        var s = cleaned.replace(/[،,.؟?—–\-]/g, ' ').replace(/\s+/g, ' ').trim();
        return s.replace(/[0-9\u0660-\u0669\u06F0-\u06F9]+/g, 'N');
    }
    function arabicDigitsToWestern(s) {
        return s.replace(/[\u0660-\u0669]/g, function(c) { return String.fromCharCode(0x30 + c.charCodeAt(0) - 0x0660); })
                .replace(/[\u06F0-\u06F9]/g, function(c) { return String.fromCharCode(0x30 + c.charCodeAt(0) - 0x06F0); });
    }
    function matchStalebetSentence(cleaned) {
        var norm = normalizeForSentence(cleaned);
        var translation = STALEBET_SENTENCES[norm];
        if (!translation) return null;
        var nums = cleaned.match(/[0-9\u0660-\u0669\u06F0-\u06F9]+/g);
        if (nums && nums.length && translation.indexOf('N') !== -1) {
            translation = translation.replace(/N/g, arabicDigitsToWestern(nums[0]));
        }
        return translation;
    }
    // Hard words = tokens / contiguous slices that appear in STALEBET_DICT.
    // Particles/articles/names not in the dict (من، إلى، في، الله) are filtered
    // out by construction. Multi-word sub-phrases strictly contained inside a
    // longer match are dropped.
    function extractHardWords(cleaned) {
        var norm = cleaned.replace(/[،,.؟?—–\-]/g, ' ').replace(/\s+/g, ' ').trim();
        var parts = norm.split(/\s+/).filter(Boolean);
        var seen = {}, found = [];
        for (var len = parts.length; len >= 1; len--) {
            for (var i = 0; i + len <= parts.length; i++) {
                var slice = parts.slice(i, i + len).join(' ');
                if (STALEBET_DICT[slice] && !seen[slice]) {
                    seen[slice] = true;
                    found.push({ key: slice, translation: STALEBET_DICT[slice], start: i, len: len });
                }
            }
        }
        found.sort(function(a, b) { return a.start - b.start || b.len - a.len; });
        var kept = [];
        found.forEach(function(hw) {
            var contained = kept.some(function(k) { return hw.start >= k.start && hw.start + hw.len <= k.start + k.len; });
            if (!contained) kept.push(hw);
        });
        return kept;
    }
    function escapeHtml(s) {
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }
    // Render the stalebet match into a results container (used by Dictionary
    // module AND the embedded vd-* dict panel in vocab.html). Takes the ORIGINAL
    // query so it can build a 3-layer layout: full-sentence translation on top,
    // hard-word breakdown in the middle, easter-egg fluff at the bottom.
    function renderStalebetInto(resultsEl, origQuery) {
        if (!resultsEl) return;
        var cleaned = stripForMatch(origQuery);
        var sentence = matchStalebetSentence(cleaned);
        var hardWords = extractHardWords(cleaned);

        var html = ['<div style="padding:16px;direction:rtl">'];

        if (sentence) {
            html.push('<div style="font-size:1.35em;font-weight:bold;text-align:center;margin-bottom:8px;font-family:Times New Roman,serif;color:#1f2937;line-height:1.6">' + escapeHtml(cleaned) + '</div>');
            html.push('<div style="font-size:1.15em;text-align:center;color:#0d9488;font-weight:bold;margin-bottom:14px;padding:8px 10px;background:#ecfdf5;border-radius:8px">' + escapeHtml(sentence) + '</div>');
        } else if (hardWords.length === 1) {
            var key = hardWords[0].key;
            var lines = hardWords[0].translation.split('\n').filter(function(l) { return l.trim(); });
            html.push('<div style="font-size:1.6em;font-weight:bold;text-align:center;margin-bottom:12px;font-family:Times New Roman,serif">' + escapeHtml(key) + '</div>');
            html.push('<div style="font-size:1.2em;text-align:center;color:#0d9488;font-weight:bold;margin-bottom:8px">' + escapeHtml(lines[0]) + '</div>');
            lines.slice(1).forEach(function(l) {
                html.push('<div style="font-size:1.05em;text-align:center;color:#f59e0b;font-weight:bold;margin-top:8px">' + escapeHtml(l) + '</div>');
            });
        }

        if (hardWords.length > 0 && (sentence || hardWords.length > 1)) {
            html.push('<div style="margin:8px 0 14px;padding:10px 12px;background:#fef3c7;border-right:4px solid #f59e0b;border-radius:6px">');
            html.push('<div style="font-size:0.82em;color:#92400e;font-weight:bold;margin-bottom:6px">מילים חדשות / קשות:</div>');
            hardWords.forEach(function(hw) {
                var first = hw.translation.split('\n')[0];
                html.push('<div style="display:flex;justify-content:space-between;align-items:baseline;gap:12px;margin:5px 0;padding:5px 0;border-bottom:1px dashed #fde68a">' +
                    '<span style="font-family:Times New Roman,serif;font-size:1.2em;font-weight:bold;color:#1f2937">' + escapeHtml(hw.key) + '</span>' +
                    '<span style="color:#78350f;font-size:0.95em">' + escapeHtml(first) + '</span>' +
                    '</div>');
            });
            html.push('</div>');
        }

        html.push('<div style="text-align:center;color:#9ca3af;font-size:0.85em;margin-top:16px;padding-top:12px;border-top:1px dashed #e5e7eb">מילה שהובאה אליך מעיגולי החיוביות 🌟</div>');
        html.push('<div style="text-align:center;color:#6b7280;font-size:0.8em;margin-top:10px;line-height:1.6">תמשיך להיות סקרן, יאלוף!<br>ותמיד תזכור — הסקרנות הרגה את הנצראללה ;)</div>');
        html.push('</div>');
        resultsEl.innerHTML = html.join('');
    }

    // Returns true iff `word` has either a sentence-template match OR at least
    // one known hard-word. Any dict entry point calls this before short-circuiting.
    function hasStalebetMatch(word) {
        if (!word) return false;
        var clean = stripForMatch(word);
        if (matchStalebetSentence(clean)) return true;
        return !!resolveStalebet(clean);
    }
    // Expose for vd-* search functions (defined in an earlier <script> block).
    window.__plonterStalebetMatch = function(word, resultsId) {
        if (!hasStalebetMatch(word)) return false;
        renderStalebetInto(document.getElementById(resultsId), word);
        return true;
    };

    var origSearch = Dictionary._searchCurrentEngine.bind(Dictionary);
    Dictionary._searchCurrentEngine = function(word) {
        if (hasStalebetMatch(word)) {
            Dictionary._lastSearchedQuery = word;
            var msBtn = document.getElementById('dict-mobile-search-btn');
            if (msBtn) msBtn.style.display = 'none';
            var results = Dictionary._panel ? Dictionary._panel.querySelector('#dict-results') : null;
            renderStalebetInto(results, word);
            return;
        }
        origSearch(word);
    };

    // Wrap the embedded vocab-dict-panel search functions (vd-* ids) so a
    // stalebet-phrase query short-circuits before hitting milson/AI/Madrasa.
    ['vocabDictSearch', 'vdAiSearch', 'vdSpokenSearch'].forEach(function(fnName) {
        var orig = window[fnName];
        if (typeof orig !== 'function') return;
        var inputId = { vocabDictSearch: 'vd-input', vdAiSearch: 'vd-ai-input', vdSpokenSearch: 'vd-spoken-input' }[fnName];
        var resultsId = { vocabDictSearch: 'vd-results', vdAiSearch: 'vd-ai-results', vdSpokenSearch: 'vd-spoken-results' }[fnName];
        window[fnName] = function() {
            var inp = document.getElementById(inputId);
            var word = inp ? inp.value.trim() : '';
            if (window.__plonterStalebetMatch(word, resultsId)) return;
            return orig.apply(this, arguments);
        };
    });
})();
</script>

<!-- WhatsApp button attention bounce -->
<style>
@keyframes wa-attention-bounce { 0%{transform:scale(1)} 30%{transform:scale(1.15) translateY(-3px)} 50%{transform:scale(0.95)} 70%{transform:scale(1.08) translateY(-1px)} 100%{transform:scale(1)} }
.wa-bounce-btn { display:inline-block; }
</style>
<script>
(function() {
    function bounceLoop() {
        var btns = document.querySelectorAll('.wa-bounce-btn');
        btns.forEach(function(btn) {
            if (btn.offsetParent !== null) {
                btn.style.animation = 'none';
                btn.offsetHeight;
                btn.style.animation = 'wa-attention-bounce 0.5s ease';
                btn.addEventListener('animationend', function handler() {
                    btn.style.animation = '';
                    btn.removeEventListener('animationend', handler);
                });
            }
        });
        var next = 5000 + Math.random() * 7000;
        setTimeout(bounceLoop, next);
    }
    var initial = 5000 + Math.random() * 7000;
    setTimeout(bounceLoop, initial);
})();
</script>
<script>
/* Unified-site back-link fix (2026-06-04): when אוצם runs inside the unified
   Plonter clone (same-origin iframe), "חזרה לפלונטר" must return to the syntax
   view at the SAME address via the host's closeVocabView(), NOT a full top-level
   navigation to index.html (target=_top). Standalone use is unchanged. */
(function () {
    var embedded = false;
    try { embedded = window.self !== window.top; } catch (_) { embedded = true; }
    if (!embedded) return;
    document.addEventListener('click', function (e) {
        var a = e.target && e.target.closest ? e.target.closest('#back-link') : null;
        if (!a) return;
        // ONLY hijack the genuine "exit to Plonter" state: the back-link in vocab
        // HOME mode (href=index.html, target=_top, no in-app onclick). The in-app
        // back states — "← חזרה לקטגוריות" / "← חזור לקבוצה" / "↓ גלול למטה" — set
        // their OWN onclick (_exitGameTo / _scrollHomeCategoriesDown) and href='#';
        // those must run natively so the user can navigate back to the category
        // list and pick categories. Do NOT touch them. (Amitai bug 2026-06-04.)
        if (typeof a.onclick === 'function') return;
        if (a.getAttribute('target') !== '_top') return;
        e.preventDefault();
        e.stopPropagation();
        try {
            if (window.parent && typeof window.parent.closeVocabView === 'function') {
                window.parent.closeVocabView();
                return;
            }
        } catch (_) {}
        try { window.parent.location.hash = ''; } catch (_) {}
    }, true); // capture phase so it beats the element's own href/onclick
})();
</script>
