    function stalebetToast(type, replacements) {
        try {
            var pool = STALEBET_AR[type]; if (!pool || !pool.length) return;
            var msg = pool[Math.floor(Math.random() * pool.length)];
            if (replacements) Object.keys(replacements).forEach(function(k) { msg = msg.replace(new RegExp(k,'g'), replacements[k]); });
            var colorClass = type === 'wrong' ? 'wrong' : type.indexOf('streak') === 0 ? 'streak' : 'correct';
            var el = document.createElement('div');
            el.className = 'stalebet-toast ' + colorClass;
            el.textContent = msg;
            // Random position across the viewport (avoid very top/bottom edges)
            // top: 12%–80%, left: 8%–70% (so a 240px toast doesn't clip off the right)
            var topPct = 12 + Math.floor(Math.random() * 68);
            var leftPct = 8 + Math.floor(Math.random() * 62);
            el.style.top = topPct + '%';
            el.style.left = leftPct + '%';
            // Click to dismiss so it doesn't stay stuck on screen.
            // Tapping also triggers a little confetti burst for fun (Amitai 2026-04-15).
            var dismiss = function(fromClick) {
                if (el._dismissed) return;
                el._dismissed = true;
                if (fromClick) _stalebetBurstAt(el);
                el.classList.add('hiding');
                // Match stalebetShrink animation duration (0.08s per Amitai 2026-04-19) before unmounting.
                setTimeout(function() { if (el.parentNode) el.parentNode.removeChild(el); }, 90);
            };
            el.addEventListener('click', function(ev) {
                try { navigator.clipboard.writeText(msg); } catch(e) {}
                dismiss(true);
            });
            document.body.appendChild(el);
            requestAnimationFrame(function() { el.classList.add('show'); });
            setTimeout(function() { dismiss(false); }, 2800);
        } catch (e) {}
    }
    function _stalebetBurstAt(el) {
        try {
            var rect = el.getBoundingClientRect();
            var cx = rect.left + rect.width / 2;
            var cy = rect.top + rect.height / 2;
            var colors = ['#fbbf24','#34d399','#60a5fa','#f472b6','#a78bfa','#fde047','#fb923c','#f87171'];
            var N = 10;
            for (var i = 0; i < N; i++) {
                var p = document.createElement('div');
