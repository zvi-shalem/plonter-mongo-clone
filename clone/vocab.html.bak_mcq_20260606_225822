    function checkReverseConj() {
        var q = rconjQuestions[rconjIndex];
        var rootInput = document.getElementById('rconj-root').value.trim();
        var feedback = document.getElementById('rconj-feedback');
        rconjTotal++;

        // Normalize root comparison (strip spaces around dashes)
        var normalizeRoot = function(r) { return r.replace(/\s/g, '').replace(/-/g, ''); };
        // Accept multiple roots separated by comma — any match counts
        var rootCandidates = rootInput.split(/[,،]/).map(function(r) { return normalizeRoot(r.trim()); }).filter(function(r) { return r; });
        var correctRoot = normalizeRoot(q.root);
        var rootOk = rootCandidates.some(function(r) { return r === correctRoot; });

        // Map our tense IDs to what the question expects
        var tenseOk = false;
        if (rconjSelectedTense === q.tense) tenseOk = true;
        // Accept 'present' for 'future_indicative' since Arabic مضارع serves both
        if (q.tense === 'present' && rconjSelectedTense === 'present') tenseOk = true;

        var binyanOk = rconjSelectedBinyan === q.binyan;
        var personOk = rconjSelectedPerson && rconjSelectedPerson.he === q.person.he;

        var allCorrect = rootOk && tenseOk && binyanOk && personOk;

        if (allCorrect) {
            rconjCorrect++; rconjStreak++;
            if (rconjStreak > rconjBestStreak) rconjBestStreak = rconjStreak;
            var msg = rconjStreak >= 3 ? 'נכון! 🔥 רצף ' + rconjStreak : 'נכון!';
            feedback.innerHTML = msg;
            feedback.className = 'trivia-feedback show correct-feedback';
        } else {
            rconjStreak = 0;
            var tenseLabel = RCONJ_TENSES.find(function(t) { return t.id === q.tense; });
            var wrongParts = [];
            if (!rootOk) wrongParts.push('שורש: ' + q.root);
            if (!binyanOk) wrongParts.push('בניין: ' + q.binyan);
            if (!tenseOk) wrongParts.push('זמן: ' + (tenseLabel ? tenseLabel.label : q.tense));
            if (!personOk) wrongParts.push('גוף: ' + q.person.he + ' (' + q.person.ar + ')');
            feedback.innerHTML = 'לא נכון — ' + wrongParts.join(' · ');
            feedback.className = 'trivia-feedback show wrong-feedback';
        }

        if (q.verb.notes) {
            feedback.innerHTML += '<br><span style="font-size:0.85em;color:#6b7280;margin-top:4px;display:inline-block">📝 ' + q.verb.notes + '</span>';
        }

        document.getElementById('rconj-submit').disabled = true;
        document.getElementById('rconj-submit').style.display = 'none';
        renderStreakBar('rconj-streak-bar', rconjStreak, rconjBestStreak);
        document.getElementById('rconj-score').textContent = rconjCorrect + ' / ' + rconjTotal + ' נכון';
        var nextBtn = document.getElementById('rconj-next');
        nextBtn.style.display = 'block';
        nextBtn.className = allCorrect ? 'trivia-next correct-next' : 'trivia-next';
        setTimeout(function() { nextBtn.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 100);
    }

