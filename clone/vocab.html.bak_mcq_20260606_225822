    function startMemory(players) {
        memoryPlayers = players;
        memoryCurrentPlayer = 0;
        memoryScores = [0, 0];
        memoryFlipped = [];
        memoryLocked = false;
        memoryAttempts = 0;

        if (players === 2) {
            var n1 = document.getElementById('memory-p1').value.trim();
            var n2 = document.getElementById('memory-p2').value.trim();
            memoryNames = [n1 || 'שחקן 1', n2 || 'שחקן 2'];
        }

        document.getElementById('memory-setup').style.display = 'none';
        document.getElementById('memory-result').style.display = 'none';

        var words = getCategoryWords(currentCategory);
        if (words.length < 2) return;
        var pool = words.slice();
        shuffle(pool);
        // Pick pairs: up to 8 for a 4x4 grid (16 cards)
        var count = Math.min(7, pool.length);
        var selected = pool.slice(0, count);

        // Create card data: each word becomes 2 cards (arabic + hebrew)
        memoryCards = [];
        selected.forEach(function(w, i) {
            memoryCards.push({ pairId: i, text: w.arabic, lang: 'arabic', word: w });
            memoryCards.push({ pairId: i, text: w.hebrew, lang: 'hebrew', word: w });
        });
        shuffle(memoryCards);
        memoryPairsLeft = count;
        memoryStartTime = Date.now();

        var grid = document.getElementById('memory-grid');
        grid.innerHTML = '';
        // Adjust columns based on total cards
        var totalCards = memoryCards.length;
        if (totalCards <= 8) grid.style.gridTemplateColumns = 'repeat(4, 1fr)';
        else if (totalCards <= 12) grid.style.gridTemplateColumns = 'repeat(4, 1fr)';
        else grid.style.gridTemplateColumns = 'repeat(4, 1fr)';

        // Image-question categories swap the Hebrew side of each pair for
        // the flag image; the Arabic side stays as text. The pair is still
        // matched by pairId, so matching logic is unchanged. Amitai
