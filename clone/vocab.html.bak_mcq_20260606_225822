    // transition (user→user, user→guest, guest→user) wipes local vocab
    // state so the new owner starts clean. Server copies stay intact;
    // ContentSync.pullAll + VocabProgressSync rehydrate for logged-in
    // users. Guest never pulls (no token), so guest always starts fresh.
    function _currentVocabOwner() {
        try {
            if (typeof PlonterAuth !== 'undefined' && PlonterAuth.isLoggedIn && PlonterAuth.isLoggedIn()) {
                return localStorage.getItem('plonter_data_owner') || 'unknown-user';
            }
        } catch (_) {}
        return 'guest';
    }
    // Same prefix set as auth.js _clearUserScopedContent (the authoritative
    // list maintained by @3). Kept in sync manually — update both together.
    var _VOCAB_ISOLATION_PREFIXES = ['plonter_vocab_', 'plonter_trivia_', 'plonter_fc_', 'plonter_stars_'];
    // Keys that match a prefix but must survive the wipe. Including the
    // one-shot migration flags is critical: if wiped, VocabProgressSync's
    // lazy _migrateIfNeeded re-runs at the next save and pushes the
    // now-empty LS to the server, stomping user B's progress row.
    // (Amitai 2026-04-20 14:01 regression: progress reset on user switch.)
    var _VOCAB_ISOLATION_PRESERVE = {
        'plonter_vocab_active_owner': true,
        'plonter_vocab_progress_migrated_v1': true,
        'plonter_vocab_stars_per_cat_migrated_v1': true,
        'plonter_vocab_builtins_server_cleanup_v1': true,
        'plonter_vocab_stars_migrated_v2': true
    };
    // Guest-progress shadow: `<prefix>guest_backup_<rest>` — e.g.
    //   plonter_vocab_v2           → plonter_vocab_guest_backup_v2
    //   plonter_fc_state_<cat>     → plonter_fc_guest_backup_state_<cat>
    //   plonter_stars_<cat>        → plonter_stars_guest_backup_<cat>
    //   plonter_trivia_stats       → plonter_trivia_guest_backup_stats
    // Shadow keys must SURVIVE _wipeVocabScopedProgress so guest data
    // persists across user sessions (Amitai 2026-04-21 00:57: "each
    // keeps own" — reversal of the 2026-04-20 12:53 clean-wipe rule).
    var _VOCAB_SHADOW_INFIX = 'guest_backup_';
    function _isShadowKey(k) { return k && k.indexOf(_VOCAB_SHADOW_INFIX) >= 0; }
    function _shadowKeyFor(k) {
        for (var p = 0; p < _VOCAB_ISOLATION_PREFIXES.length; p++) {
            var pref = _VOCAB_ISOLATION_PREFIXES[p];
            if (k.indexOf(pref) === 0) return pref + _VOCAB_SHADOW_INFIX + k.slice(pref.length);
        }
        return null;
    }
    function _originalKeyFor(shadowKey) {
        for (var p = 0; p < _VOCAB_ISOLATION_PREFIXES.length; p++) {
            var pref = _VOCAB_ISOLATION_PREFIXES[p];
            var shadowPref = pref + _VOCAB_SHADOW_INFIX;
            if (shadowKey.indexOf(shadowPref) === 0) return pref + shadowKey.slice(shadowPref.length);
        }
        return null;
    }
    function _snapshotGuestToShadow() {
        // Called before wiping on guest→user: copy each live guest key
        // to its shadow slot. Overwrites any prior shadow (shadow always
        // reflects the most recent guest state).
        var toCopy = [];
        for (var i = 0; i < localStorage.length; i++) {
            var k = localStorage.key(i);
            if (!k) continue;
            if (_VOCAB_ISOLATION_PRESERVE[k]) continue;
            if (_isShadowKey(k)) continue;
            for (var p = 0; p < _VOCAB_ISOLATION_PREFIXES.length; p++) {
                if (k.indexOf(_VOCAB_ISOLATION_PREFIXES[p]) === 0) { toCopy.push(k); break; }
            }
        }
        toCopy.forEach(function(k) {
            try {
                var shadow = _shadowKeyFor(k);
                if (shadow) localStorage.setItem(shadow, localStorage.getItem(k));
            } catch(_) {}
        });
    }
    function _restoreShadowToGuest() {
        // Called after wiping on user→guest: copy each shadow back to
        // its original key. Shadow entries are NOT deleted — they stay
        // as the rolling guest snapshot for future user→guest cycles.
        // No-op if no shadow exists (first-ever user before any guest
        // data was saved) — guest then starts fresh, matching the
        // pre-shadow behavior.
        var toRestore = [];
        for (var i = 0; i < localStorage.length; i++) {
            var k = localStorage.key(i);
            if (_isShadowKey(k)) toRestore.push(k);
        }
        toRestore.forEach(function(sk) {
            try {
                var orig = _originalKeyFor(sk);
                if (orig) localStorage.setItem(orig, localStorage.getItem(sk));
            } catch(_) {}
        });
    }
    function _wipeVocabScopedProgress() {
        var toRemove = [];
        for (var i = 0; i < localStorage.length; i++) {
            var k = localStorage.key(i);
            if (!k) continue;
            if (_VOCAB_ISOLATION_PRESERVE[k]) continue;
            if (_isShadowKey(k)) continue;
            for (var p = 0; p < _VOCAB_ISOLATION_PREFIXES.length; p++) {
                if (k.indexOf(_VOCAB_ISOLATION_PREFIXES[p]) === 0) {
                    toRemove.push(k);
                    break;
                }
            }
        }
        toRemove.forEach(function(k) { try { localStorage.removeItem(k); } catch(_) {} });
    }
    // Armed after we're sure about auth state: either PlonterAuth.onLogin
    // fired (user logged in, login() fired synchronously from init() if the
    // session cookie restored), or the 2s safety timeout elapsed without a
    // login (truly guest). Before arming we return silently so we never
    // wipe during the brief window where isLoggedIn() is false before
    // init() restores the session — otherwise a logged-in user reloading
    // the page would see their unsynced data nuked.
    var _vocabIsolationArmed = false;
    function _enforceVocabOwnerIsolation() {
        if (!_vocabIsolationArmed) return;
        var current = _currentVocabOwner();
        var stored = null;
        try { stored = localStorage.getItem('plonter_vocab_active_owner'); } catch(_) {}
        // Owner transition — wipe the outgoing owner's LS state so the
        // incoming owner doesn't see it. user→user/user→guest/guest→user
        // all wipe, BUT guest's data survives the cross-user-cycle via
        // a shadow snapshot (Amitai 2026-04-21 00:57 "each keeps own"):
        //   guest → user: snapshot guest LS into shadow, then wipe guest.
        //     The user then pulls from the server as usual.
        //   user → guest: wipe the user's LS, then restore the shadow
        //     back over the guest keys (no-op if no shadow yet).
        //   user → user: plain wipe — both sides have server truth.
        if (stored !== null && stored !== current) {
            if (stored === 'guest' && current !== 'guest') {
                _snapshotGuestToShadow();
                _wipeVocabScopedProgress();
            } else if (stored !== 'guest' && current === 'guest') {
                _wipeVocabScopedProgress();
                _restoreShadowToGuest();
            } else {
                _wipeVocabScopedProgress();
            }
        }
        try { localStorage.setItem('plonter_vocab_active_owner', current); } catch(_) {}
    }

    function getCustomData() {
        try { return JSON.parse(localStorage.getItem('plonter_vocab_v2') || '{}'); }
        catch(e) { return {}; }
    }
    function saveCustomData(data) {
        // Snapshot the pre-save category names so we can tell VocabSync
        // about deletions — without this, deleting a category leaks it on
        // the server forever (survives login from any other device).
        var prevNames = [];
        try {
            var prev = JSON.parse(localStorage.getItem('plonter_vocab_v2') || '{}');
            prevNames = Object.keys(prev || {});
        } catch (_) {}
        localStorage.setItem('plonter_vocab_v2', JSON.stringify(data));
        try {
            if (typeof VocabSync !== 'undefined') {
                var names = Object.keys(data || {});
                var surviving = {};
                for (var i = 0; i < names.length; i++) surviving[names[i]] = true;
                if (VocabSync.onCategorySaved) {
                    for (var j = 0; j < names.length; j++) VocabSync.onCategorySaved(names[j]);
                }
                if (VocabSync.onCategoryDeleted) {
                    for (var k = 0; k < prevNames.length; k++) {
                        if (!surviving[prevNames[k]]) VocabSync.onCategoryDeleted(prevNames[k]);
                    }
                }
            }
        } catch (e) { console.warn('[vocab] VocabSync hook threw', e); }
    }

    // ===== Ghost-deletion fix (task #51) =====
    // When a category or word is removed, its guest-mode backup must also be
    // pruned, otherwise the post-login restore prompt (_promptGuestBackupOnLogin
    // in auth.js — which builds its candidate list straight from
    // plonter_vocab_guest_backup_v2 + companion shadow keys) keeps re-offering
    // the deleted item ("מצאנו N קטגוריות שיצרת במצב אורח"). vocab has no separate
    // "handled" flag (unlike stages.js); the shadow content itself is what the
    // prompt reads, so the equivalent of "mark handled" is to remove the deleted
    // item from the shadow. Both helpers are PRECISE: they touch only the named
    // category's backup data and never wipe unrelated categories.
    function _pruneGuestVocabBackupForCategory(catName) {
        if (!catName) return;
        // 1. Vocab shadow dict (category-keyed mirror of plonter_vocab_v2).
        try {
            var raw = localStorage.getItem('plonter_vocab_guest_backup_v2');
            if (raw) {
                var shadow = JSON.parse(raw) || {};
                if (Object.prototype.hasOwnProperty.call(shadow, catName)) {
                    delete shadow[catName];
                    if (Object.keys(shadow).length) localStorage.setItem('plonter_vocab_guest_backup_v2', JSON.stringify(shadow));
                    else localStorage.removeItem('plonter_vocab_guest_backup_v2');
                }
            }
        } catch (_) {}
        // 2. Per-category companion shadow keys (flashcard state, stars). Derived
        //    via the existing _shadowKeyFor layout so they stay in sync with it.
        try { var kFc = _shadowKeyFor('plonter_fc_state_' + catName); if (kFc) localStorage.removeItem(kFc); } catch (_) {}
        try { var kSt = _shadowKeyFor('plonter_stars_' + catName); if (kSt) localStorage.removeItem(kSt); } catch (_) {}
        // 3. Global trivia shadow dicts are "<cat>::"-prefixed — prune ONLY this
        //    category's entries so other categories' trivia backup survives.
        ['plonter_trivia_stats', 'plonter_trivia_not_sure'].forEach(function(origKey) {
            try {
                var sk = _shadowKeyFor(origKey);
                if (!sk) return;
                var rawT = localStorage.getItem(sk);
                if (!rawT) return;
                var dict = JSON.parse(rawT) || {};
                var prefix = catName + '::';
                var changed = false;
                Object.keys(dict).forEach(function(kk) { if (kk.indexOf(prefix) === 0) { delete dict[kk]; changed = true; } });
                if (changed) {
                    if (Object.keys(dict).length) localStorage.setItem(sk, JSON.stringify(dict));
                    else localStorage.removeItem(sk);
                }
            } catch (_) {}
        });
    }
    function _syncGuestVocabBackupWords(catName, words) {
        // Word-level removal: drop from the shadow category any word no longer
        // present in the surviving list. Only updates a backup entry that already
        // exists — never creates one, never touches other categories, and keeps
        // surviving shadow words (and their fields) intact.
        if (!catName) return;
        try {
            var raw = localStorage.getItem('plonter_vocab_guest_backup_v2');
            if (!raw) return;
            var shadow = JSON.parse(raw) || {};
            var sCat = shadow[catName];
            if (!sCat || typeof sCat !== 'object' || !Array.isArray(sCat.words)) return;
            var keep = {};
            (words || []).forEach(function(w) { keep[(w.arabic || '') + '|' + (w.hebrew || '')] = true; });
            var before = sCat.words.length;
            sCat.words = sCat.words.filter(function(w) { return keep[(w.arabic || '') + '|' + (w.hebrew || '')]; });
            if (sCat.words.length !== before) localStorage.setItem('plonter_vocab_guest_backup_v2', JSON.stringify(shadow));
        } catch (_) {}
    }

    // VocabSync badge helper. Must be defined in the main script block (not
    // the auth-widget block further down) so the initial renderLanding()
    // call — which runs before auth_widget.js / vocabSync.js load — can
    // reference it without ReferenceError. Returns '' if VocabSync hasn't
    // registered yet; the later render (post-login / contentsync:change)
    // picks up the real badge. Built-in categories never show a badge —
    // Amitai 2026-04-19 20:41: "don't show 'לא מגובה' on built-ins."
    function _vocabBadge(catName) {
        try {
            if (BUILTIN_CATEGORIES && Object.prototype.hasOwnProperty.call(BUILTIN_CATEGORIES, catName)) return '';
            if (typeof VocabSync !== 'undefined' && VocabSync.getBadge) return VocabSync.getBadge(catName);
        } catch (e) { /* ignore */ }
        return '';
    }

    function getAllCategories() {
        var custom = getCustomData();
        var cats = {};
        // Builtin
        for (var name in BUILTIN_CATEGORIES) {
            var b = BUILTIN_CATEGORIES[name];
            var c = custom[name] || {};
            var words = c.overrideBuiltin ? (c.words || []) : (b.words || []).concat(c.words || []);
            var conj = c.overrideBuiltin ? (c.conjugations || []) : (b.conjugations || []).concat(c.conjugations || []);
            cats[name] = { words: words, conjugations: conj.length ? conj : null };
        }
        // Custom-only categories
        for (var name in custom) {
            if (!cats[name]) {
                cats[name] = { words: custom[name].words || [], conjugations: null };
            }
        }
        // Live shared categories opened from the public search. These are
        // read-through cache entries keyed by the server public category id.
        // They do not overwrite custom categories and they are safe to lose:
        // the server remains the source of truth, while deleted sources are
        // offered as "clone to myself" from the shared home panel.
        try {
            var shared = _publicGetCache();
            for (var sid in shared) {
                if (!Object.prototype.hasOwnProperty.call(shared, sid)) continue;
                var item = shared[sid];
                if (!item || item.is_deleted) continue;
                if (_publicIsPublished(item.source_cat_name || item.title || '')) continue;
                var publicName = _publicLocalName(item);
                if (!cats[publicName]) cats[publicName] = {
                    words: item.words || [],
                    conjugations: null,
                    publicShared: true,
                    publicSourceCatName: item.source_cat_name || item.title || '',
                    publicOwnerUserId: item.owner_user_id || null
                };
            }
        } catch (_) {}
        return cats;
    }

    function getCategoryWords(catName) {
        var cats = getAllCategories();
        return cats[catName] ? cats[catName].words : [];
    }

    function getCategoryConj(catName) {
        var cats = getAllCategories();
        return cats[catName] ? cats[catName].conjugations : null;
    }

    // Get all words across all categories (for trivia wrong answers)
    function getAllWords() {
        var all = [];
        var cats = getAllCategories();
        for (var name in cats) { all = all.concat(cats[name].words || []); }
        return all;
    }

    function _isPublicSharedCatName(catName) {
        if (!catName) return false;
        if (String(catName).indexOf('🌐 ') === 0) return true;
        try {
            var cats = getAllCategories();
            return !!(cats[catName] && cats[catName].publicShared);
        } catch (_) { return false; }
    }

    // ============ PUBLIC VOCAB SHARING ============
    var PUBLIC_VOCAB_API = '/plonter/api/vocab_public_api.php';
    var PUBLIC_VOCAB_CACHE_KEY = 'plonter_public_vocab_cache_v1';
    var PUBLIC_VOCAB_PUBLISHED_KEY = 'plonter_public_vocab_published_v1';

    function _publicEsc(s) {
        return String(s == null ? '' : s).replace(/[&<>"']/g, function(ch) {
            return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[ch];
        });
    }

    function _publicGetCache() {
        try { return JSON.parse(localStorage.getItem(PUBLIC_VOCAB_CACHE_KEY) || '{}'); }
        catch (_) { return {}; }
    }

    function _publicSaveCache(cache) {
        try { localStorage.setItem(PUBLIC_VOCAB_CACHE_KEY, JSON.stringify(cache || {})); } catch (_) {}
    }

    function _publicReplaceCacheFromItems(items) {
        var next = {};
        (items || []).forEach(function(item) {
            if (item && item.id) next[String(item.id)] = item;
        });
        _publicSaveCache(next);
        return next;
    }

    function _publicPruneOpenedCacheForSource(catName) {
        catName = (catName || '').trim();
        if (!catName) return false;
        var cache = _publicGetCache();
        var changed = false;
        for (var id in cache) {
            if (!Object.prototype.hasOwnProperty.call(cache, id)) continue;
            var item = cache[id];
            if (!item) continue;
            if ((item.source_cat_name || item.title || '') === catName) {
                delete cache[id];
                changed = true;
            }
        }
        if (changed) _publicSaveCache(cache);
        return changed;
    }

    function _publicGetPublished() {
        try { return JSON.parse(localStorage.getItem(PUBLIC_VOCAB_PUBLISHED_KEY) || '{}'); }
        catch (_) { return {}; }
    }

    function _publicSavePublished(map) {
        try { localStorage.setItem(PUBLIC_VOCAB_PUBLISHED_KEY, JSON.stringify(map || {})); } catch (_) {}
    }

    function _publicToken() {
        try { return _vocabAuthToken(); } catch (_) { return localStorage.getItem('plonter_auth_token') || ''; }
    }

    function _publicRequireLogin(cb) {
        if (_publicToken()) return true;
        if (typeof PlonterAuth !== 'undefined' && typeof PlonterAuth.showLoginDialog === 'function') {
            PlonterAuth.showLoginDialog(function() { if (typeof cb === 'function') cb(); });
        } else {
            alert('כדי להשתמש בשיתוף בין משתמשים צריך להתחבר.');
        }
        return false;
    }

    function _publicApi(action, body, needsAuth) {
        var headers = { 'Content-Type': 'application/json' };
        var tok = _publicToken();
        if (tok) headers.Authorization = 'Bearer ' + tok;
        if (needsAuth && !tok) return Promise.resolve({ success: false, error: 'נדרשת התחברות' });
        return fetch(PUBLIC_VOCAB_API + '?action=' + encodeURIComponent(action), {
            method: 'POST',
            headers: headers,
            body: JSON.stringify(body || {})
        }).then(function(r) { return r.json(); });
    }

    function _publicLocalName(item) {
        var title = (item && item.title) || 'קטגוריה משותפת';
        var owner = (item && item.owner_name) || 'משתמש';
        return '🌐 ' + title + ' — ' + owner;
    }

    function _publicSharedMetaForCat(catName) {
        try {
            var shared = _publicGetCache();
            for (var sid in shared) {
                if (!Object.prototype.hasOwnProperty.call(shared, sid)) continue;
                var item = shared[sid];
                if (item && !item.is_deleted && _publicLocalName(item) === catName) {
                    return {
                        sourceCatName: item.source_cat_name || item.title || catName,
                        ownerUserId: item.owner_user_id || null
                    };
                }
            }
        } catch (_) {}
        return null;
    }

    function _publicWordsFromEdit() {
        return (editWords || []).map(function(w) {
            return { arabic: w.arabic || '', form: w.form || '', hebrew: w.hebrew || '' };
        });
    }

    function _publicIsPublished(catName) {
        var pub = _publicGetPublished();
        return !!(catName && pub[catName]);
    }

    function _publicUpdateEditPublishButton(catName) {
        var btn = document.getElementById('edit-public-toggle-btn');
        if (!btn) return;
        var published = _publicIsPublished(catName || editOriginalName);
        btn.textContent = published ? '🌐 בטל שיתוף' : '🌐 פרסם לכולם';
        btn.classList.toggle('unpublish-btn', published);
        btn.title = published ? 'בטל את השיתוף הציבורי של הקטגוריה' : 'פרסם את הקטגוריה לכולם';
    }

    function _publicPublishCurrentCategory() {
        if (!_publicRequireLogin(_publicPublishCurrentCategory)) return;
        if (editOriginalName && BUILTIN_CATEGORIES.hasOwnProperty(editOriginalName)) {
            showSoftToast('קטגוריה מובנית לא מתפרסמת כקטגוריה אישית');
            return;
        }
        if (!_doEditSave()) return;
        var catName = document.getElementById('edit-cat-name').value.trim();
        var words = _publicWordsFromEdit();
        if (!catName || !words.length) { alert('אין מילים לפרסום'); return; }
        showSoftToast('מפרסם לכולם...');
        _publicApi('publish', { source_cat_name: catName, title: catName, words: words }, true).then(function(j) {
            if (!j || !j.success) { alert((j && j.error) || 'הפרסום נכשל'); return; }
            var pub = _publicGetPublished();
            pub[catName] = { id: j.category && j.category.id, published_at: new Date().toISOString() };
            _publicSavePublished(pub);
            _publicPruneOpenedCacheForSource(catName);
            _publicUpdateEditPublishButton(catName);
            showSoftToast('פורסם לכולם ✓');
            _publicSearch(catName);
        }).catch(function() { alert('שגיאת תקשורת בפרסום'); });
    }

    function _publicUnpublishCategory(catName) {
        if (!_publicRequireLogin(function() { _publicUnpublishCategory(catName); })) return;
        if (!catName || !_publicIsPublished(catName)) return;
        var ok = confirm('לבטל את השיתוף של "' + catName + '" לכולם?\n\nמי שכבר פתח את הקטגוריה יראה שהמקור נמחק ויקבל אפשרות לשכפל לעצמו מהעותק האחרון שהיה לו.');
        if (!ok) return;
        showSoftToast('מבטל שיתוף...');
        _publicApi('mark_deleted', { source_cat_name: catName }, true).then(function(j) {
            if (!j || !j.success) { alert((j && j.error) || 'ביטול השיתוף נכשל'); return; }
            var pub = _publicGetPublished();
            delete pub[catName];
            _publicSavePublished(pub);
            _publicPruneOpenedCacheForSource(catName);
            _publicUpdateEditPublishButton(catName);
            showSoftToast('השיתוף בוטל ✓');
            renderLanding();
        }).catch(function() { alert('שגיאת תקשורת בביטול השיתוף'); });
    }

    function _publicToggleCurrentCategory() {
        var catName = (document.getElementById('edit-cat-name') || {}).value || editOriginalName;
        catName = (catName || '').trim();
        if (_publicIsPublished(catName)) _publicUnpublishCategory(catName);
        else _publicPublishCurrentCategory();
    }

    function _publicPublishCategory(catName) {
        if (!_publicRequireLogin(function() { _publicPublishCategory(catName); })) return;
        if (!catName || (BUILTIN_CATEGORIES && BUILTIN_CATEGORIES.hasOwnProperty(catName))) {
            showSoftToast('אפשר לפרסם רק קטגוריה אישית');
            return;
        }
        var custom = getCustomData();
        var entry = custom[catName];
        var words = (entry && entry.words) ? entry.words : [];
        if (!words.length) { alert('אין מילים לפרסום'); return; }
        showSoftToast('מפרסם לכולם...');
        _publicApi('publish', { source_cat_name: catName, title: catName, words: words }, true).then(function(j) {
            if (!j || !j.success) { alert((j && j.error) || 'הפרסום נכשל'); return; }
            var pub = _publicGetPublished();
            pub[catName] = { id: j.category && j.category.id, published_at: new Date().toISOString() };
            _publicSavePublished(pub);
            _publicPruneOpenedCacheForSource(catName);
            showSoftToast('פורסם לכולם ✓');
            _publicSearch(catName);
            renderLanding();
        }).catch(function() { alert('שגיאת תקשורת בפרסום'); });
    }

    function _publicAutoPublishIfNeeded(catName) {
        var pub = _publicGetPublished();
