            }
        }
        _saveFcState();
    }
    function fcVerdict(verdict) {
        var w = shuffledWords[cardIndex];
        if (!w) return;
        // De-duplicate: remove this word from ALL lists first so it appears at most once
        var wKey = w.arabic + '|' + w.hebrew;
        var _sameWord = function(other) { return (other.arabic + '|' + other.hebrew) === wKey; };
        fcKnownWords = fcKnownWords.filter(function(x) { return !_sameWord(x); });
        fcUnknownWords = fcUnknownWords.filter(function(x) { return !_sameWord(x); });
        fcNotSureWords = fcNotSureWords.filter(function(x) { return !_sameWord(x); });
        if (verdict === 'knew') {
            fcKnownWords.unshift(w);
        } else if (verdict === 'notsure') {
            fcNotSureWords.unshift(w);
        } else {
            fcUnknownWords.unshift(w);
        }
        fcReviewed++;
        updateFcProgress();
        renderFcLists();
        _fcMaybePctToast();
        cardIndex++;
        renderCard();
        _saveFcState();
    }
    // Track the last % milestone we already toasted in this round so we don't
    // re-fire (e.g. if user goes back-and-forth or pct stays the same).
    var _fcLastPctMilestone = 0;
    function _toArabicDigits(n) {
        return String(n).replace(/\d/g, function(d) { return '٠١٢٣٤٥٦٧٨٩'.charAt(+d); });
    }
    function _fcMaybePctToast() {
        var total = shuffledWords.length || 0;
        if (total < 5) return; // tiny rounds — skip percent milestones
        var pct = Math.round((fcReviewed / total) * 100);
        // Fire on any 5+ jump above the last milestone. Use the actual current
        // pct (Amitai 2026-04-17: "אם זלג ל-26 אז שיכתוב 26 בّالمئة").
        if (pct >= _fcLastPctMilestone + 5) {
            _fcLastPctMilestone = pct;
            try { stalebetToast('percent', { N: _toArabicDigits(pct) }); } catch(e) {}
        }
    }
    function updateFcProgress() {
        var total = shuffledWords.length || 1;
        var pct = Math.round((fcReviewed / total) * 100);
        document.getElementById('fc-progress-fill').style.width = pct + '%';
        document.getElementById('fc-progress-text').innerHTML = '<span dir="ltr" style="unicode-bidi:isolate">' + fcReviewed + ' / ' + total + '</span> (' + pct + '%)';
    }
    function renderFcLists() {
        document.getElementById('fc-known-count').textContent = fcKnownWords.length;
        document.getElementById('fc-unknown-count').textContent = fcUnknownWords.length;
        var nsCount = document.getElementById('fc-notsure-count');
        if (nsCount) nsCount.textContent = fcNotSureWords.length;
        _renderFcListItems('fc-known-list', fcKnownWords, 'known');
        _renderFcListItems('fc-unknown-list', fcUnknownWords, 'unknown');
        _renderFcListItems('fc-notsure-list', fcNotSureWords, 'notsure');
    }
    function _renderFcListItems(containerId, words, listName) {
        var el = document.getElementById(containerId);
        if (!el) return;
        var starred = getStarred();
        // Big CTA at the top of the list: "🎯 כרטיסיות רק על הקטגוריה הזו".
        // Only render when there are ≥2 words (single-word filter is useless)
        // AND the deck isn't already filtered to this same bucket. Amitai
        // 2026-04-19 21:20 — mirrors the trivia bucket-CTA added same day.
        var ctaHtml = '';
        if (words.length >= 2 && _fcBucketFilter !== listName) {
            var color = listName === 'known' ? '#22c55e' : listName === 'unknown' ? '#ef4444' : '#8b5cf6';
            var label = listName === 'known' ? 'שידעת' : listName === 'unknown' ? 'שלא ידעת' : 'שממש לא ידעת';
            ctaHtml = '<div style="text-align:center;margin:8px 0"><button onclick="setFcBucketFilter(\'' + listName + '\')" style="padding:12px 20px;border-radius:12px;border:none;background:' + color + ';color:white;font-weight:800;cursor:pointer;font-size:1em;box-shadow:0 4px 14px rgba(0,0,0,0.14)">🎯 כרטיסיות רק על מילים ' + label + ' (' + words.length + ')</button></div>';
        }
        el.innerHTML = ctaHtml + words.map(function(w, idx) {
            var key = w.arabic + '|' + w.hebrew;
            var isStar = starred[key];
            var moveBtns = '';
            // Add move buttons to transfer to other lists
            if (listName !== 'known') {
                moveBtns += '<button class="fc-move-btn" title="העבר ל-ידעתי" onclick="fcMoveWord(\'' + listName + '\', \'known\', ' + idx + ')" style="background:#dcfce7;color:#166534">→✓</button>';
            }
            if (listName !== 'unknown') {
                moveBtns += '<button class="fc-move-btn" title="העבר ל-לא ידעתי" onclick="fcMoveWord(\'' + listName + '\', \'unknown\', ' + idx + ')" style="background:#fee2e2;color:#991b1b">→✗</button>';
            }
            if (listName !== 'notsure') {
                moveBtns += '<button class="fc-move-btn" title="העבר ל-ממש לא סגור" onclick="fcMoveWord(\'' + listName + '\', \'notsure\', ' + idx + ')" style="background:#ede9fe;color:#5b21b6">→😲</button>';
            }
            return '<div class="fc-list-item"><span class="fc-item-text"><span class="fc-item-arabic">' + w.arabic + _speakBtnHtml(w.arabic) + '</span><span>' + w.hebrew + '</span></span>' +
                '<span style="display:flex;gap:4px;align-items:center">' + moveBtns +
                '<button class="fc-item-star" onclick="fcToggleListStar(this,\'' + key.replace(/'/g, "\\'") + '\')">' + (isStar ? '★' : '☆') + '</button></span></div>';
        }).join('');
    }
    function fcMoveWord(fromList, toList, idx) {
        var sourceMap = { known: fcKnownWords, unknown: fcUnknownWords, notsure: fcNotSureWords };
        var src = sourceMap[fromList];
        var dst = sourceMap[toList];
        if (!src || !dst || idx < 0 || idx >= src.length) return;
        var w = src.splice(idx, 1)[0];
        dst.unshift(w);
        renderFcLists();
        _saveFcState();
    }
    function fcToggleListStar(btn, key) {
        if (!currentCategory) return;
        var starred = getStarred();
        if (starred[key]) { delete starred[key]; btn.textContent = '☆'; }
        else { starred[key] = true; btn.textContent = '★'; }
        localStorage.setItem('plonter_stars_' + currentCategory, JSON.stringify(starred));
        if (window.VocabProgressSync) VocabProgressSync.onStarToggled(currentCategory, key, !!starred[key]);
    }
    function toggleFcList(which) {
        var listEl = document.getElementById('fc-' + which + '-list');
        var arrow = document.getElementById('fc-' + which + '-arrow');
        var isOpen = listEl.classList.contains('open');
        listEl.classList.toggle('open');
        arrow.textContent = isOpen ? '▼' : '▲';
    }
    function fcShowRoundComplete() {
        document.getElementById('flashcard').style.display = 'none';
        document.getElementById('fc-verdict').classList.remove('show');
        document.getElementById('fc-counter').style.display = 'none';
        var panel = document.getElementById('fc-round-complete');
        panel.classList.add('show');
        var knewPct = fcTotalInRound ? Math.round((fcKnownWords.length / fcTotalInRound) * 100) : 0;
        document.getElementById('fc-round-stat').textContent = 'ידעת ' + fcKnownWords.length + ' מתוך ' + fcTotalInRound + ' (' + knewPct + '%)';
        // Improvement from last round
        var storageKey = 'plonter_fc_last_' + currentCategory;
        var lastPct = parseInt(localStorage.getItem(storageKey) || '0');
        var improvEl = document.getElementById('fc-round-improvement');
        if (lastPct > 0 && lastPct !== knewPct) {
            var diff = knewPct - lastPct;
            if (diff > 0) improvEl.textContent = '📈 שיפור של ' + diff + '% מהסבב הקודם!';
            else if (diff < 0) improvEl.textContent = '📉 ירידה של ' + Math.abs(diff) + '% מהסבב הקודם';
            else improvEl.textContent = '';
            improvEl.style.color = diff > 0 ? '#22c55e' : '#ef4444';
        } else {
            improvEl.textContent = '';
        }
        localStorage.setItem(storageKey, String(knewPct));
        if (window.VocabProgressSync && currentCategory) VocabProgressSync.onFcLastCardChanged(currentCategory);
        // Show/hide unknown round button
        var unknownBtn = document.getElementById('fc-btn-unknown');
        unknownBtn.style.display = fcUnknownWords.length > 0 ? '' : 'none';
    }
    function nextCard() { cardIndex++; renderCard(); _saveFcState(); }
    function prevCard() { cardIndex--; renderCard(); _saveFcState(); }
    function shuffleCards() {
        if (_fcShuffled) {
            _fcShuffled = false;
            shuffledWords = _fcOriginalOrder.slice();
        } else {
            _fcShuffled = true;
            shuffle(shuffledWords);
        }
        // Don't wipe fcKnownWords / fcUnknownWords / fcNotSureWords / fcReviewed /
        // cardIndex — warehouses AND current position persist across shuffle
        // (Amitai 2026-04-14). Just clamp to new deck bounds.
        if (cardIndex >= shuffledWords.length) cardIndex = 0;
        if (cardIndex < 0) cardIndex = 0;
        fcTotalInRound = shuffledWords.length;
        _saveFcState();
        updateFcProgress();
        renderFcLists();
        document.getElementById('fc-round-complete').classList.remove('show');
        document.getElementById('flashcard').style.display = '';
        document.getElementById('fc-counter').style.display = '';
        renderCard();
        _updateFcShuffleBtn();
    }
    function _updateFcShuffleBtn() {
        var btn = document.querySelector('#flashcards-mode .shuffle-btn');
        if (btn) btn.textContent = _fcShuffled ? '↩ חזור לסדר הקיים' : '🔀 ערבב';
    }

    // ============ TRIVIA ============
    function toggleQmarkMode() {
        qmarkMode = !qmarkMode;
        document.getElementById('qmark-toggle').classList.toggle('active', qmarkMode);
        if (!triviaAnswered) renderTrivia();
    }
    function setTriviaDirection(dir) {
        // Save the current direction's streak before switching, load the new one's.
        _persistTriviaStreakForDir(triviaDirection);
        triviaDirection = dir;
        _loadTriviaStreakForDir(dir);
        document.getElementById('dir-ar2he').classList.toggle('active', dir === 'ar2he');
        document.getElementById('dir-he2ar').classList.toggle('active', dir === 'he2ar');
        resetGameMode();
    }

    function renderTrivia() {
        var words = shuffledWords;
        if (words.length < 2) {
            document.getElementById('trivia-word').textContent = 'צריך לפחות 2 מילים';
            document.getElementById('trivia-options').innerHTML = '';
            document.getElementById('trivia-form').textContent = '';
            document.getElementById('trivia-feedback').className = 'trivia-feedback';
            document.getElementById('trivia-next').style.display = 'none';
            return;
        }
        if (cardIndex >= words.length) { cardIndex = 0; shuffle(shuffledWords); }
        var w = words[cardIndex];
        var wordEl = document.getElementById('trivia-word');
        var formEl = document.getElementById('trivia-form');
        // Image-question categories: flag IS the question, Arabic country
        // name is always the answer regardless of direction toggle. Amitai
        // 2026-05-16.
        var _tvImageQuestion = !!(w && w.image && _getCategoryQuestionType(currentCategory) === 'image');
        // Bilingual-pair categories: capital (AR + HE) is the question,
        // country (AR + HE) is the answer; direction toggle ignored.
        // Amitai 2026-05-16 23:26.
        var _tvBilingualPair = !!(w && (w.qAr || w.qHe) && _getCategoryQuestionType(currentCategory) === 'bilingual_pair');

        if (_tvBilingualPair) {
            wordEl.innerHTML = '';
            if (w.qAr) {
                var _tvQAr = document.createElement('div');
                _tvQAr.textContent = w.qAr;
                _tvQAr.style.cssText = 'font-family:\'Times New Roman\', serif;font-weight:bold;color:#0d9488;line-height:1.2';
                wordEl.appendChild(_tvQAr);
            }
            if (w.qHe) {
                var _tvQHe = document.createElement('div');
                _tvQHe.textContent = w.qHe;
                _tvQHe.style.cssText = 'font-family:\'Segoe UI\', Tahoma, Geneva, Verdana, sans-serif;font-size:0.42em;color:#1e293b;font-weight:bold;margin-top:8px;line-height:1.2';
                wordEl.appendChild(_tvQHe);
            }
            wordEl.classList.remove('arabic-text');
            formEl.textContent = '';
            // No autoplay on bilingual-pair side — the pair has no single
            // utterance to read, and reading the AR portion would give
            // away the answer-half.
        } else if (_tvImageQuestion) {
            wordEl.innerHTML = '';
            var _tvImgQ = document.createElement('img');
            _tvImgQ.src = w.image;
            _tvImgQ.alt = w.hebrew || w.arabic || '';
            _tvImgQ.style.cssText = 'max-width:100%;max-height:220px;object-fit:contain;border-radius:12px;display:block;margin:0 auto;min-height:140px;min-width:200px';
            _attachFlagLoadingShimmer(_tvImgQ);
            wordEl.appendChild(_tvImgQ);
            wordEl.classList.remove('arabic-text');
            formEl.textContent = '';
            // No autoplay on image-question side — there is no text to read
            // and the answer (Arabic name) must stay hidden until clicked.
        } else if (triviaDirection === 'ar2he') {
            wordEl.innerHTML = '';
            wordEl.appendChild(document.createTextNode(w.arabic));
            _appendSpeakBtn(wordEl, w.arabic);
            _appendAudioBtn(wordEl, currentCategory, (w.arabic || '') + '|' + (w.hebrew || ''), 'ar');
            wordEl.classList.add('arabic-text');
            if (w.form) {
                var formInline = document.createElement('div');
                formInline.className = 'trivia-form-inline';
                formInline.textContent = w.form;
                wordEl.appendChild(formInline);
            }
            formEl.textContent = '';
            // Autoplay only on ar2he — the Arabic IS the question. On
            // he2ar (Hebrew question, Arabic options) auto-playing would
            // leak the answer. Lang='ar' so we play the Arabic recording.
            _audioAutoplayIfOn(w, currentCategory, 'ar');
        } else {
            wordEl.innerHTML = '';
            wordEl.appendChild(document.createTextNode(w.hebrew));
            wordEl.classList.remove('arabic-text');
            formEl.textContent = '';
            // Autoplay the Hebrew recording (the visible question side) — playing
            // 'he' doesn't leak the Arabic answer. Amitai 2026-04-26 23:38: 'אם
            // אני בטריוויה במצב מעברית לערבית אז זה לא מקריא את העברית הגלויה'.
            _audioAutoplayIfOn(w, currentCategory, 'he');
        }
        _scheduleSubtitleJump(wordEl.querySelector('.trivia-form-inline'));

        triviaAnswered = false;
        document.getElementById('trivia-next').style.display = 'none';
        var notSureBtn = document.getElementById('trivia-not-sure');
        if (notSureBtn) notSureBtn.style.display = 'none';
        document.getElementById('trivia-feedback').className = 'trivia-feedback';

        // Wrong word / not-sure indicator
        var triviaStats = _getTriviaStats();
        var notSureMap = _getNotSure();
        var wStat = triviaStats[_wordKey(w)];
        var isNotSure = !!notSureMap[_wordKey(w)];
        var triviaArea = document.querySelector('.trivia-area');
        if (triviaArea) triviaArea.style.background = '';
        var wrongHint = document.getElementById('trivia-wrong-hint');
        if (wrongHint) wrongHint.remove();
        if (isNotSure) {
            // Yellow background + small header — overrides wrong-word indicator
            if (triviaArea) triviaArea.style.background = 'rgba(245,158,11,0.12)';
            var hint = document.createElement('div');
            hint.id = 'trivia-wrong-hint';
            hint.style.cssText = 'text-align:center;color:#b45309;font-size:0.85em;margin-bottom:4px;font-weight:bold';
            hint.textContent = '🤔 אתה לא סגור על זה';
            wordEl.parentNode.insertBefore(hint, wordEl);
        } else if (wStat && wStat.wrong > wStat.correct) {
            if (triviaArea) triviaArea.style.background = 'rgba(239,68,68,0.06)';
            var hint = document.createElement('div');
            hint.id = 'trivia-wrong-hint';
            hint.style.cssText = 'text-align:center;color:#ef4444;font-size:0.85em;margin-bottom:4px;opacity:0.8';
            hint.textContent = 'מילה שטעית בה (:';
            wordEl.parentNode.insertBefore(hint, wordEl);
        }

        // Image-question forces correctField='arabic' (the Arabic country
        // name is the answer); direction toggle ignored.
        // Bilingual-pair has TWO fields per side (aAr + aHe) — handled as
        // a composite key below, not by correctField.
        var correctField = _tvImageQuestion
            ? 'arabic'
            : (triviaDirection === 'ar2he' ? 'hebrew' : 'arabic');
        // Composite key for bilingual_pair: 'aAr||aHe' joins the two
        // answer halves into a single comparable string. Falls back to the
        // single-field correctField for every other mode.
        var _tvPairKey = function(x) { return (x && (x.aAr || '') + '||' + (x.aHe || '')) || ''; };
        var correctValue = _tvBilingualPair ? _tvPairKey(w) : w[correctField];
        // Wrong answers come from the CURRENT category only (Amitai 2026-04-19).
        // If the category is too small to fill 3 distractors, fall back to all words.
        var catWords = currentCategory ? getCategoryWords(currentCategory) : [];
        // Key helper: composite for bilingual_pair, single field otherwise.
        var _tvKeyOf = _tvBilingualPair
            ? _tvPairKey
            : function(x) { return x ? x[correctField] : ''; };
        var pool = catWords.filter(function(x) { return _tvKeyOf(x) !== correctValue; });
        if (pool.length < 3) {
            var fallback = getAllWords().filter(function(x) { return _tvKeyOf(x) !== correctValue; });
            var seen = {}; pool.forEach(function(x) { seen[_tvKeyOf(x)] = true; });
            fallback.forEach(function(x) { var k = _tvKeyOf(x); if (!seen[k]) { seen[k] = true; pool.push(x); } });
        }
        shuffle(pool);
        // Build the option list. For bilingual_pair, every option carries
        // both a flat `text` key (for compare) and a 2-line `html` blob
        // (for render). For non-pair modes, opt.text is the visible string.
        var _tvBuildOpt = function(src, isCorrect) {
            if (_tvBilingualPair) {
                var ar = src.aAr || '';
                var he = src.aHe || '';
                var esc = function(s) { return String(s).replace(/[&<>"']/g, function(c) { return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; }); };
                return {
                    text: _tvPairKey(src),
                    html: '<div style="font-family:\'Times New Roman\', serif;font-weight:bold;color:#0d9488;line-height:1.2">' + esc(ar) + '</div>' +
                          '<div style="font-family:\'Segoe UI\', Tahoma, Geneva, Verdana, sans-serif;font-size:0.78em;color:#1e293b;font-weight:bold;margin-top:4px;line-height:1.2">' + esc(he) + '</div>',
                    correct: !!isCorrect
                };
            }
            return { text: src[correctField], correct: !!isCorrect };
        };
        var options = [_tvBuildOpt(w, true)];
        for (var i = 0; i < 3 && i < pool.length; i++) {
            options.push(_tvBuildOpt(pool[i], false));
        }
        shuffle(options);

        var container = document.getElementById('trivia-options');
        container.innerHTML = '';
        options.forEach(function(opt) {
            var btn = document.createElement('button');
            btn.className = 'trivia-option';
            if (triviaDirection === 'he2ar' || _tvImageQuestion || _tvBilingualPair) btn.classList.add('arabic-text');
            if (opt.html) {
                btn.innerHTML = opt.html;
            } else {
                btn.textContent = opt.text;
            }
            // _isCorrect survives any innerHTML rewrite — used by the
            // post-wrong "highlight the correct option" loop below.
            btn._isCorrect = !!opt.correct;
            btn.onclick = function() {
                if (triviaAnswered) return;
                triviaAnswered = true;
                triviaTotal++;
                _triviaAnsweredInRound++;
                _markTriviaRoundAnswered(w);
                container.querySelectorAll('.trivia-option').forEach(function(b) { b.classList.add('disabled'); });
                var feedback = document.getElementById('trivia-feedback');
                if (opt.correct) {
                    triviaCorrect++; triviaStreak++;
                    _triviaRoundCorrect++;
                    if (triviaStreak > triviaBestStreak) triviaBestStreak = triviaStreak;
                    btn.classList.add('correct');
                    feedback.textContent = triviaStreak >= 3 ? 'נכון! 🔥 רצף ' + triviaStreak : 'נכון!';
                    feedback.className = 'trivia-feedback show correct-feedback';
                    _recordTriviaResult(w, true);
                    try { _recordTriviaSessionResult(w, true); } catch (_) {}
                    stalebetMaybePlain('correct');
