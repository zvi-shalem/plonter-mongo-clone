    function vocabDictSearch() {
        var inputEl = document.getElementById('vd-input');
        // Auto-convert Hebrew letters to Arabic before searching (matches main dict behavior)
        if (/[֐-׿]/.test(inputEl.value)) {
            inputEl.value = heb2ar(inputEl.value);
