    function _isGroupShareEligible() {
        try {
            if (typeof _isAudioFeatureOwner === 'function' && _isAudioFeatureOwner()) return true;
            if (typeof PlonterAdmin !== 'undefined') {
                if (PlonterAdmin.isDragon && PlonterAdmin.isDragon()) return true;
