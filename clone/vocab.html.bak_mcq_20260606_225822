        var rightCol = document.getElementById('matching-right');
        var leftCol = document.getElementById('matching-left');
        rightCol.innerHTML = '';
        leftCol.innerHTML = '';

        // Shuffle each side independently
        var rightOrder = matchPairs.slice();
        var leftOrder = matchPairs.slice();
        shuffle(rightOrder);
        shuffle(leftOrder);

        rightOrder.forEach(function(w, i) {
            var el = document.createElement('div');
