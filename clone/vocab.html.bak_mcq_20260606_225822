    function _getFcKnownUnknown(cat, direction) {
        try {
            var s = JSON.parse(localStorage.getItem('plonter_fc_state_' + cat) || 'null');
            if (!s) return { known: {}, unknown: {}, notsure: {} };
            // direction = 'he2ar' or 'ar2he'. Each direction has its own classification.
            // Strict: if a direction was requested and we don't have perDir data for it,
            // return empty. Falling back to top-level legacy means ar2he data leaks into
            // he2ar queries (legacy field always mirrors LAST-used direction). Amitai
            // 2026-04-17: "if I know a word ar→he it shouldn't appear under he→ar known".
            var src;
            if (direction) {
                if (s.perDir && s.perDir[direction]) src = s.perDir[direction];
                else return { known: {}, unknown: {}, notsure: {} };
            } else {
                src = s;
            }
            var known = {}, unknown = {}, notsure = {};
            (src.known || []).forEach(function(k) { known[k] = true; });
            (src.unknown || []).forEach(function(k) { unknown[k] = true; });
            (src.notsure || []).forEach(function(k) { notsure[k] = true; });
            return { known: known, unknown: unknown, notsure: notsure };
        } catch(e) { return { known: {}, unknown: {}, notsure: {} }; }
    }
