    // Gather all per-category progress (stars / flashcard state / trivia
    // stats / trivia not-sure flags) so the user can choose to include it
    // when exporting a category to JSON. Trivia keys are global-scoped but
    // prefixed with "<cat>::" — we slice that prefix out for portability.
    function _gatherCategoryProgress(catName) {
        var prog = {};
        try {
            var stars = localStorage.getItem('plonter_stars_' + catName);
            if (stars) {
                var s = JSON.parse(stars);
                if (s && Object.keys(s).length) prog.stars = s;
            }
        } catch (_) {}
        try {
            var fc = localStorage.getItem('plonter_fc_state_' + catName);
            if (fc) prog.flashcards = JSON.parse(fc);
        } catch (_) {}
        try {
            var allStats = JSON.parse(localStorage.getItem('plonter_trivia_stats') || '{}');
            var prefix = catName + '::';
            var slice = {};
            Object.keys(allStats).forEach(function(k) {
                if (k.indexOf(prefix) === 0) slice[k] = allStats[k];
            });
            if (Object.keys(slice).length) prog.trivia_stats = slice;
        } catch (_) {}
        try {
            var allNS = JSON.parse(localStorage.getItem('plonter_trivia_not_sure') || '{}');
            var prefix2 = catName + '::';
            var slice2 = {};
            Object.keys(allNS).forEach(function(k) {
                if (k.indexOf(prefix2) === 0) slice2[k] = allNS[k];
            });
            if (Object.keys(slice2).length) prog.trivia_notsure = slice2;
        } catch (_) {}
        return prog;
    }
