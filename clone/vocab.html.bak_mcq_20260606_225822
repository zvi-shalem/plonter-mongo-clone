            badge.className = 'table-import-status ' + row.status;
            badge.textContent = _tableImportStatusLabel(row.status);
        }
        var addBtn = card.querySelector('[data-table-action="add"]');
        if (addBtn) {
            addBtn.disabled = row.status === 'added' || row.status === 'ignored' || !(row.arabic && row.hebrew);
            addBtn.style.opacity = addBtn.disabled ? '0.45' : '';
        }
    }

    function _syncTableImportRowFromCard(card, idx) {
        var row = _tableImportRows[idx];
        if (!row || !card) return null;
        row.arabic = (card.querySelector('[data-tfield="arabic"]') || {}).value || '';
        row.form = (card.querySelector('[data-tfield="form"]') || {}).value || '';
        row.hebrew = (card.querySelector('[data-tfield="hebrew"]') || {}).value || '';
        row.arabic = row.arabic.trim();
        row.form = row.form.trim();
        row.hebrew = row.hebrew.trim();
        if (row.status !== 'ignored' && row.status !== 'added') row.status = (row.arabic && row.hebrew) ? 'ready' : 'pending';
        return row;
    }

    function renderTableImportReview() {
        var review = document.getElementById('table-import-review');
        var summary = document.getElementById('table-import-summary');
        if (!review || !summary) return;
        review.innerHTML = '';
        var ready = 0, pending = 0, ignored = 0, added = 0;
        _tableImportRows.forEach(function(r) {
            if (r.status === 'ready') ready++;
            else if (r.status === 'ignored') ignored++;
            else if (r.status === 'added') added++;
            else pending++;
        });
        summary.textContent = _tableImportRows.length
            ? ('זוהו ' + _tableImportRows.length + ' שורות: ' + ready + ' תקינות, ' + pending + ' חסרות, ' + ignored + ' בהתעלמות, ' + added + ' נוספו.')
            : 'לא זוהו שורות עדיין.';
        _tableImportRows.forEach(function(row, idx) {
            var card = document.createElement('div');
            card.className = 'table-import-card ' + row.status;
            var top = document.createElement('div');
            top.style.cssText = 'display:flex;align-items:center;justify-content:space-between;gap:8px';
            var num = document.createElement('strong');
            num.textContent = 'שורה ' + (idx + 1);
            var badge = document.createElement('span');
            badge.className = 'table-import-status ' + row.status;
            badge.textContent = _tableImportStatusLabel(row.status);
            top.appendChild(num);
            top.appendChild(badge);
            card.appendChild(top);

            var fields = document.createElement('div');
            fields.className = 'table-import-fields';
            [
                { key: 'arabic', label: 'ערבית', dir: 'rtl', family: 'Times New Roman,serif' },
                { key: 'form', label: 'תוספת', dir: 'rtl', family: 'Times New Roman,serif' },
                { key: 'hebrew', label: 'עברית', dir: 'rtl', family: 'inherit' }
            ].forEach(function(f) {
                var input = document.createElement('input');
                input.type = 'text';
                input.placeholder = f.label;
                input.value = row[f.key] || '';
                input.dir = f.dir;
                input.setAttribute('data-tfield', f.key);
                input.style.fontFamily = f.family;
                input.disabled = row.status === 'added';
                input.oninput = function() {
                    var synced = _syncTableImportRowFromCard(card, idx);
                    _refreshTableImportCardStatus(card, synced);
                };
                fields.appendChild(input);
            });
            card.appendChild(fields);

            var actions = document.createElement('div');
            actions.className = 'table-import-actions';
            var addBtn = document.createElement('button');
            addBtn.type = 'button';
            addBtn.className = 'primary';
            addBtn.setAttribute('data-table-action', 'add');
            addBtn.textContent = 'הוסף שורה';
            addBtn.disabled = row.status === 'added' || row.status === 'ignored' || !(row.arabic && row.hebrew);
            addBtn.style.opacity = addBtn.disabled ? '0.45' : '';
            addBtn.onclick = function() { addOneTableImportRow(idx); };
            actions.appendChild(addBtn);

            var ignoreBtn = document.createElement('button');
            ignoreBtn.type = 'button';
            ignoreBtn.className = row.status === 'ignored' ? '' : 'warning';
            ignoreBtn.textContent = row.status === 'ignored' ? 'החזר' : 'התעלם';
            ignoreBtn.disabled = row.status === 'added';
            ignoreBtn.onclick = function() {
                var synced = _syncTableImportRowFromCard(card, idx);
                if (!synced || synced.status === 'added') return;
                synced.status = synced.status === 'ignored' ? ((synced.arabic && synced.hebrew) ? 'ready' : 'pending') : 'ignored';
                renderTableImportReview();
            };
            actions.appendChild(ignoreBtn);
            card.appendChild(actions);
            review.appendChild(card);
        });
    }

    function _addTableImportRows(rowIndexes) {
        var added = [];
        var skippedDuplicates = 0;
        var seenExisting = {};
        editWords.forEach(function(w) {
            var key = [(w.arabic || '').trim(), (w.form || '').trim(), (w.hebrew || '').trim()].join('\u0001');
            seenExisting[key] = true;
        });
        rowIndexes.forEach(function(idx) {
            var row = _tableImportRows[idx];
            if (!row || row.status === 'ignored' || row.status === 'added' || !row.arabic || !row.hebrew) return;
            var word = { arabic: row.arabic, form: row.form || '', hebrew: row.hebrew };
            var wordKey = [word.arabic.trim(), (word.form || '').trim(), word.hebrew.trim()].join('\u0001');
            if (seenExisting[wordKey]) {
                skippedDuplicates++;
                row.status = 'added';
                return;
            }
            var insertIndex = editWords.length;
            editWords.push(word);
            seenExisting[wordKey] = true;
            added.push({ rowIndex: idx, insertIndex: insertIndex, word: word, previousStatus: row.status });
            row.status = 'added';
        });
        if (!added.length) {
            showSoftToast(skippedDuplicates ? 'השורות כבר קיימות באוצ״מ' : 'אין שורות תקינות להוספה');
            renderTableImportReview();
            return;
        }
        _tableImportUndo = { added: added };
        editDirty = true;
        renderEditContent();
        renderTableImportReview();
        showSoftToast('נוספו ' + added.length + ' מילים ✓' + (skippedDuplicates ? ' · דולגו ' + skippedDuplicates + ' כפולות' : ''));
    }

    function addOneTableImportRow(idx) {
        var card = document.querySelectorAll('#table-import-review .table-import-card')[idx];
        _syncTableImportRowFromCard(card, idx);
        _addTableImportRows([idx]);
    }

    function addAllReadyTableImportRows() {
        var cards = document.querySelectorAll('#table-import-review .table-import-card');
        for (var i = 0; i < cards.length; i++) _syncTableImportRowFromCard(cards[i], i);
        var indexes = [];
        _tableImportRows.forEach(function(row, idx) {
            if (row.status !== 'ignored' && row.status !== 'added' && row.arabic && row.hebrew) indexes.push(idx);
        });
        _addTableImportRows(indexes);
    }

    function undoLastTableImportAdd() {
        if (!_tableImportUndo || !_tableImportUndo.added || !_tableImportUndo.added.length) {
            showSoftToast('אין הוספה אחרונה לביטול');
            return;
        }
        var removed = 0;
        for (var i = _tableImportUndo.added.length - 1; i >= 0; i--) {
            var item = _tableImportUndo.added[i];
            var w = editWords[item.insertIndex];
            var same = w && w.arabic === item.word.arabic && (w.form || '') === (item.word.form || '') && w.hebrew === item.word.hebrew;
            if (same) {
                editWords.splice(item.insertIndex, 1);
                removed++;
            } else {
                for (var j = editWords.length - 1; j >= 0; j--) {
                    w = editWords[j];
                    if (w && w.arabic === item.word.arabic && (w.form || '') === (item.word.form || '') && w.hebrew === item.word.hebrew) {
                        editWords.splice(j, 1);
                        removed++;
                        break;
                    }
                }
            }
            if (_tableImportRows[item.rowIndex]) _tableImportRows[item.rowIndex].status = item.previousStatus || 'ready';
        }
        _tableImportUndo = null;
        if (removed) editDirty = true;
        renderEditContent();
        renderTableImportReview();
        showSoftToast(removed ? ('בוטלו ' + removed + ' הוספות') : 'לא נמצאו מילים לביטול');
    }

