            document.getElementById('flashcard').style.position = 'relative';
            document.getElementById('flashcard').appendChild(starBtn);
        }
        var starKey = w.arabic + '|' + w.hebrew;
        var starred = getStarred();
        starBtn.textContent = starred[starKey] ? '★' : '☆';
        starBtn.style.color = starred[starKey] ? '#f59e0b' : '#d1d5db';
