    // ============ DICT TABS & FEATURES ============
    var HEB2AR_MAP = {'א':'ا','ב':'ب','ג':'ج','ד':'د','ה':'ه','ו':'و','ז':'ز','ח':'ح','ט':'ط','י':'ي','כ':'ك','ך':'ك','ל':'ل','מ':'م','ם':'م','נ':'ن','ן':'ن','ס':'س','ע':'ع','פ':'ف','ף':'ف','צ':'ص','ץ':'ص','ק':'ق','ר':'ر','ש':'ش','ת':'ت'};
    function heb2ar(text) {
        var result = '';
        for (var i = 0; i < text.length; i++) {
            var ch = text[i];
            if (ch === "'" && i > 0) {
                var prev = result[result.length - 1];
                var geresh = {'ه':'ة','ا':'ء','ح':'خ','د':'ذ','ص':'ض','ط':'ظ','ع':'غ','ت':'ث','و':'ؤ','ي':'ئ','أ':'ء','ئ':'ى'};
                if (geresh[prev]) { result = result.slice(0, -1) + geresh[prev]; continue; }
            }
            result += HEB2AR_MAP[ch] || ch;
        }
        return result;
    }
    function vdInsertGeresh(inputId) {
        var el = document.getElementById(inputId);
