    // 600ms long-press on a group-header element. Cancels on move>10px, up,
    // cancel, or scroll — same conventions as the in-app word-text-area
    // long-press helper. Suppresses the synthetic click that would otherwise
    // toggle the group, so a long-press doesn't also collapse/expand it.
    function _attachGroupShareLongPress(btnEl, label, groupCats) {
        var HOLD_MS = 600;
        var MOVE_PX = 10;
        var t = null, sx = 0, sy = 0, fired = false;

        // iOS/Android long-press on text triggers the OS copy/select menu,
        // which steals our gesture. Disable text-select + callout on the header
        // so our 600ms timer wins.
        btnEl.style.webkitUserSelect = 'none';
        btnEl.style.userSelect = 'none';
        btnEl.style.webkitTouchCallout = 'none';
        btnEl.addEventListener('contextmenu', function(e) { e.preventDefault(); });

        function clearTimer() { if (t) { clearTimeout(t); t = null; } }
        function reset() { clearTimer(); fired = false; }

        function onDown(e) {
            reset();
            var p = e.touches ? e.touches[0] : e;
            sx = p.clientX; sy = p.clientY;
            t = setTimeout(function() {
                fired = true;
                t = null;
                try { e.preventDefault && e.preventDefault(); } catch (_) {}
                openGroupShareDialog(label, groupCats);
            }, HOLD_MS);
        }
        function onMove(e) {
            if (!t) return;
            var p = e.touches ? e.touches[0] : e;
            if (Math.abs(p.clientX - sx) > MOVE_PX || Math.abs(p.clientY - sy) > MOVE_PX) clearTimer();
        }
        function onUp() { clearTimer(); }
        function onCancel() { reset(); }

        btnEl.addEventListener('pointerdown',   onDown);
        btnEl.addEventListener('pointermove',   onMove);
        btnEl.addEventListener('pointerup',     onUp);
        btnEl.addEventListener('pointercancel', onCancel);
        // Touch fallback for browsers without PointerEvents.
        btnEl.addEventListener('touchstart',  onDown,   { passive: true });
        btnEl.addEventListener('touchmove',   onMove,   { passive: true });
        btnEl.addEventListener('touchend',    onUp);
        btnEl.addEventListener('touchcancel', onCancel);
        // Scroll cancels (page scroll while user holds means it's a scroll, not a press).
        window.addEventListener('scroll', clearTimer, true);

        // Capture-phase click suppressor: if a long-press just fired, eat the
        // subsequent synthetic click so the group-toggle handler doesn't run.
        btnEl.addEventListener('click', function(e) {
            if (fired) {
                fired = false;
                e.stopPropagation();
                e.preventDefault();
            }
        }, true);
    }

