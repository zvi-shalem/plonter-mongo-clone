                PERSONS.forEach(function(person) {
                    var form = verb[tense][person.ar];
                    if (form) {
                        rconjQuestions.push({
                            form: form, root: verb.root, binyan: verb.binyan,
                            tense: tense, person: person, verb: verb
                        });
                    }
                });
            });
            if (verb.imperative) {
                for (var p in verb.imperative) {
                    var person = PERSONS.find(function(x) { return x.ar === p; });
                    if (person) {
                        rconjQuestions.push({
                            form: verb.imperative[p], root: verb.root, binyan: verb.binyan,
                            tense: 'imperative', person: person, verb: verb
                        });
                    }
                }
            }
            if (verb.participle) {
                var partMap = { 'مذكر': 'יחיד', 'مؤنث': 'יחידה', 'جمع': 'רבים' };
                for (var g in verb.participle) {
                    rconjQuestions.push({
                        form: verb.participle[g], root: verb.root, binyan: verb.binyan,
                        tense: 'participle_active', person: { ar: g, he: partMap[g] || g }, verb: verb
                    });
                }
            }
        });
        shuffle(rconjQuestions);
    }

