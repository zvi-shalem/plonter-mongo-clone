    // ============ CONJUGATION ============
    function generateConjQuestions() {
        conjQuestions = [];
        var conj = getCategoryConj(currentCategory);
        if (!conj) return;
        conj.forEach(function(verb) {
            ['past', 'present'].forEach(function(tense) {
                if (!verb[tense]) return;
                PERSONS.forEach(function(person) {
                    var form = verb[tense][person.ar];
                    if (form) {
                        conjQuestions.push({
                            root: verb.root, meaning: verb.meaning,
                            binyan: verb.binyan, pattern: verb.pattern,
                            tense: tense, person: person,
                            correct: form, verb: verb
                        });
                    }
                });
            });
            // Imperative if exists
            if (verb.imperative) {
                for (var p in verb.imperative) {
                    var person = PERSONS.find(function(x) { return x.ar === p; });
                    if (person) {
                        conjQuestions.push({
                            root: verb.root, meaning: verb.meaning,
                            binyan: verb.binyan, pattern: verb.pattern,
                            tense: 'imperative', person: person,
                            correct: verb.imperative[p], verb: verb
                        });
                    }
                }
            }
            // Participle if exists
            if (verb.participle) {
                var partLabels = { 'مذكر': 'זכר', 'مؤنث': 'נקבה', 'جمع': 'רבים' };
                for (var g in verb.participle) {
                    if (partLabels[g]) {
                        conjQuestions.push({
                            root: verb.root, meaning: verb.meaning,
                            binyan: verb.binyan, pattern: verb.pattern,
                            tense: 'participle', person: { ar: g, he: partLabels[g] },
                            correct: verb.participle[g], verb: verb
                        });
                    }
                }
            }
        });
        shuffle(conjQuestions);
    }

    function renderConjugation() {
