    function flipMemoryCard(idx, el) {
        if (memoryLocked) return;
        if (el.classList.contains('flipped') || el.classList.contains('matched')) return;

        el.classList.add('flipped');
        memoryFlipped.push({ idx: idx, el: el, card: memoryCards[idx] });
        // Auto-play audio for the side that was just flipped (Amitai 2026-04-24 15:47).
        // Arabic card → Arabic recording. Hebrew card → Hebrew recording (when available).
        if (typeof _isAudioAutoplayOn === 'function' && _isAudioAutoplayOn()) {
            var card = memoryCards[idx];
            var w = card && card.word;
            if (w && typeof _playWordRecording === 'function') {
                var wk = w.arabic || '';
                setTimeout(function() { try { _playWordRecording(currentCategory, wk); } catch (_) {} }, 150);
            }
        }

        if (memoryFlipped.length === 2) {
            memoryLocked = true;
            memoryAttempts++;
            var c1 = memoryFlipped[0];
            var c2 = memoryFlipped[1];

            if (c1.card.pairId === c2.card.pairId) {
                // Match!
                setTimeout(function() {
                    c1.el.classList.add('matched');
                    c2.el.classList.add('matched');
                    // Collapse matched cards after showing the match briefly
                    setTimeout(function() {
                        c1.el.classList.add('collapsed');
                        c2.el.classList.add('collapsed');
                    }, 600);
                    memoryPairsLeft--;
                    if (memoryPlayers === 2) {
                        memoryScores[memoryCurrentPlayer]++;
                        updateMemoryStatus();
                    }
                    memoryFlipped = [];
                    memoryLocked = false;

                    if (memoryPairsLeft <= 0) {
                        endMemoryGame();
                    }
                }, 500);
            } else {
                // No match — flip back
