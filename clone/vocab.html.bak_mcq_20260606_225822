    function editDeleteCategory() {
        if (!confirm('למחוק את הקטגוריה "' + editOriginalName + '"?')) return;
        var _deletedName = editOriginalName;
        try { _publicMarkDeleted(_deletedName); } catch (_) {}
        // Cascade to the server: wipe recordings + revoke any live share-links
        // so we don't leave orphaned blobs / working links pointing at a
        // category that no longer exists. Amitai 2026-04-24: "when I delete a
        // category it of course deletes all my recordings from the DB."
        var _authToken = (typeof _vocabAuthToken === 'function') ? _vocabAuthToken() : '';
        var _cascadeAudio = _authToken
            ? fetch('/plonter/api/vocab_audio_api.php?action=delete_category', {
                method: 'POST',
                headers: {'Content-Type': 'application/json', 'Authorization': 'Bearer ' + _authToken},
                body: JSON.stringify({cat_name: _deletedName})
              }).then(function(r) { return r.json(); }).catch(function() { return {success: false}; })
            : Promise.resolve({success: false, skipped: 'no-auth'});
        var _cascadeTokens = _authToken
            ? fetch('/plonter/api/vocab_share_api.php?action=delete_category_tokens', {
                method: 'POST',
                headers: {'Content-Type': 'application/json', 'Authorization': 'Bearer ' + _authToken},
                body: JSON.stringify({category: _deletedName})
              }).then(function(r) { return r.json(); }).catch(function() { return {success: false}; })
            : Promise.resolve({success: false, skipped: 'no-auth'});
        Promise.all([_cascadeAudio, _cascadeTokens]).then(function(results) {
            var audioRes = results[0] || {};
            var tokRes   = results[1] || {};
            if (audioRes.deleted || tokRes.revoked) {
                var bits = [];
                if (audioRes.deleted) bits.push(audioRes.deleted + ' הקלטות נמחקו');
                if (tokRes.revoked)   bits.push(tokRes.revoked + ' קישורי שיתוף בוטלו');
                if (typeof showSoftToast === 'function') showSoftToast(bits.join(' · '));
            }
        });
        var custom = getCustomData();
        delete custom[editOriginalName];
        saveCustomData(custom);
        // Ghost-deletion fix (task #51): also drop this category from the guest
        // backup + its companion shadow keys, so login won't re-offer it.
        _pruneGuestVocabBackupForCategory(_deletedName);
        if (window.VocabProgressSync) VocabProgressSync.onCategoryDeleted(_deletedName);
        _exitGameTo();
