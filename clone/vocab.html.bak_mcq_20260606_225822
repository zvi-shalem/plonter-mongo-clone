    function _splitTableImportLine(line) {
        var cols;
        if (line.indexOf('\t') >= 0) cols = line.split('\t');
        else if (line.indexOf('|') >= 0) cols = line.split('|');
        else if (line.indexOf(',') >= 0) cols = line.split(',');
        else if (/\s{2,}/.test(line)) cols = line.split(/\s{2,}/);
        else {
            var arRe = /[؀-ۿݐ-ݿﭐ-﷿ﹰ-﻿]/;
            var heRe = /[א-ת]/;
            var firstHe = -1;
            for (var i = 0; i < line.length; i++) {
                if (heRe.test(line[i])) { firstHe = i; break; }
            }
            if (firstHe > 0 && arRe.test(line.slice(0, firstHe))) cols = [line.slice(0, firstHe), line.slice(firstHe)];
            else cols = line.split(/\s+/);
        }
        return cols.map(function(c) { return (c || '').trim(); }).filter(function(c) { return c !== ''; });
    }

    function _tableImportLooksArabic(text) {
        return /[؀-ۿݐ-ݿﭐ-﷿ﹰ-﻿]/.test(text || '');
    }

    function _tableImportLooksHebrew(text) {
        return /[א-ת]/.test(text || '');
    }

    function _tableImportIsHeaderCells(cols) {
        var joined = (cols || []).join(' ').replace(/\s+/g, ' ').trim().toLowerCase();
        return joined === 'ערבית עברית' || joined === 'עברית ערבית' ||
            (joined.indexOf('ערבית') >= 0 && joined.indexOf('עברית') >= 0 && joined.length <= 22);
    }

    function _tableImportRowFromCols(cols) {
        if (!cols || !cols.length || _tableImportIsHeaderCells(cols)) return null;
        var row = { arabic: '', form: '', hebrew: '', status: 'pending' };
        if (cols.length === 1) {
            row.arabic = cols[0];
        } else if (cols.length === 2) {
            // Excel in RTL/Word sometimes copies the Hebrew column first even
            // when the visual table shows Arabic on the right.
            if (_tableImportLooksHebrew(cols[0]) && _tableImportLooksArabic(cols[1])) {
                row.arabic = cols[1];
                row.hebrew = cols[0];
            } else {
                row.arabic = cols[0];
                row.hebrew = cols[1];
            }
        } else {
            row.arabic = cols[0];
            row.form = cols.slice(1, cols.length - 1).join(' ');
            row.hebrew = cols[cols.length - 1];
            if (_tableImportLooksHebrew(row.arabic) && _tableImportLooksArabic(row.hebrew)) {
                var oldArabic = row.arabic;
                row.arabic = row.hebrew;
                row.hebrew = oldArabic;
                row.form = cols.slice(1, cols.length - 1).join(' ');
            }
        }
        row.status = (row.arabic && row.hebrew) ? 'ready' : 'pending';
        return row;
    }

    function parseTableImportRows(raw) {
        var lines = (raw || '').split(/\r?\n/);
        var rows = [];
        var singleCells = [];
        lines.forEach(function(line) {
            line = (line || '').trim();
            if (!line) return;
            var cols = _splitTableImportLine(line);
            if (!cols.length) return;
            if (cols.length === 1 && !_tableImportIsHeaderCells(cols)) {
                singleCells.push(cols[0]);
                return;
            }
            var row = _tableImportRowFromCols(cols);
            if (row) rows.push(row);
        });
        singleCells = singleCells.filter(function(cell) {
            var normalized = (cell || '').replace(/\s+/g, ' ').trim();
            return normalized !== 'ערבית' && normalized !== 'עברית' && !_tableImportIsHeaderCells([cell]);
        });
        for (var i = 0; i < singleCells.length; i++) {
            var cur = singleCells[i];
            var next = singleCells[i + 1] || '';
            if (!cur) continue;
            if (next && _tableImportLooksArabic(cur) && _tableImportLooksHebrew(next)) {
                rows.push({ arabic: cur, form: '', hebrew: next, status: 'ready' });
                i++;
            } else if (next && _tableImportLooksHebrew(cur) && _tableImportLooksArabic(next)) {
                rows.push({ arabic: next, form: '', hebrew: cur, status: 'ready' });
                i++;
            } else {
                rows.push({ arabic: cur, form: '', hebrew: '', status: 'pending' });
            }
        }
        return rows;
    }

