                        if (b.textContent === q.correct) b.classList.add('correct');
                    });
                    feedback.textContent = 'לא נכון — ' + q.correct;
                    feedback.className = 'trivia-feedback show wrong-feedback';
                }
                if (q.verb.notes) {
                    feedback.innerHTML = feedback.textContent + '<br><span style="font-size:0.85em;color:#6b7280;margin-top:4px;display:inline-block">📝 ' + q.verb.notes + '</span>';
                }
                renderStreakBar('conj-streak-bar', conjStreak, conjBestStreak);
                document.getElementById('conj-score').textContent = conjCorrect + ' / ' + conjTotal + ' נכון';
                var conjNextBtn = document.getElementById('conj-next');
                conjNextBtn.style.display = 'block';
