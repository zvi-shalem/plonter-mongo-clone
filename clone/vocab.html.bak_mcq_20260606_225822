        [{ label: 'בניין ' + q.binyan }, { label: tenseLabel }, { label: q.person.he + ' (' + q.person.ar + ')' }, { label: 'משקל: ' + q.pattern }].forEach(function(t) {
            var span = document.createElement('span');
            span.className = 'detail-tag';
