    // 🎤 Voice — Web Speech API. Default lang='ar-SA'. Long-press for he-IL is future work.
    var _editAddFastRecognition = null;
    function _editAddFastMic() {
        var btn = document.getElementById('edit-add-fast-mic');
        var inp = document.getElementById('edit-add-fast-input');
        if (!inp || !btn) return;
        var SR = window.SpeechRecognition || window.webkitSpeechRecognition;
        if (!SR) {
            alert('הדפדפן הזה לא תומך בזיהוי דיבור. נסה Chrome / Safari עדכניים.');
            return;
        }
        if (_editAddFastRecognition) {
