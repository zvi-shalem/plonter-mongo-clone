                    var title = c.title || it.title || '';
                    var catData;
                    try { catData = (c.data && typeof c.data === 'object') ? c.data : JSON.parse(c.data || '{}'); } catch (_) { catData = {}; }
                    var all = (typeof getCustomData === 'function') ? getCustomData() : {};
                    all[title] = catData;
                    try { localStorage.setItem('plonter_vocab_v2', JSON.stringify(all)); } catch (_) {}
                    try {
                        var meta = JSON.parse(localStorage.getItem('plonter_sync_meta') || '{}');
                        // No shareToken: identity-authorised (user/email). contentSync's
                        // update authorises against the owner's row by identity.
                        meta['vocab_category:' + title] = Object.assign(meta['vocab_category:' + title] || {}, {
                            synced: true, serverId: c.id, sharedRole: it.role
                        });
                        localStorage.setItem('plonter_sync_meta', JSON.stringify(meta));
