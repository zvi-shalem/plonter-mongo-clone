    // Global Ctrl+G handler for all text inputs — Hebrew to Arabic transliteration
    // Uses e.code='KeyG' for layout-independence (works in Hebrew/Arabic/English keyboard)
    function isCtrlG(e) {
        return (e.ctrlKey || e.metaKey) && (e.code === 'KeyG' || e.key === 'g' || e.key === 'G' || e.key === 'ע' || e.keyCode === 71);
    }
    // Flashcard verdict shortcuts (layout-independent via e.code):
    //   Z / Ctrl+A = "really didn't know"
    //   X / A / ArrowLeft = "didn't know"
    //   C / D / ArrowRight = "knew"
    // Only active in flashcard mode AFTER the card has been flipped (user must see the answer first)
    document.addEventListener('keydown', function(e) {
        if (e.metaKey || e.altKey) return;
        var code = e.code;
        var key = (e.key || '').toLowerCase();
        var isCtrlA = e.ctrlKey && (code === 'KeyA' || key === 'a' || key === 'ש');
        if (e.ctrlKey && !isCtrlA) return;
        var isZ = !e.ctrlKey && (code === 'KeyZ' || key === 'z' || key === 'ז');
        var isX = !e.ctrlKey && (code === 'KeyX' || code === 'KeyA' || code === 'ArrowLeft' || key === 'x' || key === 'ס' || key === 'a' || key === 'ש');
        var isC = !e.ctrlKey && (code === 'KeyC' || code === 'KeyD' || code === 'ArrowRight' || key === 'c' || key === 'ב' || key === 'd' || key === 'ג');
        if (!isZ && !isX && !isC && !isCtrlA) return;
        var fcMode = document.getElementById('flashcards-mode');
        if (!fcMode || fcMode.style.display === 'none') return;
        var active = document.activeElement;
        if (active && (active.tagName === 'INPUT' || active.tagName === 'TEXTAREA' || active.isContentEditable)) return;
        // Require card to be flipped — user must see the answer before the verdict is accepted
        if (typeof fcCardFlipped === 'undefined' || !fcCardFlipped) return;
        e.preventDefault();
        if (typeof fcVerdict !== 'function') return;
        if (isZ || isCtrlA) fcVerdict('notsure');
        else if (isX) fcVerdict('didnt');
        else if (isC) fcVerdict('knew');
    });

    document.addEventListener('keydown', function(e) {
        if (!isCtrlG(e)) return;
        var el = document.activeElement;
        if (!el || (el.tagName !== 'INPUT' && el.tagName !== 'TEXTAREA') || el.type === 'checkbox' || el.type === 'radio') return;
        e.preventDefault();
        var start = el.selectionStart, end = el.selectionEnd;
        if (start !== undefined && start !== end) {
            // Convert only selected text
            var before = el.value.substring(0, start);
            var selected = el.value.substring(start, end);
            var after = el.value.substring(end);
            var converted = transliterate(selected);
            el.value = before + converted + after;
            el.setSelectionRange(start, start + converted.length);
        } else {
            // No selection — convert entire field
            el.value = transliterate(el.value);
        }
    });

    function addTranslitBtn(inputEl) {
