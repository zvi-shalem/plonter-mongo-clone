                results.innerHTML = '<div style="text-align:center;color:#9ca3af;padding:16px">מחפש במילון החינמי של HUJI...</div>';
                fetch(_vdHujiFreeSearchUrl(clean, 1))
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        results.innerHTML = '';
                        if (!data.ok || data.error) {
                            results.innerHTML = '<div style="color:#ef4444;padding:8px">שגיאה בחיפוש במילון החינמי</div>';
                            return;
                        }
                        if (!data.entries || data.entries.length === 0) {
                            results.innerHTML = '<div style="color:#6b7280;padding:8px">לא נמצאו ערכים במילון החינמי</div>';
                            return;
                        }
                        Dictionary.renderMilsonEntries(results, data.entries, { includePin: false });
                    })
                    .catch(function() {
                        results.innerHTML = '<div style="color:#ef4444;padding:8px">שגיאת רשת במילון החינמי</div>';
                    });
            } else {
                _vdShowMilsonLoginPrompt(results);
            }
            return;
        }
        fetch(searchUrl)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                results.innerHTML = '';
                if (data.error) { results.innerHTML = '<div style="color:#ef4444;padding:8px">שגיאה</div>'; return; }
                if (!data.entries || !data.entries.length) {
                    // ه→ة fallback
                    if (clean.endsWith('\u0647')) {
                        var alt = clean.slice(0, -1) + '\u0629';
                        var altUrl = _vdMilsonSearchUrl(alt, 1);
                        if (!altUrl) { _vdShowMilsonLoginPrompt(results); return; }
                        fetch(altUrl)
                            .then(function(r) { return r.json(); })
                            .then(function(d2) {
                                if (d2.entries && d2.entries.length) {
                                    results.innerHTML = '';
                                    Dictionary.renderMilsonEntries(results, d2.entries, { includePin: false });
                                } else {
                                    results.innerHTML = '<div style="color:#9ca3af;padding:16px;text-align:center">אין תוצאות עבור "' + clean + '"</div>';
                                }
                            });
                        return;
                    }
                    // ال fallback
                    if (clean.indexOf('\u0627\u0644') === 0 || clean.indexOf('\u0671\u0644') === 0 || clean.indexOf('\u0623\u0644') === 0) {
                        var noAl = clean.replace(/^[\u0627\u0671\u0623]\u0644/, '');
                        if (noAl.length > 0) {
                            var noAlUrl = _vdMilsonSearchUrl(noAl, 1);
