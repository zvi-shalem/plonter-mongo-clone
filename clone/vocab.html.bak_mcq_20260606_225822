        (function _injectSharedWithMe() {
            if (typeof ContentShare === 'undefined' || !ContentShare.sharedWithMe) return;
            var SID = 'vocab-shared-with-me-section';
            var prev = document.getElementById(SID);
            if (prev && prev.parentNode) prev.parentNode.removeChild(prev);
            function _openSharedVocabCategory(it) {
                if (typeof ContentShare === 'undefined' || !ContentShare.fetchContentById) return;
                ContentShare.fetchContentById(it.content_id).then(function(c) {
                    if (!c || c.content_type !== 'vocab_category') {
                        if (typeof showSoftToast === 'function') showSoftToast('הקישור אינו זמין');
                        return;
