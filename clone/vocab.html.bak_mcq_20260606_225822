    function _vocabUploadClip(blob, catName, wordKey) {
        var token = _vocabAuthToken();
        if (!token) {
            alert('יש להתחבר כדי לשמור הקלטות.');
            if (typeof PlonterAuth !== 'undefined' && PlonterAuth.showLoginDialog) PlonterAuth.showLoginDialog();
            return;
        }
        // Inline upload toast
        if (typeof showSoftToast === 'function') showSoftToast('מעלה הקלטה…');
        var fd = new FormData();
        fd.append('word_key', wordKey);
        fd.append('cat_name', _audioServerCatName(catName || ''));
        fd.append('audio', blob, 'clip.webm');
        fetch('/plonter/api/vocab_audio_api.php?action=upload', {
            method: 'POST',
            headers: { 'Authorization': 'Bearer ' + token },
            body: fd
        })
        .then(function(r) { return r.json(); })
        .then(function(res) {
            if (!res || !res.success || !res.id) {
                alert('שגיאה בהעלאה: ' + ((res && res.error) || 'unknown'));
                return;
            }
            var prev = _audioIdsForWord(catName, wordKey);
            var all = _audioGetForCat(catName);
            var _nk = _audioNormKey(wordKey);
            all[_nk] = [res.id];
            _audioSaveForCat(catName, all);
            if (window.VocabProgressSync && VocabProgressSync.onAudioAttached) {
                VocabProgressSync.onAudioAttached(catName, wordKey, res.id);
            }
            prev.forEach(function(oldId) {
                if (oldId === res.id) return;
                _vocabDeleteBlobOnServer(oldId);
            });
            if (typeof showSoftToast === 'function') showSoftToast('ההקלטה נשמרה ✓');
            if (typeof renderEditContent === 'function') renderEditContent();
