                var _newestSticker = _isNewestInGroup ? _newestCategoryStickerHtml() : '';
                card.innerHTML = btns + _categoryShareButtonsHtml() + _newestSticker + _noaSticker + _rashSticker + _idoYosefSticker + '<div class="cat-name">' + _displayName + ' ' + (cat.publicShared ? '' : _vocabBadge(catName)) + '</div><div class="cat-count">' + wc + ' מילים</div>' + _audBadge2 + _auditDoneBadgeHtml(catName) + _globalBadgeHtml(_isGlobal2);
