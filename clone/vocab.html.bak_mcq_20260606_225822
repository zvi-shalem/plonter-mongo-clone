    function _doEditSave() {
        // Built-in categories are readonly — no-op save (the ▶ button still opens the game below)
        if (editOriginalName && BUILTIN_CATEGORIES.hasOwnProperty(editOriginalName)) return true;
        var newName = document.getElementById('edit-cat-name').value.trim();
        if (!newName) { alert('יש לתת שם לקטגוריה'); return false; }
        var custom = getCustomData();

        // If renamed, remove old custom entry
        var _renamedFrom = null;
        if (editOriginalName !== newName && custom[editOriginalName]) {
            delete custom[editOriginalName];
            _renamedFrom = editOriginalName;
        }

        if (!custom[newName]) custom[newName] = {};
        custom[newName].words = editWords.slice();
        if (editConjugations.length > 0) {
            custom[newName].conjugations = editConjugations.slice();
        }
        if (BUILTIN_CATEGORIES.hasOwnProperty(newName)) {
            custom[newName].overrideBuiltin = true;
        }
        saveCustomData(custom);
        // Ghost-deletion fix (task #51): mirror this save into the guest backup.
        // A rename leaves the old name as a removed category (prune it); for the
        // surviving category, drop any words that were removed in this edit.
        if (_renamedFrom) _pruneGuestVocabBackupForCategory(_renamedFrom);
        _syncGuestVocabBackupWords(newName, editWords);
        if (_renamedFrom && window.VocabProgressSync) VocabProgressSync.onCategoryRenamed(_renamedFrom, newName);
        // Push the fresh words to any active share-tokens for this category
        // so teachers opening existing links see the updated word list
        // (Amitai 2026-04-24 15:25). Fire-and-forget.
        try { if (_canEditAudioForCat(newName)) _refreshShareTokensWords(newName, editWords); } catch (_) {}
        editOriginalName = newName;
        editDirty = false;
        try { _publicAutoPublishIfNeeded(newName); } catch (_) {}
        return true;
    }

    function _refreshShareTokensWords(catName, words) {
        var token = _vocabAuthToken();
        if (!token || !catName) return;
        var payloadWords = (words || []).map(function(w) {
            return { arabic: w.arabic || '', form: w.form || '', hebrew: w.hebrew || '' };
        });
        fetch('/plonter/api/vocab_share_api.php?action=refresh_tokens_words', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
            body: JSON.stringify({ category: catName, words: payloadWords })
        }).catch(function(e) { console.warn('[share] refresh tokens failed', e); });
    }

