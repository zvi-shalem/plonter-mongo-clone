        if (conjIndex >= conjQuestions.length) { conjIndex = 0; shuffle(conjQuestions); }
        var q = conjQuestions[conjIndex];

        document.getElementById('conj-root').textContent = q.root;
        var details = document.getElementById('conj-details');
        details.innerHTML = '';
