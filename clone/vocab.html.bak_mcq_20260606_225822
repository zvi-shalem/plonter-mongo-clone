                    window.__sharedEditCats = window.__sharedEditCats || {};
                    window.__sharedEditCats[title] = it.role;
                    if (it.role === 'edit' && typeof openEditMode === 'function') openEditMode(title);
                    else if (typeof enterGame === 'function') enterGame(title);
                });
            }
            ContentShare.sharedWithMe('vocab_category').then(function(items) {
                if (!items || !items.length) return;
                var sect = document.createElement('div');
                sect.id = SID;
                sect.style.cssText = 'grid-column:1 / -1;margin-top:10px';
