    var _triviaLastIndex = -1;
    function _triviaSelectionWeight(w, idx, stats, notSure) {
        if (idx === _triviaLastIndex) return 0;
        var s = stats[_wordKey(w)];
        var weight;
        if (!s) {
            weight = 8;
        } else if (_triviaIsWrong(s)) {
            weight = 10 + Math.min(8, (s.wrong || 0) * 2) - Math.min(6, (s.postMistakeStreak || 0) * 2);
        } else if (s.wrong > 0) {
            weight = 3;
        } else {
            weight = Math.max(1, 4 - Math.min(3, s.correct || 0));
        }
        if (notSure[_wordKey(w)]) weight += 8;
        return Math.max(1, weight);
    }
    function _pickSmartIndex() {
        var words = shuffledWords;
        if (words.length < 2) return 0;
        var stats = _getTriviaStats();
        var notSure = _getNotSure();
        // Weighted practice: recent correct answers lower a word's chance,
        // mistakes raise it, and "not sure" words get an extra boost.
        // Zero weight for the previously-picked word so we never repeat the same one consecutively.
        var weights = words.map(function(w, idx) {
            return _triviaSelectionWeight(w, idx, stats, notSure);
        });
        var total = weights.reduce(function(a, b) { return a + b; }, 0);
        if (total === 0) {
            // All weights zero (e.g. only one word or all blocked) — fall back to any different index
            return (_triviaLastIndex + 1) % words.length;
        }
        var r = Math.random() * total;
        var cumulative = 0;
        var picked = words.length - 1;
        for (var i = 0; i < weights.length; i++) {
            cumulative += weights[i];
            if (r <= cumulative) { picked = i; break; }
        }
        _triviaLastIndex = picked;
        return picked;
    }

