    // Called from the CTAs at the top of each open warehouse list in
    // _renderTriviaProgress, and from the existing round-complete panel.
    function triviaStartBucket(bucket) {
        var stats = _getTriviaStats();
        var notSure = (typeof _getNotSure === 'function') ? _getNotSure() : {};
        var fullList = _filterByFcStar ? _filterByFcStar(getCategoryWords(currentCategory)) : getCategoryWords(currentCategory);
        var filtered = fullList.filter(function(w) {
            var s = stats[_wordKey(w)];
            var isNotSure = !!notSure[_wordKey(w)];
            if (bucket === 'notsure') return isNotSure;
            if (bucket === 'wrong') return s && _triviaIsWrong(s);
            if (bucket === 'correct') return s && !_triviaIsWrong(s) && !isNotSure;
            // 'everwrong' — ANY word that has ever had a miss recorded,
            // even if the user later built up mastery (postMistakeStreak>=3)
            // and the current UI status is 'צדקתי'. Amitai 2026-04-19 21:45:
            // round-complete dialog should offer a round on these too.
            if (bucket === 'everwrong') return s && s.wrong > 0;
            // Combined bucket: not-sure ∪ ever-wrong. Amitai 2026-05-12.
            if (bucket === 'notsure_or_everwrong') return isNotSure || (s && s.wrong > 0);
            return true;
        });
        if (filtered.length < 2) {
            // Not enough words in this bucket to run a meaningful trivia —
            // fall back to the full round rather than loop on one word.
            triviaStartNewRound();
