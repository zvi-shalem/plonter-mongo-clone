    // One-time migration: convert old per-category star keys (cat_arabic)
    // into the global arabic|hebrew format so stars are shared across modes.
    (function migrateStarsOnce() {
        try {
            if (localStorage.getItem('plonter_vocab_stars_migrated_v2') === '1') return;
            var starred = getStarred();
            var allCats = {};
            // BUILTIN_CATEGORIES
            if (typeof BUILTIN_CATEGORIES !== 'undefined') {
                Object.keys(BUILTIN_CATEGORIES).forEach(function(name) { allCats[name] = BUILTIN_CATEGORIES[name]; });
            }
            // Custom categories from localStorage
            try {
                var custom = JSON.parse(localStorage.getItem('plonter_vocab_v2') || '{}');
                Object.keys(custom).forEach(function(name) { allCats[name] = custom[name]; });
            } catch(e) {}
            var migrated = 0;
            Object.keys(allCats).forEach(function(catName) {
                var words = (allCats[catName] && allCats[catName].words) || [];
                words.forEach(function(w) {
                    var oldKey = catName + '_' + (w.arabic || '');
                    var newKey = (w.arabic || '') + '|' + (w.hebrew || '');
                    if (starred[oldKey] && !starred[newKey]) {
                        starred[newKey] = true;
                        migrated++;
                    }
                });
            });
            if (migrated > 0) {
                localStorage.setItem('plonter_vocab_stars', JSON.stringify(starred));
            }
            localStorage.setItem('plonter_vocab_stars_migrated_v2', '1');
        } catch (e) {}
    })();

