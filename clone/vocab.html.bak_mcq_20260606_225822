    // ============ EDITOR ARABIC-INPUT HELPERS (E2/E5 — 2026-05-27) ============
    // Generic "insert string at the cursor" for the geresh button (E2) and the
    // tashkeel quick-insert bar (E5). Dispatches an 'input' event so the field's
    // oninput-bound live preview / add-button state stay in sync.
    function _insertAtEditCursor(el, str) {
        if (!el) return;
        var s = (el.selectionStart != null) ? el.selectionStart : el.value.length;
        var e = (el.selectionEnd != null) ? el.selectionEnd : el.value.length;
        el.value = el.value.slice(0, s) + str + el.value.slice(e);
        var pos = s + str.length;
        el.focus();
        try { el.setSelectionRange(pos, pos); } catch (_) {}
        try { el.dispatchEvent(new Event('input')); } catch (_) {}
    }

    // E2 (2026-05-27): geresh-insert button — replaces the old ع→א convert
    // button on the Arabic answer field. Inserts an apostrophe ('); typing a
    // letter followed by it (e.g. ח') makes transliterate() emit the special
    // Arabic letter (ח'→خ, ד'→ذ, צ'→ض …). Idempotent across re-renders.
    function addGereshBtn(inputEl) {
        if (!inputEl) return;
        var sib = inputEl.nextElementSibling;
        while (sib) {
            if (sib.classList && sib.classList.contains('geresh-btn')) return; // already present
            if (sib.tagName !== 'BUTTON') break; // reached the next field
            sib = sib.nextElementSibling;
        }
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.textContent = "'";
        btn.className = 'geresh-btn';
        btn.title = "הכנס גרש — לאותיות מיוחדות (ח'→خ, ד'→ذ, צ'→ض …)";
        btn.style.cssText = 'background:#f0fdfa;color:#0d9488;border:1px solid #0d9488;border-radius:6px;padding:4px 9px;font-size:1em;font-weight:bold;cursor:pointer;white-space:nowrap;flex-shrink:0';
        btn.onmousedown = function(e) { e.preventDefault(); }; // keep field focus
        btn.onclick = function(e) { e.preventDefault(); e.stopPropagation(); _insertAtEditCursor(inputEl, "'"); };
        inputEl.parentNode.insertBefore(btn, inputEl.nextSibling);
    }

    // E5 (2026-05-27): floating tashkeel quick-insert bar above the תוספת field.
    // Appears (fade + slide-in) on focus, disappears on blur. Buttons insert at
    // the cursor: (ج) / damma ُ / fatha َ / kasra ِ.
    var _formQuickBar = null, _formQuickBarHideTimer = null;
    function _ensureFormQuickBar() {
        if (_formQuickBar) return _formQuickBar;
        var bar = document.createElement('div');
        bar.id = 'edit-form-quick-bar';
        bar.style.cssText = 'position:fixed;z-index:10000;display:none;gap:6px;background:#0d9488;padding:6px 8px;border-radius:10px;box-shadow:0 4px 14px rgba(13,148,136,0.35);opacity:0;transform:translateY(6px) scale(0.96);transition:opacity .16s ease, transform .16s cubic-bezier(.2,.9,.3,1.35);pointer-events:none;direction:rtl';
        var items = [
            { label: '(ج)', ins: '(ج)', title: 'הוסף (ج)' },
            { label: 'ـُ', ins: 'ُ', title: 'דَמّה (U)' },
            { label: 'ـَ', ins: 'َ', title: 'פَתْחה (A)' },
            { label: 'ـِ', ins: 'ِ', title: 'כַּסְרה (I)' }
        ];
        items.forEach(function(it) {
            var b = document.createElement('button');
            b.type = 'button';
            b.textContent = it.label;
            b.title = it.title;
            b.style.cssText = 'background:white;color:#0d9488;border:none;border-radius:7px;padding:5px 11px;font-size:1.15em;font-weight:bold;cursor:pointer;font-family:"Times New Roman",serif;min-width:34px';
            b.onmousedown = function(e) { e.preventDefault(); }; // keep field focus
            b.onclick = function(e) { e.preventDefault(); e.stopPropagation(); _insertAtEditCursor(document.getElementById('edit-add-form'), it.ins); };
            bar.appendChild(b);
        });
        document.body.appendChild(bar);
        _formQuickBar = bar;
        return bar;
    }
    function _positionFormQuickBar() {
        var fm = document.getElementById('edit-add-form');
        if (!fm || !_formQuickBar) return;
        var r = fm.getBoundingClientRect();
        var bar = _formQuickBar;
        bar.style.top = Math.max(4, r.top - bar.offsetHeight - 6) + 'px';
        var left = r.right - bar.offsetWidth;
        if (left < 4) left = 4;
        if (left + bar.offsetWidth > window.innerWidth - 4) left = window.innerWidth - 4 - bar.offsetWidth;
        bar.style.left = left + 'px';
    }
    function _showFormQuickBar() {
        if (_formQuickBarHideTimer) { clearTimeout(_formQuickBarHideTimer); _formQuickBarHideTimer = null; }
        var bar = _ensureFormQuickBar();
        bar.style.display = 'flex';
        _positionFormQuickBar();
        void bar.offsetWidth; // reflow before transition
        bar.style.opacity = '1';
        bar.style.transform = 'translateY(0) scale(1)';
        bar.style.pointerEvents = 'auto';
        window.addEventListener('resize', _positionFormQuickBar);
        window.addEventListener('scroll', _positionFormQuickBar, { passive: true });
    }
    function _hideFormQuickBar() {
        if (!_formQuickBar) return;
        var bar = _formQuickBar;
        bar.style.opacity = '0';
        bar.style.transform = 'translateY(6px) scale(0.96)';
        bar.style.pointerEvents = 'none';
        window.removeEventListener('resize', _positionFormQuickBar);
        window.removeEventListener('scroll', _positionFormQuickBar);
        _formQuickBarHideTimer = setTimeout(function() { if (_formQuickBar) _formQuickBar.style.display = 'none'; }, 200);
    }
    function _attachFormQuickInserts(formInput) {
        if (!formInput || formInput._quickInsertsWired) return;
        formInput._quickInsertsWired = true;
        formInput.addEventListener('focus', _showFormQuickBar);
        formInput.addEventListener('blur', _hideFormQuickBar);
    }

