    // Smart parser: returns AN ARRAY of {arabic, form, hebrew} entries.
    // Strategy: walk char-by-char, detect language runs (Arabic vs Hebrew). Each run extends
    // as long as we stay in the same language; whitespace/punct between same-language letters
    // is INCLUDED so multi-word lexemes ("وزير المالية", "שר האוצר") are preserved. Each language
    // switch ends a run. Adjacent runs are paired (run[0]+run[1], run[2]+run[3], …) → one entry per pair.
    // This supports bulk paste like "وزير المالية שר האوצر ولد ילד" → 2 entries.
    // (Amitai 2026-04-30 10:46 single-space; 10:54 bulk lists.)
    function _parseFastEntryAll(raw) {
        var s = (raw || '').trim();
        if (!s) return [];
        var arRe = /[؀-ۿݐ-ݿﭐ-﷿ﹰ-﻿]/;
        var heRe = /[א-ת]/;
        var stripRe = /^[\s\-—–=/|,:;.‎‏]+|[\s\-—–=/|,:;.‎‏]+$/g;

        var runs = [];
        var curLang = null, curStart = -1, curEnd = -1;
        function flushRun() {
            if (curLang !== null && curStart >= 0) {
                var txt = s.slice(curStart, curEnd + 1).replace(stripRe, '').trim();
                if (txt) runs.push({ lang: curLang, text: txt });
            }
            curLang = null; curStart = -1; curEnd = -1;
        }
        for (var i = 0; i < s.length; i++) {
            var c = s[i];
            var lang = arRe.test(c) ? 'ar' : (heRe.test(c) ? 'he' : null);
            if (lang === null) {
                // Whitespace / separator / punct — tentatively extend current run; will trim
                if (curLang !== null) curEnd = i;
                continue;
            }
            if (curLang === null) {
                curLang = lang; curStart = i; curEnd = i;
            } else if (curLang === lang) {
                curEnd = i;
            } else {
                flushRun();
                curLang = lang; curStart = i; curEnd = i;
            }
        }
        flushRun();

        // Pair adjacent runs into entries
        var entries = [];
        for (var j = 0; j < runs.length; j += 2) {
            var r1 = runs[j];
            var r2 = runs[j + 1] || null;
            var entry = { arabic: '', form: '', hebrew: '' };
            if (r1.lang === 'ar') {
                entry.arabic = r1.text;
                entry.hebrew = r2 ? r2.text : '';
            } else {
                entry.hebrew = r1.text;
                entry.arabic = r2 ? r2.text : transliterate(r1.text);
            }
            if (heRe.test(entry.arabic) && !arRe.test(entry.arabic)) entry.arabic = transliterate(entry.arabic);
            entries.push(entry);
        }

        // Special case: zero language runs (input is English/numbers/etc.) — fall back to hebrew slot
        if (entries.length === 0 && s) {
            entries.push({ arabic: '', form: '', hebrew: s });
        }
        return entries;
    }
    // Single-entry adapter (kept for any callers that expect one entry)
    function _parseFastEntry(raw) {
        var arr = _parseFastEntryAll(raw);
        return arr.length ? arr[0] : null;
    }
