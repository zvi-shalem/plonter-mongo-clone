    function getCategoriesForAddVocab() {
        var cats = getAllCategories();
        var result = [];
        for (var name in cats) {
            // Only show categories with words (not conjugation-only)
            if (cats[name].words && cats[name].words.length > 0) result.push(name);
            // Also show custom categories that might be empty but are word categories
            if (!cats[name].conjugations || (cats[name].words && cats[name].words.length > 0)) result.push(name);
        }
        // Deduplicate
        var seen = {};
        return result.filter(function(n) { if (seen[n]) return false; seen[n] = true; return true; });
    }

