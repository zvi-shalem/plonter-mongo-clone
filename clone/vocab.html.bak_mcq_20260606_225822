                toggleBtn.textContent = '⏸';
                toggleBtn.title = 'השהה';
            }).catch(function(e) { console.warn('[vocab audio] autoplay blocked', e); });
        }
        _prepareTrimmedAudio(id, url, function(prep) {
            trimOffset = prep.offsetSec || 0;
            audio.src = prep.blobUrl;
