        };
        try { rec.start(); }
        catch (e) { alert('לא הצלחתי להתחיל הקלטה: ' + e.message); return; }
        _editAddFastRecognition = rec;
        btn.textContent = '⏹';
        btn.style.background = '#fee2e2';
    }

