                _matchImg.src = w.image;
                _matchImg.alt = '';
                _matchImg.style.cssText = 'max-width:100%;max-height:90px;object-fit:contain;border-radius:6px;display:block;margin:0 auto;min-height:60px;min-width:90px';
                _attachFlagLoadingShimmer(_matchImg);
                el.appendChild(_matchImg);
                if (w.hebrew) {
