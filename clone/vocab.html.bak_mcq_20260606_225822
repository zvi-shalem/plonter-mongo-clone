    function matchClick(side, pairIndex, el) {
        if (el.classList.contains('matched')) return;
        // Auto-play the Arabic recording when either column is clicked, so the
        // learner gets audio reinforcement alongside visual. Skip if we've
        // already matched this pair — no sound after a match animation.
        if (typeof _isAudioAutoplayOn === 'function' && _isAudioAutoplayOn()) {
            var wk = el.getAttribute('data-word-key');
            if (wk && typeof _playWordRecording === 'function') {
                try { _playWordRecording(currentCategory, wk); } catch (_) {}
            }
        }

        // If clicking same side as already selected, switch selection
        if (matchSelected && matchSelected.side === side) {
            matchSelected.el.classList.remove('selected');
            if (matchSelected.el === el) { matchSelected = null; return; }
            matchSelected = { side: side, index: pairIndex, el: el };
            el.classList.add('selected');
            return;
        }

        // First selection
        if (!matchSelected) {
            matchSelected = { side: side, index: pairIndex, el: el };
            el.classList.add('selected');
            return;
        }

        // Second selection — check match
        el.classList.add('selected');
        if (matchSelected.index === pairIndex) {
            // Correct match!
            matchedCount++;
            var el1 = matchSelected.el;
            var el2 = el;
            setTimeout(function() {
                el1.classList.add('matched');
                el2.classList.add('matched');
                el1.classList.remove('selected');
                el2.classList.remove('selected');
            }, 300);
            document.getElementById('matching-score').textContent = matchedCount + ' / ' + matchTotal;
            matchSelected = null;

            if (matchedCount >= matchTotal) {
                stopMatchTimer();
                var elapsedMs = Date.now() - matchStartTime;
                var elapsedSec = (elapsedMs / 1000).toFixed(1);
                var isNewBest = !matchBestTime || (elapsedMs / 1000) < matchBestTime;
                if (isNewBest) {
                    matchBestTime = elapsedMs / 1000;
                    localStorage.setItem(getMatchBestKey(), matchBestTime.toFixed(1));
                }
                setTimeout(function() {
                    var msg = 'כל הכבוד! סיימת ב-' + elapsedSec + ' שניות';
                    if (isNewBest) msg += ' 🏆 שיא חדש!';
                    document.getElementById('matching-complete').textContent = msg;
                    document.getElementById('matching-complete').style.display = 'block';
                    document.getElementById('matching-restart').style.display = 'inline-block';
                    var bestEl = document.getElementById('matching-best');
                    if (bestEl) bestEl.textContent = '🏆 שיא: ' + matchBestTime.toFixed(1) + ' שניות';
                    // Collapse the now-empty matching board so the completion
                    // message + 'play again' button rise into the freed space
                    // (Amitai 2026-04-17: button was too low → users miss it).
                    var board = document.getElementById('matching-board');
                    if (board) board.style.display = 'none';
                }, 600);
            }
        } else {
            // Wrong match
            var el1 = matchSelected.el;
            var el2 = el;
            el1.classList.add('wrong');
            el2.classList.add('wrong');
            setTimeout(function() {
                el1.classList.remove('selected', 'wrong');
                el2.classList.remove('selected', 'wrong');
            }, 600);
            matchSelected = null;
        }
    }

    // ============ MEMORY CARD GAME ============
    var memoryCards = [];
    var memoryFlipped = [];
    var memoryLocked = false;
    var memoryPlayers = 1;
    var memoryCurrentPlayer = 0;
    var memoryScores = [0, 0];
    var memoryNames = ['שחקן 1', 'שחקן 2'];
