    // Humanize remaining-seconds. Mirrors share.html's fmtRemaining for visual
    // consistency between the dialog and the recipient's view.
    function _grpFmtRemaining(secs) {
        secs = parseInt(secs, 10) || 0;
        if (secs <= 0) return 'פג';
        if (secs >= 86400) return 'עוד ' + Math.floor(secs / 86400) + ' ימים';
        if (secs >= 3600)  return 'עוד ' + Math.floor(secs / 3600)  + ' שעות';
        if (secs >= 60)    return 'עוד ' + Math.floor(secs / 60)    + ' דקות';
        return 'עוד ' + secs + ' שניות';
    }
    function _grpFmtDate(unixSec) {
        if (!unixSec) return '—';
        return new Date(unixSec * 1000).toLocaleDateString('he-IL', {
            day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit'
        });
    }
    function _grpEsc(s) {
        return String(s == null ? '' : s).replace(/[&<>"]/g, function(c) {
            return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c];
        });
    }

    function _refreshGroupShareWarehouse(label) {
        var bannerEl    = document.getElementById('grp-share-existing-banner');
