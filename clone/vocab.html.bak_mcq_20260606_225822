        };
        // Autoplay on the front side: match the visible-side language so
        // ar2he plays Arabic (not whichever recording is newest), and he2ar
        // plays Hebrew on the Hebrew front. Back-side autoplay is in flipCard.
        // Amitai 2026-04-24 17:01.
        if (fcDirection === 'ar2he') _audioAutoplayIfOn(w, currentCategory, 'ar');
        else _audioAutoplayIfOn(w, currentCategory, 'he');
