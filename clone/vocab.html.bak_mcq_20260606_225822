                sgrid.style.cssText = 'display:grid;grid-template-columns:repeat(auto-fill, minmax(160px, 1fr));gap:12px';
                items.forEach(function(it) {
                    var card = document.createElement('div');
                    card.className = 'cat-card';
                    card.style.cssText = 'cursor:pointer;border:1px solid #a5f3fc;border-top:4px solid #0891b2';
                    var roleBadge = it.role === 'edit' ? '✏️ עריכה' : '👁 צפייה';
                    var safeTitle = String(it.title || '').replace(/[&<>"]/g, function(ch) { return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[ch]; });
