            details.appendChild(span);
        });

        // Wrong options — always same root
        var wrongPool = [];
        var v = q.verb;
        ['past', 'present', 'imperative', 'participle'].forEach(function(t) {
            if (!v[t]) return;
            for (var p in v[t]) {
                if (v[t][p] !== q.correct) wrongPool.push(v[t][p]);
            }
        });
        var seen = {}; seen[q.correct] = true;
        var uniqueWrongs = [];
        wrongPool.forEach(function(w) { if (!seen[w]) { seen[w] = true; uniqueWrongs.push(w); } });
        shuffle(uniqueWrongs);

        var options = [{ text: q.correct, correct: true }];
        for (var i = 0; i < 3 && i < uniqueWrongs.length; i++) {
            options.push({ text: uniqueWrongs[i], correct: false });
        }
