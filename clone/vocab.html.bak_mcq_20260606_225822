    // falls back to nothing (no TTS per Amitai 'בלי TTS').
    // Optional `lang` — when the caller knows which side is visible (flashcard
    // front/back), pass 'ar' or 'he' so autoplay picks the matching recording.
    // Omitting it falls back to the first id regardless of lang (legacy trivia
    // / matching / etc.). Amitai 2026-04-24 17:01: autoplay was playing
    // whichever recording was newest instead of the visible-side language.
    // Debounce guard (Amitai 2026-04-24 22:38): two renderCard calls in quick
    // succession (e.g. enterGame → _refreshAudioIdsForCategory → re-render)
    // used to queue two autoplays and the first word was read twice. Suppress
    // same (cat, word, lang) autoplay within 1500ms.
    var _lastAutoplaySig = null, _lastAutoplayAt = 0;
    function _audioAutoplayIfOn(w, catName, lang) {
        if (!_isAudioAutoplayOn()) return;
        if (!w) return;
        var wordKey = (w.arabic || '') + '|' + (w.hebrew || '');
        // Bail early if audio_ids haven't loaded yet (enterGame fires
        // _refreshAudioIdsForCategory async; first renderCard runs before the
        // fetch completes). Without this guard the debounce below was arming
        // on a no-op call and blocking the post-fetch re-render's retry —
        // autoplay never fired (Amitai 2026-04-26 23:24 'לא משמיע אוטומטית').
        if (_audioFirstIdForWord(catName, wordKey, lang) == null) return;
        var sig = catName + '|' + wordKey + '|' + (lang || '');
        var now = Date.now();
        if (_lastAutoplaySig === sig && (now - _lastAutoplayAt) < 1500) return;
        _lastAutoplaySig = sig;
        _lastAutoplayAt = now;
        setTimeout(function() { _playWordRecording(catName, wordKey, lang); }, 120);
    }

    // ============ BUCKET LONG-PRESS → COPY (Amitai 2026-04-25 22:33) ============
    // Long-press a warehouse tab/header (ידעתי / לא ידעתי / ממש לא ידעתי / טעיתי /
    // צדקתי / עדיין לא סגור) → copy that bucket's words to clipboard.
    function _attachLongPress(el, onLongPress) {
        if (!el || el._lpBound) return;
        el._lpBound = true;
        var timer = null, sx = 0, sy = 0;
        var start = function(e) {
            var t = (e.touches && e.touches[0]) ? e.touches[0] : e;
            sx = t.clientX; sy = t.clientY;
            if (timer) clearTimeout(timer);
            timer = setTimeout(function() {
                timer = null;
                window._lpFiredAt = Date.now(); // arms the document-level click swallower below
                try { if (navigator.vibrate) navigator.vibrate(35); } catch(_) {}
                onLongPress();
            }, 600);
        };
        var cancel = function() { if (timer) { clearTimeout(timer); timer = null; } };
        var move = function(e) {
            if (!timer) return;
            var t = (e.touches && e.touches[0]) ? e.touches[0] : e;
            if (Math.abs(t.clientX - sx) > 12 || Math.abs(t.clientY - sy) > 12) cancel();
        };
        el.addEventListener('touchstart', start, { passive: true });
        el.addEventListener('mousedown', start);
        el.addEventListener('touchmove', move, { passive: true });
        el.addEventListener('mousemove', move);
        el.addEventListener('touchend', cancel);
        el.addEventListener('touchcancel', cancel);
        el.addEventListener('mouseup', cancel);
        el.addEventListener('mouseleave', cancel);
        // Prevent the iOS/Android long-press context menu from interfering
        el.addEventListener('contextmenu', function(e) { e.preventDefault(); });
    }
    // One-time document-level click swallower: once long-press fires (sets
    // window._lpFiredAt), the synthesized click that follows is captured at
    // document level and stopImmediatePropagation'd before it reaches the
    // target's inline onclick (which would otherwise toggle the warehouse).
    if (!document._lpSwallowerInstalled) {
        document._lpSwallowerInstalled = true;
        document.addEventListener('click', function(e) {
            if (window._lpFiredAt && (Date.now() - window._lpFiredAt) < 700) {
                window._lpFiredAt = 0;
                e.preventDefault();
                e.stopImmediatePropagation();
                e.stopPropagation();
            }
        }, true);
    }

    function _showCopyBucketToast(msg, ok) {
        var el = document.getElementById('_copy-bucket-toast');
        if (!el) {
            el = document.createElement('div');
            el.id = '_copy-bucket-toast';
            el.style.cssText = 'position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);padding:14px 22px;border-radius:12px;font-weight:bold;z-index:99999;font-size:1.05em;box-shadow:0 8px 28px rgba(0,0,0,0.25);pointer-events:none;text-align:center;direction:rtl;max-width:80vw';
            document.body.appendChild(el);
        }
        el.style.background = ok ? '#16a34a' : '#dc2626';
        el.style.color = '#fff';
        el.style.transition = 'opacity 0.25s';
        el.textContent = msg;
        el.style.opacity = '1';
        if (el._timer) clearTimeout(el._timer);
        el._timer = setTimeout(function() { el.style.opacity = '0'; }, 1900);
    }

    // Format an array of {label, words} groups into a single clipboard payload
    // and copy it. Empty groups are still listed (with "(0)") so the user sees
    // the structure. Inside each group, each line is "arabic — hebrew".
    // Optional `customToastBuilder(groups, totalCount)` returns a custom success
    // toast string; falls back to "✅ הועתקו N מילים מ<title>".
    function _copyGroupedWords(modeTitle, groups, customToastBuilder) {
        var totalCount = groups.reduce(function(s, g) { return s + (g.words ? g.words.length : 0); }, 0);
        if (totalCount === 0) {
            _showCopyBucketToast('אין מילים להעתקה (' + modeTitle + ')', false);
            return;
        }
        // Amitai 2026-05-10: include audit complex_error notes in any grouped copy.
        var auditState = {};
        try { auditState = (typeof currentCategory === 'string' && currentCategory && typeof _loadAuditState === 'function') ? _loadAuditState(currentCategory) : {}; } catch (_) {}
        var fmt = function(w) {
            var ar = (w && w.arabic) ? String(w.arabic) : '';
            var fm = (w && w.form) ? String(w.form) : '';
            var he = (w && w.hebrew) ? String(w.hebrew) : '';
            var line = ar + (fm ? ' ' + fm : '') + ' — ' + he;
            try {
                var k = (typeof _auditWordKey === 'function') ? _auditWordKey(w) : null;
                var entry = k ? auditState[k] : null;
                if (entry && entry.classification === 'complex_error' && entry.note) {
                    line += '   ⚠️ ' + entry.note;
                }
            } catch (_) {}
            return line;
        };
        var blocks = groups.map(function(g) {
            var words = g.words || [];
            var head = g.label + ' (' + words.length + ')';
            if (words.length === 0) return head + ':\n—';
            return head + ':\n' + words.map(fmt).join('\n');
        });
        var header = (typeof currentCategory === 'string' && currentCategory) ? (currentCategory + '\n\n') : '';
        var text = header + blocks.join('\n\n');
        var done = function(ok) {
            var msg;
            if (!ok) msg = '❌ העתקה נכשלה';
            else if (typeof customToastBuilder === 'function') {
                try { msg = customToastBuilder(groups, totalCount); }
                catch (_) { msg = '✅ הועתקו ' + totalCount + ' מילים מ"' + modeTitle + '"'; }
            }
            else msg = '✅ הועתקו ' + totalCount + ' מילים מ"' + modeTitle + '"';
            _showCopyBucketToast(msg, ok);
        };
        if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text).then(function() { done(true); }, function() { _legacyCopy(text, done); });
        } else {
            _legacyCopy(text, done);
        }
    }

    function _buildFlashcardGroups() {
        if (!currentCategory) return null;
        var all = getCategoryWords(currentCategory) || [];
        var keyOf = function(w) { return (w.arabic || '') + '|' + (w.hebrew || ''); };
        var inSet = function(arr) { var s = {}; (arr || []).forEach(function(w) { s[keyOf(w)] = true; }); return s; };
        var knownS = inSet(fcKnownWords);
        var unknownS = inSet(fcUnknownWords);
        var notSureS = inSet(fcNotSureWords);
        var unseen = [], known = [], unknownOrNotsure = [];
        all.forEach(function(w) {
            var k = keyOf(w);
            if (knownS[k]) known.push(w);
            else if (unknownS[k] || notSureS[k]) unknownOrNotsure.push(w);
            else unseen.push(w);
        });
        return [
            { label: '⬜ לא ראיתי', words: unseen },
            { label: '✓ ידעתי', words: known },
            { label: '✗ לא ידעתי / 😲 ממש לא ידעתי', words: unknownOrNotsure }
        ];
    }
    // Trivia tab long-press groups — LIFETIME stats, 3-bucket spec from
    // TODO #541 PHASE A. Differs from the trivia game-area long-press
    // (`_buildTriviaSessionGroups`) which uses session-only state.
    function _buildTriviaGroups() {
        if (!currentCategory) return null;
        var all = getCategoryWords(currentCategory) || [];
        var stats = _getTriviaStats();
        var unseen = [], known = [], dontknow = [];
        all.forEach(function(w) {
            var k = _wordKey(w);
            var s = stats[k];
            if (!s) { unseen.push(w); return; }
            if (_triviaIsWrong(s)) { dontknow.push(w); return; }
            // Correct (incl. notSure-flagged correct) — collapsed into "ידעתי"
            // per spec (3 buckets total). The game-area handler still surfaces
            // notSure separately for SESSION buckets.
            known.push(w);
        });
        return [
            { label: '⬜ לא ראיתי', words: unseen },
            { label: '✅ ידעתי', words: known },
            { label: '❌ לא ידעתי + ממש לא ידעתי', words: dontknow }
        ];
    }
    // Trivia game-area long-press groups — SESSION-only state
    // (`_triviaSessionState`). Independent of lifetime trivia stats.
    function _buildTriviaSessionGroups() {
        if (!currentCategory) return null;
        var all = getCategoryWords(currentCategory) || [];
        if (_triviaSessionState.category !== currentCategory) _loadTriviaSession(currentCategory);
        var ck = _triviaSessionState.correctKeys || {};
        var wk = _triviaSessionState.wrongKeys || {};
        var nk = _triviaSessionState.notSureKeys || {};
        var unseen = [], correct = [], wrong = [], notsure = [];
        all.forEach(function(w) {
            var k = _triviaSessionWordKey(w);
            if (wk[k]) { wrong.push(w); return; }
            if (nk[k]) { notsure.push(w); return; }
            if (ck[k]) { correct.push(w); return; }
            unseen.push(w);
        });
        return [
            { label: '⬜ לא ראיתי', words: unseen },
            { label: '✅ צדקתי', words: correct },
            { label: '❌ טעיתי', words: wrong },
            { label: '🤔 לא סגור', words: notsure }
        ];
    }
    function _buildListGroups() {
        if (!currentCategory) return null;
        var all = getCategoryWords(currentCategory) || [];
        var starred = getStarred();
        var starredW = [], rest = [];
        all.forEach(function(w) {
            var k = (w.arabic || '') + '|' + (w.hebrew || '');
            if (starred[k]) starredW.push(w);
            else rest.push(w);
        });
        return [
            { label: '★ מסומנים בכוכב', words: starredW },
            { label: '☆ כל השאר', words: rest }
        ];
    }

    // ============ AUDIT GAME (TODO #541 PHASE A part B) ============
    // Dev-only flashcard-style classification — gated to amitai.shalem@gmail.com
    // via _isAudioFeatureOwner. Iterates current category words; user flips
    // each card, picks one of 5 classifications + toggles 2 independent flags.
    // State persists in plonter_audit_<category> (matches plonter_*_<cat>
    // pattern; not under _VOCAB_ISOLATION_PREFIXES because audit data is
    // single-user-by-design — only Amitai sees the tab).
    var _AUDIT_CLASSES = [
        { id: 'correct',             label: 'נכון',              emoji: '✅', color: '#22c55e' },
        { id: 'missing_ribui',       label: 'חסר ריבוי',          emoji: '🔢', color: '#f59e0b' },
        { id: 'missing_object',      label: 'חסר מושא',          emoji: '🎯', color: '#a855f7' },
        { id: 'missing_future_uia',  label: 'חסר עהפ בעתיד',     emoji: '🔤', color: '#3b82f6' },
        { id: 'complex_error',       label: 'טעות מורכבת',        emoji: '⚠️', color: '#dc2626' }
    ];
    var _AUDIT_FLAGS = [
        { id: 'hez_in_toseft',  label: 'הצרכות לא בערך הראשי' },
        { id: 'binyan1_no_uia', label: 'פועל בנין 1 בלי עהפ U/I/A' }
    ];
    var _auditWords = [];
    var _auditIndex = 0;
    var _auditFlipped = false;
    // Local escape (escapeHtml lives in a later <script> block — different scope).
    function _auditEscape(s) {
        return String(s == null ? '' : s)
            .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }
    function _auditStorageKey(cat) { return 'plonter_audit_' + (cat || ''); }
    function _loadAuditState(cat) {
        try { return JSON.parse(localStorage.getItem(_auditStorageKey(cat)) || '{}'); }
        catch (_) { return {}; }
    }
    function _saveAuditState(cat, state) {
        try { localStorage.setItem(_auditStorageKey(cat), JSON.stringify(state)); } catch (_) {}
    }
    function _pruneOrphanAuditState(cat) {
        if (!cat) return {};
        var words = (typeof getCategoryWords === 'function') ? (getCategoryWords(cat) || []) : [];
        var validKeys = {};
        words.forEach(function(w) { validKeys[_auditWordKey(w)] = true; });
        var state = _loadAuditState(cat);
        var changed = false;
        Object.keys(state).forEach(function(k) {
            if (!validKeys[k]) { delete state[k]; changed = true; }
        });
        if (changed) _saveAuditState(cat, state);
        return state;
    }
    function _auditWordKey(w) { return (w && w.arabic ? w.arabic : '') + '|' + (w && w.hebrew ? w.hebrew : ''); }
    function startAuditGame() {
        if (!currentCategory) return;
        try { _pruneOrphanAuditState(currentCategory); } catch (_) {}
        // Filter out section-title entries (form==='כותרת') — they're dividers, not audit-able words. Amitai 2026-05-10.
        _auditWords = (getCategoryWords(currentCategory) || []).filter(function(w) { return !w || w.form !== 'כותרת'; });
        // Plonter task #27 (2026-04-29) — Amitai 17:50: jump straight to the
        // first UNCLASSIFIED word so the user doesn't have to manually scroll
        // past already-sorted cards on every entry. _findNextUnclassified
        // (added in task #16) accepts -1 to scan from the very beginning.
        // If everything is classified, fall back to index 0.
        _auditIndex = 0;
        try {
            var firstUnclass = _findNextUnclassified(-1);
            if (firstUnclass >= 0) _auditIndex = firstUnclass;
        } catch (_) {}
        _auditFlipped = false;
        try { _wireAuditHeaderLongPress(); } catch (_) {}
        renderAuditCard();
    }
    function auditNext(delta) {
        delta = (typeof delta === 'number') ? delta : 1;
        if (delta === 0) { _auditIndex = 0; }
        else if (delta > 0) { _auditIndex = Math.min(_auditWords.length, _auditIndex + delta); }
        else { _auditIndex = Math.max(0, _auditIndex + delta); }
        _auditFlipped = false;
        renderAuditCard();
    }
    // auditFlip kept as a no-op for backwards compatibility — the click-flip
    // behavior was removed in task #13 REVISED (2026-04-29). Both Arabic +
    // Hebrew now show together from the start, so there's nothing to flip.
    function auditFlip() {}
    // Jump directly to a specific word index (used by smart-nav buttons in
    // task #16). Reuses the same _auditFlipped reset + render path.
    function _auditJumpTo(idx) {
        if (typeof idx !== 'number' || idx < 0 || idx >= _auditWords.length) return;
        _auditIndex = idx;
        _auditFlipped = false;
        renderAuditCard();
    }
    // Smart-jump helpers (task #16 tweak 3). Both scan _auditWords against
    // the localStorage classification map. 'unclassified' = no entry OR
    // entry exists but has no .classification (flag-only entries count as
    // unclassified for navigation purposes).
    function _isAuditWordClassified(state, w) {
        var k = _auditWordKey(w);
        var e = state[k];
        return !!(e && e.classification);
    }
    function _findNextUnclassified(fromIdx) {
        if (!currentCategory) return -1;
        var state = _loadAuditState(currentCategory);
        for (var i = fromIdx + 1; i < _auditWords.length; i++) {
            if (!_isAuditWordClassified(state, _auditWords[i])) return i;
        }
        return -1;
    }
    function _findPrevUnclassified(fromIdx) {
        if (!currentCategory) return -1;
        var state = _loadAuditState(currentCategory);
        for (var i = fromIdx - 1; i >= 0; i--) {
            if (!_isAuditWordClassified(state, _auditWords[i])) return i;
        }
        return -1;
    }
    function auditClassify(classId) {
        if (!currentCategory) return;
        var w = _auditWords[_auditIndex];
        if (!w) return;
        var state = _loadAuditState(currentCategory);
        var k = _auditWordKey(w);
        var entry = state[k] || {};
        entry.classification = classId;
        entry.classifiedAt = Date.now();
        if (!entry.flags) entry.flags = {};
        state[k] = entry;
        _saveAuditState(currentCategory, state);
        // Amitai 2026-05-10: complex_error keeps card open so user can write a note before advancing.
        if (classId === 'complex_error') { renderAuditCard(); return; }
        auditNext(1);
    }
    function auditSaveNote(noteText) {
        if (!currentCategory) return;
        var w = _auditWords[_auditIndex];
        if (!w) return;
        var state = _loadAuditState(currentCategory);
        var k = _auditWordKey(w);
        var entry = state[k] || {};
        entry.note = String(noteText || '').trim();
        if (!entry.note) delete entry.note;
        state[k] = entry;
        _saveAuditState(currentCategory, state);
    }
    // Amitai 2026-05-10: debounced save-on-input for the audit complex_error note,
    // so notes persist even if the user taps Next/another classification before blur fires.
    var _auditNoteSaveTimer = null;
    function _auditNoteInputDebounced(noteText) {
        if (_auditNoteSaveTimer) clearTimeout(_auditNoteSaveTimer);
        _auditNoteSaveTimer = setTimeout(function() { auditSaveNote(noteText); }, 250);
    }
    function auditToggleFlag(flagId) {
        if (!currentCategory) return;
        var w = _auditWords[_auditIndex];
        if (!w) return;
        var state = _loadAuditState(currentCategory);
        var k = _auditWordKey(w);
        var entry = state[k] || { flags: {} };
        if (!entry.flags) entry.flags = {};
        entry.flags[flagId] = !entry.flags[flagId];
        state[k] = entry;
        _saveAuditState(currentCategory, state);
        renderAuditCard();
    }
    function renderAuditCard() {
        var content = document.getElementById('audit-card-content');
        var actions = document.getElementById('audit-actions');
        var empty = document.getElementById('audit-empty');
        var card = document.getElementById('audit-card');
        var prog = document.getElementById('audit-progress');
        if (!content) return;
        var totalW = _auditWords.length;
        if (!totalW || _auditIndex >= totalW) {
            if (empty) empty.style.display = '';
            if (card) card.style.display = 'none';
            if (actions) actions.style.display = 'none';
            if (prog) prog.textContent = totalW ? ('סיימת ' + totalW + '/' + totalW) : 'אין מילים';
            try { _renderAuditBins(); } catch (_) {}
            return;
        }
        if (empty) empty.style.display = 'none';
        if (card) card.style.display = '';
        var w = _auditWords[_auditIndex];
        try { _pruneOrphanAuditState(currentCategory); } catch (_) {}
        var state = _loadAuditState(currentCategory);
        var k = _auditWordKey(w);
        var entry = state[k] || {};
        // Tally classified count for header
        var classifiedCount = 0;
        Object.keys(state).forEach(function(kk) { if (state[kk] && state[kk].classification) classifiedCount++; });
        if (prog) {
            prog.textContent = (_auditIndex + 1) + ' / ' + totalW + ' · סיווגו ' + classifiedCount + (entry.classification ? ' · ✓ סיווג קיים' : '');
        }
        // Plonter task #13 REVISED (2026-04-29) — Amitai: remove the flip
        // entirely. Show Arabic + Hebrew + form together from the start; the
        // classification buttons are always visible; auditClassify still
        // auto-advances. _auditFlipped is no longer toggled (auditFlip is now
        // a no-op that survives only for backwards compatibility with the
        // onclick="auditFlip()" attribute on #audit-card).
        {
            // Plonter task #26 (2026-04-29) — Amitai 17:35: enlarge audit
            // fonts further. Bumped clamp() values from #16's (28/18/22 →
            // 7/4.5/5.5vw → 44/26/32) up to (40/24/30 → 10/6/7.5vw → 64/36/44).
            content.innerHTML = '<div class="arabic-text" style="font-size:clamp(40px,10vw,64px);line-height:1.3;color:#0d9488">' + _auditEscape(w.arabic || '') + '</div>' +
                (w.form ? '<div style="font-size:clamp(24px,6vw,36px);line-height:1.3;color:#64748b">' + _auditEscape(w.form) + '</div>' : '') +
                '<div style="font-size:clamp(30px,7.5vw,44px);line-height:1.3;font-weight:700;color:#1e293b">' + _auditEscape(w.hebrew || '') + '</div>';
            if (actions) {
                var html = '<div style="display:flex;flex-direction:column;gap:8px">';
                html += '<div style="display:flex;flex-wrap:wrap;gap:6px;justify-content:center">';
                _AUDIT_CLASSES.forEach(function(c) {
                    var sel = (entry.classification === c.id);
                    html += '<button onclick="auditClassify(\'' + c.id + '\')" style="padding:10px 14px;border-radius:10px;border:2px solid ' + c.color + ';background:' + (sel ? c.color : 'white') + ';color:' + (sel ? 'white' : c.color) + ';font-weight:600;cursor:pointer;font-size:0.9em">' + c.emoji + ' ' + c.label + '</button>';
                });
                html += '</div>';
                // Amitai 2026-05-10: complex_error gets a free-text note field that's exported alongside the word.
                if (entry.classification === 'complex_error') {
                    html += '<div style="display:flex;flex-direction:column;gap:4px;margin-top:6px;padding:8px 10px;border:1.5px solid #dc2626;border-radius:10px;background:#fef2f2">' +
                            '<label style="font-size:0.82em;color:#991b1b;font-weight:600;direction:rtl">תיאור הטעות (יישמר ויועתק עם המילה):</label>' +
                            '<textarea id="audit-note-input" oninput="_auditNoteInputDebounced(this.value)" onblur="auditSaveNote(this.value)" placeholder="פרט מה הטעות..." dir="rtl" style="width:100%;padding:8px 10px;border:1.5px solid #fca5a5;border-radius:8px;font-size:0.95em;font-family:inherit;box-sizing:border-box;resize:vertical;min-height:54px">' + _auditEscape(entry.note || '') + '</textarea>' +
                          '</div>';
                }
                html += '<div style="display:flex;flex-wrap:wrap;gap:6px;justify-content:center;margin-top:6px;border-top:1px dashed #e5e7eb;padding-top:8px">';
                _AUDIT_FLAGS.forEach(function(f) {
                    var on = !!(entry.flags && entry.flags[f.id]);
                    html += '<button onclick="auditToggleFlag(\'' + f.id + '\')" style="padding:8px 12px;border-radius:10px;border:1.5px ' + (on ? 'solid' : 'dashed') + ' #f59e0b;background:' + (on ? '#fef3c7' : 'white') + ';color:#92400e;font-weight:500;cursor:pointer;font-size:0.85em">' + (on ? '🚩 ' : '⚐ ') + f.label + '</button>';
                });
                html += '</div>';
                // Amitai 2026-05-10: prev/next inline at the bottom of #audit-actions, which is itself position:fixed.
                html += '<div style="display:flex;justify-content:space-between;margin-top:10px">';
                html += '<button onclick="auditNext(-1)" ' + (_auditIndex === 0 ? 'disabled' : '') + ' style="padding:8px 16px;border-radius:8px;border:1px solid #0d9488;background:white;color:#0d9488;font-weight:600;cursor:pointer">→ קודם</button>';
                html += '<button onclick="auditNext(1)" style="padding:8px 16px;border-radius:8px;border:none;background:#0d9488;color:white;font-weight:700;cursor:pointer">הבא ←</button>';
                html += '</div>';
                // Plonter task #16 tweak 3 — smart-jump nav. Shows secondary
                // shortcut buttons only when they have somewhere useful to go:
                //   • forward: if the immediate next card is already classified
                //     AND there's a later unclassified card → jump shortcut.
                //   • backward: if any earlier card is unclassified → "you
                //     forgot one" shortcut.
                var smartHtml = '';
                var nextUnclassIdx = _findNextUnclassified(_auditIndex);
                if (nextUnclassIdx !== -1 && nextUnclassIdx !== _auditIndex + 1) {
                    smartHtml += '<button onclick="_auditJumpTo(' + nextUnclassIdx + ')" style="padding:5px 10px;border-radius:6px;border:none;background:#64748b;color:white;font-weight:500;cursor:pointer;font-size:0.8em">⏭️ דלג ללא-מסווג הבא (#' + (nextUnclassIdx + 1) + ')</button>';
                }
                var prevUnclassIdx = _findPrevUnclassified(_auditIndex);
                if (prevUnclassIdx !== -1) {
                    smartHtml += '<button onclick="_auditJumpTo(' + prevUnclassIdx + ')" style="padding:5px 10px;border-radius:6px;border:none;background:#64748b;color:white;font-weight:500;cursor:pointer;font-size:0.8em">↩️ שכחת קלף לא מסווג — חזור (#' + (prevUnclassIdx + 1) + ')</button>';
                }
                if (smartHtml) {
                    html += '<div style="display:flex;flex-wrap:wrap;gap:6px;justify-content:center;margin-top:6px">' + smartHtml + '</div>';
                }
                html += '</div>';
                actions.innerHTML = html;
                actions.style.display = '';
                // Amitai 2026-05-10: actions is position:fixed at bottom, so reserve matching padding-bottom on the mode container.
                try {
                    var modeEl = document.getElementById('audit-mode');
                    if (modeEl) {
                        setTimeout(function() {
                            modeEl.style.paddingBottom = (actions.offsetHeight + 20) + 'px';
                        }, 0);
                    }
                } catch (_) {}
            }
        }
        // Plonter task #14: bins reflect every state change. renderAuditCard
        // is called by startAuditGame / auditNext / auditClassify / auditToggleFlag,
        // so a single call here covers every classify / flag-toggle path.
        try { _renderAuditBins(); } catch (_) {}
    }
    // Long-press export builder — groups by 5 classifications + an "unclassified"
    // bucket + 2 flag buckets. Words can appear in BOTH a classification bucket
    // and a flag bucket (flags are independent of classification).
    function _buildAuditGroups() {
        if (!currentCategory) return null;
        // Amitai 2026-05-10: filter section-divider rows (form==='כותרת') so they don't pollute the export's "unclassified" bucket.
        // Mirrors startAuditGame which already excludes them from _auditWords.
        var all = (getCategoryWords(currentCategory) || []).filter(function(w) { return !w || w.form !== 'כותרת'; });
        var state = _loadAuditState(currentCategory);
        var byClass = {};
        _AUDIT_CLASSES.forEach(function(c) { byClass[c.id] = []; });
        var unclassified = [];
        var byFlag = {};
        _AUDIT_FLAGS.forEach(function(f) { byFlag[f.id] = []; });
        all.forEach(function(w) {
            var k = _auditWordKey(w);
            var entry = state[k];
            if (!entry || !entry.classification) { unclassified.push(w); }
            else if (byClass[entry.classification]) { byClass[entry.classification].push(w); }
            else { unclassified.push(w); }
            if (entry && entry.flags) {
                _AUDIT_FLAGS.forEach(function(f) { if (entry.flags[f.id]) byFlag[f.id].push(w); });
            }
        });
        var groups = [{ label: '⬜ לא מסווג', words: unclassified }];
        _AUDIT_CLASSES.forEach(function(c) { groups.push({ label: c.emoji + ' ' + c.label, words: byClass[c.id] }); });
        _AUDIT_FLAGS.forEach(function(f) { groups.push({ label: '🚩 ' + f.label, words: byFlag[f.id] }); });
        return groups;
    }

    // ============ AUDIT BINS — Plonter task #14 (2026-04-29) ============
    // Storage-bin pills below the active card so the admin can drill into
    // already-classified words and re-sort them. Mirrors the כרטיסיות
    // (flashcards) bin-sort UX (fcMoveWord pattern from line ~6103).
    function _classById(id) { for (var i = 0; i < _AUDIT_CLASSES.length; i++) if (_AUDIT_CLASSES[i].id === id) return _AUDIT_CLASSES[i]; return null; }
    function _flagById(id)  { for (var i = 0; i < _AUDIT_FLAGS.length;  i++) if (_AUDIT_FLAGS[i].id  === id) return _AUDIT_FLAGS[i];  return null; }
    function _renderAuditBins() {
        var el = document.getElementById('audit-bins');
        if (!el) return;
        if (!currentCategory) { el.innerHTML = ''; return; }
        try { _pruneOrphanAuditState(currentCategory); } catch (_) {}
        var state;
        try { state = _loadAuditState(currentCategory); } catch (_) { el.innerHTML = '<div style="color:#dc2626;font-size:0.8em;text-align:center">נתוני סיווג פגומים</div>'; return; }
        var classCounts = {}, flagCounts = {};
        _AUDIT_CLASSES.forEach(function(c) { classCounts[c.id] = 0; });
        _AUDIT_FLAGS.forEach(function(f) { flagCounts[f.id] = 0; });
        Object.keys(state).forEach(function(k) {
            var entry = state[k];
            if (!entry) return;
            if (entry.classification && classCounts.hasOwnProperty(entry.classification)) classCounts[entry.classification]++;
            if (entry.flags) _AUDIT_FLAGS.forEach(function(f) { if (entry.flags[f.id]) flagCounts[f.id]++; });
        });
        var anyNonEmpty = false;
        var pills = '';
        _AUDIT_CLASSES.forEach(function(c) {
            if (classCounts[c.id] > 0) {
                anyNonEmpty = true;
                pills += '<button onclick="_openAuditBinModal(\'class\',\'' + c.id + '\')" style="padding:6px 12px;border-radius:14px;border:1.5px solid ' + c.color + ';background:white;color:' + c.color + ';cursor:pointer;font-weight:600;font-size:0.85em">' + c.emoji + ' ' + c.label + ' (' + classCounts[c.id] + ')</button>';
            }
        });
        _AUDIT_FLAGS.forEach(function(f) {
            if (flagCounts[f.id] > 0) {
                anyNonEmpty = true;
                pills += '<button onclick="_openAuditBinModal(\'flag\',\'' + f.id + '\')" style="padding:6px 12px;border-radius:14px;border:1.5px solid #f59e0b;background:#fef3c7;color:#92400e;cursor:pointer;font-weight:500;font-size:0.85em">🚩 ' + _auditEscape(f.label) + ' (' + flagCounts[f.id] + ')</button>';
            }
        });
        if (!anyNonEmpty) {
            el.innerHTML = '<div style="text-align:center;color:#9ca3af;font-size:0.82em;padding:8px;border-top:1px dashed #e5e7eb;margin-top:8px">אין סיווגים עדיין</div>';
            return;
        }
        el.innerHTML = '<div style="border-top:1px dashed #e5e7eb;padding-top:10px">' +
            '<div style="font-size:0.85em;color:#6b7280;margin-bottom:6px;font-weight:600">🗃️ מחסנים — לחיצה לעיון</div>' +
            '<div style="display:flex;flex-wrap:wrap;gap:6px">' + pills + '</div></div>';
    }
    function _openAuditBinModal(kind, binId) {
        if (!currentCategory) return;
        try { _pruneOrphanAuditState(currentCategory); } catch (_) {}
        var state = _loadAuditState(currentCategory);
        var bin = (kind === 'class') ? _classById(binId) : _flagById(binId);
        if (!bin) return;
        var binLabel = (kind === 'class') ? (bin.emoji + ' ' + bin.label) : ('🚩 ' + bin.label);
        // Collect keys in this bin
        var keys = Object.keys(state).filter(function(k) {
            var e = state[k];
            if (!e) return false;
            return (kind === 'class') ? (e.classification === binId) : (e.flags && e.flags[binId]);
        });
        // Map keys → word objects from the current category's word list
        var allWords = (typeof getCategoryWords === 'function') ? (getCategoryWords(currentCategory) || []) : [];
        var byKey = {};
        allWords.forEach(function(w) { byKey[(w.arabic || '') + '|' + (w.hebrew || '')] = w; });
        var rows = keys.map(function(k) {
            var w = byKey[k];
            if (!w) { var p = k.split('|'); w = { arabic: p[0] || '', hebrew: p[1] || '' }; }
            return { key: k, word: w };
        });
        var existing = document.getElementById('audit-bin-modal');
        if (existing) existing.remove();
        var overlay = document.createElement('div');
        overlay.id = 'audit-bin-modal';
        overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.55);z-index:9000;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(3px)';
        overlay.onclick = function(e) { if (e.target === overlay) overlay.remove(); };
        overlay._binKind = kind;
        overlay._binId = binId;
        var dlg = document.createElement('div');
        dlg.style.cssText = 'background:white;border-radius:14px;padding:18px;max-width:560px;width:96%;max-height:80vh;overflow-y:auto;direction:rtl;text-align:right;box-shadow:0 14px 38px rgba(0,0,0,0.3)';
        // Build rows with data-* attributes; bind click handlers after
        // innerHTML so the word-key (which can contain Arabic / Hebrew
        // / quotes) doesn't have to be HTML-attribute + JS-string escaped.
        var rowsHtml = '';
        if (!rows.length) {
            rowsHtml = '<div style="text-align:center;color:#9ca3af;padding:20px">המחסן ריק</div>';
        } else {
            rowsHtml = rows.map(function(r, idx) {
                var w = r.word;
                var moveBtns = '';
                if (kind === 'class') {
                    _AUDIT_CLASSES.forEach(function(c) {
                        if (c.id === binId) return;
                        moveBtns += '<button data-row-idx="' + idx + '" data-act="reclassify" data-target="' + c.id + '" title="העבר ל-' + _auditEscape(c.label) + '" style="padding:3px 8px;border-radius:6px;border:1px solid ' + c.color + ';background:white;color:' + c.color + ';font-size:0.78em;cursor:pointer">→ ' + c.emoji + '</button>';
                    });
                    moveBtns += '<button data-row-idx="' + idx + '" data-act="unclassify" title="הסר סיווג" style="padding:3px 8px;border-radius:6px;border:1px solid #9ca3af;background:#f3f4f6;color:#374151;font-size:0.78em;cursor:pointer">❌ הסר</button>';
                } else {
                    moveBtns = '<button data-row-idx="' + idx + '" data-act="clearflag" data-target="' + binId + '" title="הסר דגל" style="padding:3px 8px;border-radius:6px;border:1px solid #9ca3af;background:#f3f4f6;color:#374151;font-size:0.78em;cursor:pointer">❌ הסר דגל</button>';
                }
                moveBtns += '<button data-row-idx="' + idx + '" data-act="jump" title="עבור ללקסמה" style="padding:3px 8px;border-radius:6px;border:1px solid #0d9488;background:#0d9488;color:white;font-size:0.78em;cursor:pointer">→ עבור</button>';
                return '<div data-row-idx="' + idx + '" style="display:flex;justify-content:space-between;align-items:center;gap:8px;padding:8px;border:1px solid #e5e7eb;border-radius:8px;margin-bottom:6px">' +
                    '<div style="flex:1;min-width:0">' +
                        '<div class="arabic-text" style="font-size:1.2em;font-weight:600;color:#0d9488">' + _auditEscape(w.arabic || '') + '</div>' +
                        (w.form ? '<div style="font-size:0.85em;color:#64748b">' + _auditEscape(w.form) + '</div>' : '') +
                        '<div style="font-size:0.95em;color:#475569">' + _auditEscape(w.hebrew || '') + '</div>' +
                    '</div>' +
                    '<div style="display:flex;flex-wrap:wrap;gap:4px;justify-content:flex-end;max-width:60%">' + moveBtns + '</div>' +
                '</div>';
            }).join('');
        }
        dlg.innerHTML = '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">' +
            '<h3 style="margin:0;color:#0d9488;font-size:1.1em">מחסן: ' + _auditEscape(binLabel) + ' (' + rows.length + ')</h3>' +
            '<button id="_audit-bin-modal-close" style="padding:5px 12px;background:#e5e7eb;border:none;border-radius:7px;cursor:pointer">סגור</button>' +
            '</div>' + rowsHtml;
        overlay.appendChild(dlg);
        document.body.appendChild(overlay);
        // Close button + per-row action buttons — programmatic binding so we
        // can pass the raw key (which may contain quotes / unicode) without
        // attribute-encoding hell.
        var closeBtn = dlg.querySelector('#_audit-bin-modal-close');
        if (closeBtn) closeBtn.onclick = function() { overlay.remove(); };
        dlg.querySelectorAll('button[data-act]').forEach(function(btn) {
            btn.onclick = function() {
                var idx = parseInt(btn.getAttribute('data-row-idx'), 10);
                var row = rows[idx];
                if (!row) return;
                var act = btn.getAttribute('data-act');
                if (act === 'reclassify') _auditReclassify(row.key, btn.getAttribute('data-target'));
                else if (act === 'unclassify') _auditUnclassify(row.key);
                else if (act === 'clearflag') _auditClearFlagFromModal(row.key, btn.getAttribute('data-target'));
                else if (act === 'jump') {
                    var jumpIdx = -1;
                    if (Array.isArray(_auditWords)) {
                        for (var jj = 0; jj < _auditWords.length; jj++) {
                            if (_auditWordKey(_auditWords[jj]) === row.key) { jumpIdx = jj; break; }
                        }
                    }
                    if (jumpIdx >= 0) {
                        overlay.remove();
                        try { _auditJumpTo(jumpIdx); } catch (_) {}
                    }
                }
            };
        });
    }
    function _refreshAuditBinModal() {
        var overlay = document.getElementById('audit-bin-modal');
        if (!overlay) return;
        _openAuditBinModal(overlay._binKind, overlay._binId);
    }
    function _auditReclassify(wkey, newClassId) {
        if (!currentCategory) return;
        var state = _loadAuditState(currentCategory);
        if (!state[wkey]) state[wkey] = { flags: {} };
        state[wkey].classification = newClassId;
        state[wkey].classifiedAt = Date.now();
        if (!state[wkey].flags) state[wkey].flags = {};
        _saveAuditState(currentCategory, state);
        _renderAuditBins();
        _refreshAuditBinModal();
        renderAuditCard();
    }
    function _auditUnclassify(wkey) {
        if (!currentCategory) return;
        var state = _loadAuditState(currentCategory);
        if (state[wkey]) {
            delete state[wkey].classification;
            delete state[wkey].classifiedAt;
            var anyFlag = state[wkey].flags && Object.keys(state[wkey].flags).some(function(k) { return state[wkey].flags[k]; });
            if (!anyFlag) delete state[wkey];
        }
        _saveAuditState(currentCategory, state);
        _renderAuditBins();
        _refreshAuditBinModal();
        renderAuditCard();
    }
    function _auditClearFlagFromModal(wkey, flagId) {
        if (!currentCategory) return;
        var state = _loadAuditState(currentCategory);
        if (state[wkey] && state[wkey].flags) {
            state[wkey].flags[flagId] = false;
            var anyFlag = Object.keys(state[wkey].flags).some(function(k) { return state[wkey].flags[k]; });
            if (!anyFlag && !state[wkey].classification) delete state[wkey];
        }
        _saveAuditState(currentCategory, state);
        _renderAuditBins();
        _refreshAuditBinModal();
        renderAuditCard();
    }

    // Shared export-to-clipboard for audit classifications. Used by BOTH
    // the long-press on #audit-header (power-user shortcut) AND the visible
    // 📋 button on the right of #audit-header (added in task #29 — Amitai
    // 17:55: discoverable copy button so the gesture isn't hidden UX).
    function copyAuditExport() {
        var groups = _buildAuditGroups();
        if (!groups) {
            _showCopyBucketToast('לא נטענה קטגוריה', false);
            return;
        }
        _copyGroupedWords('בקרה', groups, function(gs) {
            var classified = gs.slice(1, 1 + _AUDIT_CLASSES.length).reduce(function(s, g) { return s + g.words.length; }, 0);
            var unclassified = gs[0].words.length;
            var flagsOn = gs.slice(1 + _AUDIT_CLASSES.length).reduce(function(s, g) { return s + g.words.length; }, 0);
            return 'הועתק — ' + classified + ' מסווגים, ' + unclassified + ' לא מסווגים, ' + flagsOn + ' דגלים';
        });
    }
    function _wireAuditHeaderLongPress() {
        var hdr = document.getElementById('audit-header');
        if (!hdr) return;
        _attachLongPress(hdr, function() { copyAuditExport(); });
    }

    function _wireModeTabsLongPress() {
        var tabs = document.getElementById('mode-tabs');
        if (!tabs) return;
        var _gcount = function(gs, i) { return (gs[i] && gs[i].words) ? gs[i].words.length : 0; };
        var bindings = {
            flashcards: { title: 'כרטיסיות', build: _buildFlashcardGroups },
            trivia: {
                title: 'טריוויה',
                build: _buildTriviaGroups,
                toast: function(gs) {
                    return 'הועתק — ' + _gcount(gs, 0) + ' לא ראיתי, ' +
                        _gcount(gs, 1) + ' ידעתי, ' + _gcount(gs, 2) + ' לא ידעתי';
                }
            },
            list: {
                title: 'רשימה',
                build: _buildListGroups,
                toast: function(gs) {
                    return 'הועתק — ' + _gcount(gs, 0) + ' מסומנים בכוכב, ' +
