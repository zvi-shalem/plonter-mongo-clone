    // ============ LEADING-SILENCE TRIM (Amitai 2026-04-24 10:26) ============
    // Recordings often have ~0.5-1.5s of silence before speech begins. Decode
    // the blob via AudioContext, find the first sample exceeding a small RMS
    // threshold, and start playback from there (minus a 50ms lead-in buffer).
    // Cached per audio id — decoding is not free.
    var _silenceCache = {}; // id -> { offsetSec, blobUrl }
    var _sharedAudioCtx = null;
    function _audioCtx() {
        if (!_sharedAudioCtx) {
            var C = window.AudioContext || window.webkitAudioContext;
            if (!C) return null;
            _sharedAudioCtx = new C();
        }
        return _sharedAudioCtx;
    }
    function _findSpeechStart(audioBuffer) {
        // Scan the loudest channel in 10ms windows, compute peak, flag first
        // window above threshold as start. Threshold chosen to clear typical
        // mic/room noise floor (~−40 dBFS → 0.01 linear).
        var THRESH = 0.02;
        var LEAD_MS = 50;
        var sr = audioBuffer.sampleRate;
        var winSize = Math.max(1, Math.floor(sr * 0.01));
        var ch0 = audioBuffer.getChannelData(0);
        var len = ch0.length;
        for (var i = 0; i + winSize <= len; i += winSize) {
            var peak = 0;
            for (var j = 0; j < winSize; j++) {
                var v = Math.abs(ch0[i + j]);
                if (v > peak) peak = v;
            }
            if (peak >= THRESH) {
                var sec = i / sr - LEAD_MS / 1000;
                return Math.max(0, sec);
            }
        }
        return 0; // all silent / very quiet — play from start
    }
    function _prepareTrimmedAudio(id, url, onReady) {
        // onReady({ blobUrl, offsetSec }). Fires-fast on cache hit; otherwise
        // fetches + decodes + caches. On any error falls back to { blobUrl: url, offsetSec: 0 }.
        if (_silenceCache[id]) { onReady(_silenceCache[id]); return; }
        var ctx = _audioCtx();
        if (!ctx) { onReady({ blobUrl: url, offsetSec: 0 }); return; }
        fetch(url).then(function(r) { return r.blob(); }).then(function(blob) {
            var blobUrl = URL.createObjectURL(blob);
            blob.arrayBuffer().then(function(ab) {
                ctx.decodeAudioData(ab.slice(0), function(buffer) {
                    var off = _findSpeechStart(buffer);
                    _silenceCache[id] = { blobUrl: blobUrl, offsetSec: off };
                    onReady(_silenceCache[id]);
                }, function(e) {
                    console.warn('[silence-trim] decode failed', e);
                    _silenceCache[id] = { blobUrl: blobUrl, offsetSec: 0 };
                    onReady(_silenceCache[id]);
                });
            });
        }).catch(function(e) {
            console.warn('[silence-trim] fetch failed', e);
            onReady({ blobUrl: url, offsetSec: 0 });
        });
    }

    // Fire-and-forget playback of the saved recording for a (catName, wordKey)
    // pair. Used by trivia/flashcard transitions when audio-autoplay is ON.
    var _gameAudioEl = null;
    // Optional `lang` ('ar'|'he') picks the recording matching the visible
    // side of the flashcard. Omit for legacy callers (they get first-by-recency).
    function _playWordRecording(catName, wordKey, lang) {
        var id = _audioFirstIdForWord(catName, wordKey, lang);
        if (!id) return false;
        try { if (_gameAudioEl) { _gameAudioEl.pause(); } } catch (_) {}
        // Public read since 2026-04-26 — guests stream by id, no token needed.
        var url = '/plonter/api/vocab_audio_api.php?action=get&id=' + encodeURIComponent(id);
        _prepareTrimmedAudio(id, url, function(prep) {
            _gameAudioEl = new Audio(prep.blobUrl);
            _gameAudioEl.preload = 'auto';
            _gameAudioEl.addEventListener('loadedmetadata', function() {
                try { _gameAudioEl.currentTime = prep.offsetSec; } catch (_) {}
                _gameAudioEl.play().catch(function(e) { console.warn('[audio autoplay] blocked', e); });
            });
        });
        return true;
    }

