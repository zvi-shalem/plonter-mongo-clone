        document.getElementById('conj-next').style.display = 'none';
        renderStreakBar('conj-streak-bar', conjStreak, conjBestStreak);
        document.getElementById('conj-score').textContent = conjTotal > 0 ? conjCorrect + ' / ' + conjTotal + ' נכון' : '';
    }
