    // ============ TRANSLITERATION ============
    // HEBREW_TO_ARABIC + GERESH_MAP are the canonical maps declared once in
    // js/detailsPanel.js (loaded below). The previous inline `var` duplicates
    // here collided with those `const` declarations ("Identifier
    // 'HEBREW_TO_ARABIC' has already been declared" pageerror, which aborted
    // detailsPanel.js → DetailsPanel undefined) AND had a broken 'ט':'ט'
    // mapping. Removed so the single canonical map (with correct 'ט':'ط') is
    // used everywhere. transliterate() reads these globals at call time, well
    // after detailsPanel.js has executed. (E6, 2026-05-27)

    function transliterate(text) {
        var result = '';
        for (var i = 0; i < text.length; i++) {
            var ch = text[i];
            var next = text[i + 1];
            var next2 = text[i + 2];
            // Double-geresh on yod: י'' → ى (alif maqsura) — Amitai 2026-04-30
            if (ch === 'י' && next === "'" && next2 === "'") { result += 'ى'; i += 2; continue; }
            // Geresh after hamza-on-ya: ئ' → ى — Amitai 2026-04-30
            if (ch === 'ئ' && next === "'") { result += 'ى'; i++; continue; }
            // Legacy escape: א% → ئ
            if (ch === 'א' && next === '%') { result += 'ئ'; i++; continue; }
            // Single geresh after Hebrew letter (י' → ئ, ח' → خ, …)
            if (next === "'" && GERESH_MAP[ch]) { result += GERESH_MAP[ch]; i++; continue; }
            result += HEBREW_TO_ARABIC[ch] || ch;
        }
        return result;
    }

