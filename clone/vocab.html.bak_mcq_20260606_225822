                if (_ea && _ea.value && _ea.value.trim()) return _ea.value.trim();
            }
        } catch (_) {}
        if (currentMode === 'flashcards') {
            // Read from the data model (not the DOM) so we always get the
            // Arabic word even when the direction is he2ar and the DOM shows
            // Hebrew on the front. Amitai 2026-04-14.
            var fcWords = shuffledWords.length ? shuffledWords : getCategoryWords(currentCategory);
            return (fcWords[cardIndex] && fcWords[cardIndex].arabic) ? fcWords[cardIndex].arabic : '';
        } else if (currentMode === 'trivia') {
            var words = shuffledWords.length ? shuffledWords : getCategoryWords(currentCategory);
            return (words[cardIndex] && words[cardIndex].arabic) ? words[cardIndex].arabic : '';
        } else if (currentMode === 'audit') {
