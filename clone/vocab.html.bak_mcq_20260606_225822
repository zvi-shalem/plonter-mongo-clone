        var warehouseWrap = document.getElementById('grp-share-warehouse-wrap');
        if (!bannerEl || !warehouseEl) return;
        warehouseEl.innerHTML = '<div style="color:#6b7280;text-align:center;padding:8px">טוען...</div>';
        bannerEl.style.display = 'none';
        if (warehouseWrap) warehouseWrap.style.display = '';

        var token = _vocabAuthToken();
        if (!token) { warehouseEl.innerHTML = '<div style="color:#dc2626;text-align:center;padding:8px">לא מחובר</div>'; return; }
        fetch('/plonter/api/vocab_share_api.php?action=list_group_tokens', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
            body:    JSON.stringify({ group_name: label })
        }).then(function(r) { return r.json(); }).then(function(j) {
            if (!j.success) {
                warehouseEl.innerHTML = '<div style="color:#dc2626;text-align:center;padding:8px">' + _grpEsc(j.error || 'שגיאה') + '</div>';
                return;
            }
            var items = (j.items || []).slice();
            var active = items.filter(function(t) { return !t.revoked && !t.expired; });
            var topToken = null;

            // Banner: surface the freshest active token at the top.
            if (active.length > 0) {
