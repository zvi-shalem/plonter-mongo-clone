<body>
    <!-- Login modal mount — hidden unless the user clicks התחבר in #auth-status. -->
    <div id="auth-container" style="position:fixed;inset:0;z-index:100002;display:none;align-items:center;justify-content:center;background:rgba(15,23,42,0.55);backdrop-filter:blur(4px)"></div>

    <div class="header">
        <a href="index.html" target="_top" id="back-link" class="back-link-prominent">← חזרה לפלונטר</a>
        <button id="vocab-home-btn" type="button" class="back-link-prominent" style="display:none" title="חזרה לעמוד הראשי">🏠</button>
        <div class="header-title-row" style="display:flex;align-items:center;gap:10px;width:100%;justify-content:flex-start">
            <img src="plonter-logo.png?v=10" alt="Plonter logo" width="44" height="44" style="flex-shrink:0;filter:drop-shadow(0 2px 6px rgba(0,0,0,0.2))">
            <h1>לימוד מילים</h1>
            <span class="vocab-credit">© אמתי שלם</span>
        </div>
        <div class="header-controls-row" style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;width:100%;justify-content:center">
            <div id="auth-status" style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;flex-shrink:1;min-width:0"></div>
            <div id="vocab-current-actions" style="display:none;align-items:center;gap:5px;flex-wrap:nowrap;justify-content:center;max-width:100%;overflow-x:auto"></div>
            <button id="shared-with-me-btn" onclick="if(window.ContentShare)ContentShare.openSharedWithMe()" title="ששותף איתי" style="background:rgba(255,255,255,0.12);border:1.5px solid rgba(255,255,255,0.35);border-radius:9px;color:white;font-size:1.1em;cursor:pointer;padding:4px 9px;opacity:1;flex-shrink:0;line-height:1">🤝</button>
            <button id="theme-toggle" onclick="toggleTheme()" style="background:rgba(255,255,255,0.12);border:1.5px solid rgba(255,255,255,0.35);border-radius:9px;color:white;font-size:1.1em;cursor:pointer;padding:4px 9px;opacity:1;flex-shrink:0;line-height:1">🌙</button>
            <button id="tts-autoplay-toggle" onclick="_toggleTtsAutoplay()" title="השמעה אוטומטית של הקלטות" aria-pressed="true" style="background:rgba(255,255,255,0.12);border:1.5px solid rgba(255,255,255,0.35);border-radius:9px;color:white;font-size:1.1em;cursor:pointer;padding:4px 9px;opacity:1;flex-shrink:0;line-height:1">🔊</button>
        </div>
    </div>

    <!-- LANDING PAGE -->
    <div id="landing-page" class="landing">
        <div id="vocab-warn-banner" style="background:linear-gradient(135deg,#fef3c7,#fde68a);border:2px solid #f59e0b;border-radius:12px;padding:12px 16px;margin-bottom:16px;text-align:center;font-size:1.05em;color:#92400e;font-weight:600;line-height:1.6">
            ⚠️ חניך יקר! מחשב זה נהדר! אך שים לב - טקסט נכנס לראש כשהוא נכתב על הנייר...
        </div>
        <div id="vocab-section-header" style="display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:8px">
            <h2 class="section-title" style="margin:0">בחר קטגוריה</h2>
            <button id="vocab-backup-all-btn" onclick="vocabSyncAllFromBtn()" title="גבה את כל הקטגוריות וההתקדמות לענן" style="padding:7px 14px;border:2px solid #0d9488;background:white;color:#0d9488;border-radius:10px;cursor:pointer;font-weight:bold;font-size:0.9em;white-space:nowrap">💾 גבה הכל</button>
        </div>
        <div id="public-vocab-home" style="border:2px solid #0d9488;background:#f0fdfa;border-radius:12px;padding:12px 14px;margin-bottom:16px">
            <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:8px">
                <div style="font-weight:800;color:#0f766e;font-size:1.05em">קטגוריות משותפות</div>
                <button onclick="_publicLoadMyShared()" style="padding:5px 10px;border:1.5px solid #0d9488;background:white;color:#0d9488;border-radius:8px;cursor:pointer;font-weight:700;font-size:0.85em">מה שפתחתי</button>
            </div>
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
                <input type="text" id="public-vocab-search" placeholder="חפש לפי שם יוצר או שם קטגוריה" onkeydown="if(event.key==='Enter')_publicSearch()" style="flex:1;min-width:180px;padding:8px 10px;border:2px solid #99f6e4;border-radius:9px;font-size:0.95em;box-sizing:border-box">
                <button onclick="_publicSearch()" style="padding:8px 14px;border:none;background:#0d9488;color:white;border-radius:9px;cursor:pointer;font-weight:800">חפש</button>
            </div>
            <div id="public-vocab-results" style="margin-top:10px;display:none"></div>
        </div>
        <div class="cat-grid" id="cat-grid"></div>

        <!-- Intermediate group page (B.1 / 2026-05-18, polish 2026-05-18).
             Sibling of #cat-grid; shown when a group tile is clicked.
             Layout:
               #group-page-banner   — group label + count (NOT sticky)
               #group-page-toolbar  — sticky bar with [actions...] [back-btn]
                                       In RTL flex-row, the LAST DOM child
                                       renders on the visual LEFT — so back
                                       sits leftmost. The actions container
                                       has flex:1 to push back to the edge.
               #group-page-cards    — category cards grid
        -->
        <div id="group-page" style="display:none">
            <div id="group-page-banner" style="border-radius:14px;padding:14px 18px;margin-bottom:12px;color:#fff;font-weight:bold;font-size:1.15em;text-align:center;box-shadow:0 4px 14px rgba(0,0,0,0.08)"></div>
            <div id="group-page-toolbar" style="position:sticky;top:0;z-index:50;background:white;display:flex;align-items:center;gap:8px;padding:8px 10px;margin:0 -6px 14px;border-radius:0 0 12px 12px;box-shadow:0 2px 6px rgba(0,0,0,0.08);flex-wrap:wrap">
                <div id="group-page-toolbar-actions" style="display:flex;gap:6px;flex-wrap:wrap;align-items:center;flex:1;min-width:0"></div>
                <button id="group-page-back-btn" type="button" style="padding:9px 16px;border:none;background:linear-gradient(135deg,#0d9488,#0891b2);color:white;border-radius:10px;cursor:pointer;font-weight:bold;font-size:1em;box-shadow:0 2px 6px rgba(13,148,136,0.25);min-height:38px;white-space:nowrap">← חזור</button>
            </div>
            <div id="group-page-cards" style="display:grid;grid-template-columns:repeat(auto-fill, minmax(160px, 1fr));gap:12px"></div>
        </div>

        <div id="vocab-add-section" class="add-section">
            <h3>+ קטגוריה חדשה</h3>
            <div class="add-row">
                <input type="text" id="new-cat-name" placeholder="שם הקטגוריה" onkeydown="if(event.key==='Enter')addCategory()">
                <button class="add-btn" onclick="addCategory()">צור</button>
            </div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;justify-content:center">
                <button onclick="importWordsJSON()" style="padding:6px 12px;border:2px solid #f59e0b;background:white;color:#f59e0b;border-radius:10px;cursor:pointer;font-weight:bold;font-size:0.85em">📥 ייבוא JSON</button>
                <button class="wa-bounce-btn" onclick="showWhatsAppSharePopupLanding()" style="padding:6px 12px;border:2px solid #25D366;background:white;color:#25D366;border-radius:10px;cursor:pointer;font-weight:bold;font-size:0.85em">💬 שלח לנו וואטצאפ!</button>
            </div>
        </div>
    </div>

    <!-- EDIT PAGE -->
    <div id="edit-page" class="edit-page">
        <div style="text-align:center;margin-bottom:16px;padding:16px 0">
            <button class="start-play-btn" onclick="editSave();var n=document.getElementById('edit-cat-name').value;if(n)enterGame(n);" style="padding:18px 56px;background:linear-gradient(135deg,#0d9488,#0891b2);color:white;border:none;border-radius:16px;cursor:pointer;font-weight:bold;font-size:1.55em;box-shadow:0 6px 20px rgba(13,148,136,0.4);letter-spacing:1px">▶ התחל לשחק</button>
        </div>
        <div class="edit-header">
            <input type="text" class="edit-cat-name" id="edit-cat-name" placeholder="שם הקטגוריה">
        </div>
        <div id="readonly-banner">🔒 קטגוריה מובנית — לצפייה בלבד</div>
        <div class="edit-primary-tools">
            <button class="publish-btn" id="edit-public-toggle-btn" onclick="_publicToggleCurrentCategory()">🌐 פרסם לכולם</button>
            <button class="record-share-btn" id="edit-share-link-btn" onclick="_openRecordingPageForCategory(editOriginalName)">🎤 צא לדף ההקלטות</button>
        </div>
        <div class="edit-secondary-tools">
            <button onclick="copyWordsText()" style="padding:6px 12px;border:2px solid #0d9488;background:white;color:#0d9488;border-radius:10px;cursor:pointer;font-weight:bold;font-size:0.85em">📋 העתק מילים</button>
            <button onclick="copyWordsJSON()" style="padding:6px 12px;border:2px solid #0891b2;background:white;color:#0891b2;border-radius:10px;cursor:pointer;font-weight:bold;font-size:0.85em">JSON</button>
            <button class="edit-import-json-btn" onclick="importJSONToCurrentCategory()" style="padding:6px 12px;border:2px solid #f59e0b;background:white;color:#f59e0b;border-radius:10px;cursor:pointer;font-weight:bold;font-size:0.85em">📥 הוסף באמצעות JSON</button>
            <button class="edit-import-table-btn" onclick="openTableImportToCurrentCategory()" style="padding:6px 12px;border:2px solid #0d9488;background:white;color:#0d9488;border-radius:10px;cursor:pointer;font-weight:bold;font-size:0.85em">📊 ייבוא מטבלה</button>
            <button class="wa-bounce-btn" onclick="showWhatsAppSharePopup()" style="padding:6px 12px;border:2px solid #25D366;background:white;color:#25D366;border-radius:10px;cursor:pointer;font-weight:bold;font-size:0.85em">💬 וואטסאפ</button>
        </div>
        <input type="text" id="edit-search" placeholder="חיפוש מילה..." dir="rtl" oninput="filterEditWords(this.value)" onkeydown="_vdCtrlGHandler(event,'edit-search',function(){filterEditWords(document.getElementById('edit-search').value)})" style="width:100%;padding:8px 12px;border:2px solid #e5e7eb;border-radius:10px;font-size:1em;margin-bottom:10px;box-sizing:border-box">
        <h3 style="color:#0d9488;margin-bottom:10px">מילים בקטגוריה</h3>
        <div style="display:flex;justify-content:flex-end;margin-bottom:6px">
            <button type="button" id="edit-add-mode-toggle" onclick="_toggleEditAddMode()" style="padding:5px 10px;border:1px dashed #0d9488;background:transparent;color:#0d9488;border-radius:8px;cursor:pointer;font-size:0.82em">⚡ הזנה מהירה</button>
        </div>
        <div class="edit-add-row" id="edit-add-row-classic">
            <input type="text" id="edit-add-arabic" placeholder="ערבית" dir="rtl" oninput="_updateEditAddBtnState();_updateTranslitPreview('edit-add-arabic')" onkeydown="_editAddEnter(event,'arabic')" onblur="this.value=transliterate(this.value);_updateEditAddBtnState();_updateTranslitPreview('edit-add-arabic')" style="font-family:'Times New Roman',serif;font-size:1.1em">
            <input type="text" id="edit-add-form" placeholder="תוספת (עה״פ בעתיד, רבים...)" dir="rtl" oninput="_updateEditAddBtnState();_updateTranslitPreview('edit-add-form')" onkeydown="_editAddEnter(event,'form')" onblur="_updateEditAddBtnState();_updateTranslitPreview('edit-add-form')" style="font-family:'Times New Roman',serif">
            <input type="text" id="edit-add-hebrew" placeholder="עברית" oninput="_updateEditAddBtnState()" onkeydown="_editAddEnter(event,'hebrew')">
            <button class="add-btn" id="edit-add-submit" onclick="editAddWord()">+ הוסף</button>
        </div>
        <div id="edit-add-arabic-preview" class="translit-preview" style="display:none;font-size:0.85em;color:#0d9488;margin:2px 0 4px;direction:rtl;font-family:'Times New Roman',serif"></div>
        <div id="edit-add-form-preview" class="translit-preview" style="display:none;font-size:0.85em;color:#0d9488;margin:0 0 8px;direction:rtl;font-family:'Times New Roman',serif"></div>
        <!-- Fast-entry mode (hidden by default; toggle activates it) — Amitai 2026-04-30 Stage3 (D+F) -->
        <div class="edit-add-fast" id="edit-add-fast" style="display:none;background:#f0fdfa;border:2px solid #0d9488;border-radius:10px;padding:10px 12px;margin-bottom:14px">
            <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:stretch">
                <input type="text" id="edit-add-fast-input" placeholder='كلب כלب  •  وزير المالية שר האוצר ولد ילד  (גם רשימה, מופרדת ברווח)' dir="auto" onkeydown="_editAddFastEnter(event)" style="flex:1;min-width:140px;padding:9px 12px;border:2px solid #0d9488;border-radius:8px;font-size:1.05em;font-family:'Times New Roman',serif">
                <button type="button" id="edit-add-fast-mic" onclick="_editAddFastMic()" title="הקלט מילה (ערבית)" style="padding:8px 12px;border:2px solid #0d9488;background:white;color:#0d9488;border-radius:8px;cursor:pointer;font-size:1.1em;flex-shrink:0">🎤</button>
                <button type="button" onclick="_editAddFastSubmit()" style="padding:8px 16px;border:none;background:#0d9488;color:white;border-radius:8px;cursor:pointer;font-weight:bold;font-size:1em;flex-shrink:0">+ הוסף</button>
            </div>
            <div id="edit-add-fast-preview" style="display:none;font-size:0.9em;color:#0d9488;margin-top:8px;direction:rtl"></div>
            <div style="font-size:0.78em;color:#6b7280;margin-top:6px;text-align:center;direction:rtl">💡 שפה ראשונה → שנייה = זוג. מעבר חזרה לראשונה = זוג חדש. ביטויים רב-מילתיים (כמו "وزير المالية") נשמרים כי רווח בתוך אותה שפה לא חותך.</div>
        </div>
        <div class="edit-import-table-cta" style="margin:12px 0 14px;padding:12px;border:2px solid #0d9488;border-radius:14px;background:linear-gradient(135deg,#ecfdf5,#e0f2fe);text-align:center;box-shadow:0 3px 12px rgba(13,148,136,0.12)">
            <button type="button" class="edit-import-table-btn" onclick="openTableImportToCurrentCategory()" style="width:100%;padding:13px 16px;border:none;background:linear-gradient(135deg,#0d9488,#0891b2);color:white;border-radius:12px;cursor:pointer;font-weight:900;font-size:1.08em;box-shadow:0 4px 14px rgba(13,148,136,0.28)">📊 ייבוא מטבלה / אקסל</button>
            <div style="font-size:0.82em;color:#0f766e;margin-top:7px;font-weight:700">הדבק טבלה של ערבית-עברית והוסף הרבה מילים בבת אחת</div>
        </div>
        <div class="word-list" id="edit-word-list"></div>
        <div class="edit-actions">
            <button class="edit-save-btn" onclick="editSaveInPlace()">💾 שמור</button>
            <button class="edit-save-btn" onclick="editSave()">💾 שמור וצא</button>
            <button class="edit-cancel-btn" onclick="editCancel()">ביטול</button>
        </div>
        <div class="edit-delete-cat" id="edit-delete-section">
            <button onclick="editDeleteCategory()">מחק קטגוריה</button>
        </div>
    </div>

    <!-- WHATSAPP SHARE POPUP -->
    <div id="wa-share-overlay" onclick="closeWhatsAppSharePopup()" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:9999;backdrop-filter:blur(4px)">
        <div onclick="event.stopPropagation()" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:white;border-radius:16px;padding:24px;max-width:480px;width:90%;max-height:80vh;overflow-y:auto;direction:rtl;text-align:right">
            <button onclick="closeWhatsAppSharePopup()" style="position:absolute;top:12px;left:12px;background:none;border:none;font-size:1.3em;cursor:pointer;color:#6b7280">✕</button>
            <h3 style="color:#25D366;margin:0 0 16px;font-size:1.1em">💬 שיתוף בקבוצת הוואטסאפ</h3>
            <div id="wa-share-text" style="background:#f0fdf4;border:2px solid #e5e7eb;border-radius:12px;padding:16px;font-size:0.95em;line-height:1.7;white-space:pre-wrap;margin-bottom:16px;color:#1e293b"></div>
            <div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:center;flex-direction:column;align-items:center">
                <a id="wa-group-link" href="#" target="_blank" style="padding:10px 20px;border:2px solid #25D366;background:#25D366;color:white;border-radius:10px;cursor:pointer;font-weight:bold;font-size:0.9em;text-decoration:none;display:inline-flex;align-items:center;justify-content:center">💬 הצטרף לקבוצה!</a>
                <button onclick="copyWhatsAppFullMessage()" style="padding:8px 16px;border:2px solid #0d9488;background:white;color:#0d9488;border-radius:10px;cursor:pointer;font-weight:bold;font-size:0.85em">📋 העתק קישור</button>
            </div>
        </div>
    </div>

    <!-- GAME PAGE -->
    <div id="game-page" class="game-page">
        <div class="mode-tabs" id="mode-tabs"></div>
        <div class="main">
            <!-- Flashcards (Quizlet-style) -->
            <div id="flashcards-mode" class="flashcard-area">
                <div class="star-filter" id="fc-star-filter" style="justify-content:center;margin-bottom:8px">
                    <button class="active" onclick="setFcStarFilter('all')">הכל</button>
                    <button onclick="setFcStarFilter('starred')">★ מסומנים</button>
                    <button onclick="setFcStarFilter('unstarred')">☆ לא מסומנים</button>
                </div>
                <div class="star-filter" id="fc-dir-toggle" style="justify-content:center;margin-bottom:8px">
                    <button class="active" onclick="setFcDirection('ar2he')">ערבית ← עברית</button>
                    <button onclick="setFcDirection('he2ar')">עברית ← ערבית</button>
                </div>
                <div class="star-filter" id="fc-bucket-filter" style="justify-content:center;margin-bottom:8px;flex-wrap:wrap">
                    <button id="fc-bf-all" class="active" onclick="setFcBucketFilter('all')">הכל</button>
                    <button id="fc-bf-known" onclick="setFcBucketFilter('known')">✓ ידעתי</button>
                    <button id="fc-bf-unknown" onclick="setFcBucketFilter('unknown')">✗ לא ידעתי</button>
                    <button id="fc-bf-notsure" onclick="setFcBucketFilter('notsure')">😲 ממש לא ידעתי</button>
                </div>
                <!-- Big CTA that appears when the deck is currently filtered to one bucket. Amitai 2026-04-19 21:20. -->
                <div id="fc-back-to-all" style="display:none;text-align:center;margin-bottom:10px">
                    <button onclick="setFcBucketFilter('all')" style="padding:14px 24px;border-radius:14px;border:none;background:linear-gradient(135deg,#0d9488,#0891b2);color:white;font-weight:800;cursor:pointer;font-size:1.05em;box-shadow:0 6px 18px rgba(13,148,136,0.35);min-width:260px">🔙 חזרה לכל הסט</button>
                </div>
                <!-- Progress bar -->
                <div class="fc-progress-bar"><div class="fc-progress-fill" id="fc-progress-fill" style="width:0%"></div></div>
                <div class="fc-progress-text" id="fc-progress-text">0 / 0</div>
                <!-- Card -->
                <div class="flashcard" id="flashcard" onclick="flipCard()">
                    <div class="flashcard-inner">
                        <div class="flashcard-front">
                            <div class="flashcard-arabic" id="fc-arabic"></div>
                            <div class="flashcard-form" id="fc-form"></div>
                        </div>
                        <div class="flashcard-back">
                            <div class="flashcard-hebrew" id="fc-hebrew"></div>
                        </div>
                    </div>
                    <div class="flashcard-hand-hint" id="fc-hand-hint" title="לחץ כדי להפוך" style="display:none"><span class="fc-hand-bubble">לחץ כאן כדי להפוך</span><span class="fc-hand-emoji">👆</span></div>
                </div>
                <!-- Knew / Didn't know / Really not sure buttons -->
                <div class="fc-verdict" id="fc-verdict">
                    <button class="fc-knew" onclick="fcVerdict('knew')" style="flex:4">✓ ידעתי</button>
                    <button class="fc-didnt-know" onclick="fcVerdict('didnt')" style="flex:4">✗ לא ידעתי</button>
                    <button class="fc-notsure" onclick="fcVerdict('notsure')" style="flex:2" title="ממש לא סגור על זה">😲</button>
                </div>
                <span class="flashcard-counter" id="fc-counter"></span>
                <button class="shuffle-btn" onclick="shuffleCards()">🔀 ערבב</button>
                <!-- Round complete panel -->
                <div class="fc-round-complete" id="fc-round-complete">
                    <h3>🎉 סיימת את החפיסה!</h3>
                    <div class="fc-round-stat" id="fc-round-stat"></div>
                    <div class="fc-round-improvement" id="fc-round-improvement"></div>
                    <div class="fc-round-buttons">
                        <button class="fc-round-btn-unknown" id="fc-btn-unknown" onclick="fcStartRound('unknown')">🔄 סבב עם מילים לא מוכרות</button>
                        <button class="fc-round-btn-all" onclick="fcStartRound('all')">▶ סבב חדש עם הכל</button>
                    </div>
                </div>
                <!-- Known / Unknown / Really-not-sure word lists -->
                <div class="fc-lists" id="fc-lists">
                    <div class="fc-list-section">
                        <div class="fc-list-header known-header" onclick="toggleFcList('known')">
                            <span>✓ יודע (<span id="fc-known-count">0</span>)</span>
                            <span id="fc-known-arrow">▼</span>
                        </div>
                        <div class="fc-list-body" id="fc-known-list"></div>
                    </div>
                    <div class="fc-list-section">
                        <div class="fc-list-header unknown-header" onclick="toggleFcList('unknown')">
                            <span>✗ לא יודע (<span id="fc-unknown-count">0</span>)</span>
                            <span id="fc-unknown-arrow">▼</span>
                        </div>
                        <div class="fc-list-body" id="fc-unknown-list"></div>
                    </div>
                    <div class="fc-list-section">
