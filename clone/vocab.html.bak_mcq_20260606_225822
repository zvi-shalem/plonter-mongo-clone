    <script>
    /* === Clone API guard (2026-05-28) ===
       This page is a CLONE deployed under the SAME ORIGIN as the live
       /plonter/ site, so it SHARES localStorage (incl. plonter_vocab_v2 and
       plonter_auth_token). It must NEVER hit /plonter/clone/api/ (the clone's
       api/ has empty DBs) — a failed/guest auth there can wipe the real
       user's vocab. App code already targets the absolute /plonter/api/; this
       is a belt-and-braces net that re-routes any stray same-origin api/ call
       to the LIVE backend. No-op for calls already under /plonter/api/. */
    (function () {
        var LIVE = '/plonter/api/';
        function fix(u) {
            try {
                if (typeof u !== 'string' || !u) return u;
                var abs = new URL(u, document.baseURI);
                if (abs.origin !== location.origin) return u;             // cross-origin: leave
                if (abs.pathname.indexOf('/plonter/api/') === 0) return u; // already live: leave
                var m = abs.pathname.match(/\/api\/(.*)$/);
                if (!m) return u;                                          // not an api call
                return LIVE + m[1] + abs.search + abs.hash;
            } catch (e) { return u; }
        }
        if (window.fetch) {
            var _f = window.fetch;
            window.fetch = function (input, init) {
                if (typeof input === 'string') return _f.call(this, fix(input), init);
                return _f.call(this, input, init);
            };
        }
        var _o = XMLHttpRequest.prototype.open;
        XMLHttpRequest.prototype.open = function (method, url) {
            try { arguments[1] = fix(url); } catch (e) {}
            return _o.apply(this, arguments);
        };
    })();
    </script>
